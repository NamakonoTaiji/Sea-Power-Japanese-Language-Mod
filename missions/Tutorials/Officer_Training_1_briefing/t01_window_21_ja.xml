<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:SeapowerUI"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=400}"
    Padding="5,5,5,5">
    <ScrollViewer>
        <StackPanel Orientation="Vertical">
            <TextBlock
                TextWrapping="Wrap" Margin="15" FontFamily="Roboto">
                <TextBlock.Inlines>
                    <Run FontWeight="Bold" Text="フライトデッキ - 航空機の発艦" FontSize="16" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="右下に新しいウィンドウが表示される。ウィンドウのヘッダーで左マウスボタンを長押ししてドラッグすると、ウィンドウを移動できることを覚えておこう。"
                        FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="フライトデッキメニューから、「USS ギャラリー」がSH-2Fヘリコプターを2機搭載していることがわかる。本艦は1種類の航空機しか搭載していないため、デフォルトで選択されており、魚雷2本とソノブイ15発からなるデフォルトのASW兵装も同様に選択されている。"
                        FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="対潜兵装のヘリコプター1機を発艦準備させ、Launchボタンを押して発艦プロセスを開始する。航空機の発艦には時間がかかるため、戦闘中の行動にはこの点を考慮に入れる必要がある。"
                        FontSize="12" />
                </TextBlock.Inlines>
            </TextBlock>
            <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                <Button
                    Width="100" Height="50" Margin="0,0,15,0" FontSize="16"
                    VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_20_ja.xml" />
                <Button Width="100" Height="50" Margin="0" FontSize="16" VerticalAlignment="Bottom"
                    Content="次へ" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_22_ja.xml" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>