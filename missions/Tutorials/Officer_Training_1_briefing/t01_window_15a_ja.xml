<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:SeapowerUI"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=400}"
    Padding="5,5,5,5">
    <ScrollViewer>
        <StackPanel Orientation="Vertical">
            <TextBlock
                TextWrapping="Wrap" Margin="15" FontFamily="Roboto">
                <TextBlock.Inlines>
                    <Run FontWeight="Bold" Text="艦載兵装の使用 - RGM-84 ハープーン" FontSize="16" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="見事だ、指揮官。SM-1MRミサイルに加え、「USS ギャラリー」は" FontSize="12" />
                    <Run
                        FontWeight="Bold" Text="RGM-84A ハープーン" FontSize="12" />
                    <Run
                        Text="も装備している。これは水上艦および浮上した潜水艦に対して使用できる超水平線対艦ミサイルだ。米海軍が使用する主要な対艦兵器である。"
                        FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run Text="別の標的ドローンが識別された。SM-1MRの発射時と同じ手順で、このドローンをハープーンの目標に指定せよ。" FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="注：ハープーンはアクティブ・レーダー・シーカーを使用する。これは、チャフによって欺瞞されたり、意図した目標よりも大きなレーダー反射を持つ目標（大型の民間商船など）を誤って標的にする可能性があることを意味する。このため、混雑した海域ではハープーンの使用は困難な場合があり、代わりにスタンダードミサイルを使用すべきである！"
                        FontSize="12" />
                </TextBlock.Inlines>
            </TextBlock>
            <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                <Button
                    Width="100" Height="50" Margin="0,0,15,0" FontSize="16"
                    VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_15_ja.xml" />
                <Button Width="100" Height="50" Margin="0" FontSize="16" VerticalAlignment="Bottom"
                    Content="次へ" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_16_ja.xml" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>