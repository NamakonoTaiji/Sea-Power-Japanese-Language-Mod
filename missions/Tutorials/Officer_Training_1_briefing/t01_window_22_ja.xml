<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:SeapowerUI"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=400}"
    Padding="5,5,5,5">
    <ScrollViewer>
        <StackPanel Orientation="Vertical">
            <TextBlock
                TextWrapping="Wrap" Margin="15" FontFamily="Roboto">
                <TextBlock.Inlines>
                    <Run FontWeight="Bold" Text="ヘリコプター - 偵察任務" FontSize="16" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="艦載ヘリコプターは、SH-2F（およびソ連のKa-25/Ka-27）が空中水上捜索レーダーを搭載しているため、水上艦または水上戦闘群（SAG）が地域を偵察するための主要な手段の一つである。"
                        FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="ヘリコプターが発艦したら、戦術ディスプレイでクリックするか、フォーメーションマネージャー内でクリックして選択できる。その後、センサーオプションを使用して水上捜索レーダーを起動する。"
                        FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="ヘリコプターのレーダーが起動したら、レーダー水平線を広げるために高度を上げる必要がある。左下のAltitudeボタンを使い、ヘリコプターに高度10,000フィートへの上昇を命じよ。"
                        FontSize="12" />
                </TextBlock.Inlines>
            </TextBlock>
            <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                <Button
                    Width="100" Height="50" Margin="0,0,15,0" FontSize="16"
                    VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_21_ja.xml" />
                <Button Width="100" Height="50" Margin="0" FontSize="16" VerticalAlignment="Bottom"
                    Content="次へ" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_23_ja.xml" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>