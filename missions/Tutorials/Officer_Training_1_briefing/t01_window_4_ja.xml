<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:SeapowerUI"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=400}"
    Padding="5,5,5,5">
    <ScrollViewer>
        <StackPanel Orientation="Vertical">
            <TextBlock TextWrapping="Wrap" Margin="15" FontFamily="Roboto">
                <TextBlock.Inlines>
                    <Run FontWeight="Bold" Text="カメラモード" FontSize="16" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="Sea Power では、複数のカメラモードで異なる視点を提供している。デフォルトでは追従カメラ（Follow Camera）になっている。このビューは、左側の戦術ディスプレイでユニットをクリックすると自動的に開かれ、選択したユニットを追従する。"
                        FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="その他にフリーカメラ（F2キー）とフライバイカメラ（F3キー）がある。F2キーを押してカメラをパンさせ、同時にWASDキーでゲームワールド内のカメラを動かしてみよう。ShiftキーまたはCtrlキーを押しながらでフリーカメラの速度を調整でき、RキーとFキーで上昇・下降する。F1キーを押すと、選択したユニットの追従カメラに戻る。"
                        FontSize="12" />
                </TextBlock.Inlines>
            </TextBlock>

            <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                <Button Width="100" Height="50" Margin="0,0,15,0" FontSize="16"
                    VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_3_ja.xml" />
                <Button Width="100" Height="50" Margin="0" FontSize="16" VerticalAlignment="Bottom"
                    Content="次へ" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_5_ja.xml" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>