<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:SeapowerUI"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=400}"
    Padding="5,5,5,5">
    <ScrollViewer>
        <StackPanel Orientation="Vertical">
            <TextBlock
                TextWrapping="Wrap" Margin="15" FontFamily="Roboto">
                <TextBlock.Inlines>
                    <Run FontWeight="Bold" Text="艦載兵装の使用 - 射撃中止" FontSize="16" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="見事な射撃だ！戦術ディスプレイ（または編隊マネージャー）から「USS ギャラリー」を選択し、Xキーを押して砲手に射撃中止を命じよ。"
                        FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run Text="ユニットを右クリックし、「撃ち方やめ」を選択することでも、射撃中止を命令できる。" FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="射撃中止命令は、砲だけでなく全ての兵装タイプに有効であり、そのユニットの全ての攻撃命令キューに影響する。" FontSize="12" />
                </TextBlock.Inlines>
            </TextBlock>
            <StackPanel
                Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                <Button
                    Width="100" Height="50" Margin="0,0,15,0" FontSize="16"
                    VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_18_ja.xml" />
                <Button Width="100" Height="50" Margin="0" FontSize="16" VerticalAlignment="Bottom"
                    Content="次へ" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_20_ja.xml" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>