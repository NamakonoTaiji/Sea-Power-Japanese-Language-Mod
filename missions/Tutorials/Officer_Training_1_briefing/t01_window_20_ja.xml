<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:SeapowerUI"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=400}"
    Padding="5,5,5,5">
    <ScrollViewer>
        <StackPanel Orientation="Vertical">
            <TextBlock
                TextWrapping="Wrap" Margin="15" FontFamily="Roboto">
                <TextBlock.Inlines>
                    <Run FontWeight="Bold" Text="フライトデッキ" FontSize="16" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="兵装の使用方法を学んだところで、次は艦のフライトデッキからヘリコプターを発着艦させる方法を見ていこう。" FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="「USS ギャラリー」は後部格納庫に対潜・偵察ヘリコプターSH-2Fを2機搭載している。搭載ヘリは戦力増強装置（フォース・マルチプライヤー）であり、本艦の主要な対潜戦（ASW）兵装として機能する。また、水上捜索レーダーも搭載しており、そのデータは自動的に母艦へデータリンクされる。"
                        FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="フライトデッキを開くには、艦を右クリックして「フライトデッキ」メニューオプションを選択するか、右下の小さな飛行機アイコンをクリックする。ウィンドウが開いたら、左マウスボタンでクリック＆ドラッグして移動させることができる。"
                        FontSize="12" />
                </TextBlock.Inlines>
            </TextBlock>
            <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                <Button
                    Width="100" Height="50" Margin="0,0,15,0" FontSize="16"
                    VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_19_ja.xml" />
                <Button Width="100" Height="50" Margin="0" FontSize="16" VerticalAlignment="Bottom"
                    Content="次へ" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_21_ja.xml" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>