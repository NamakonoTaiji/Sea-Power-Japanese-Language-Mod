<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="航空投下魚雷" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto" FontSize="12">
                    <TextBlock.Inlines>
                        <Run
                            Text="魚雷は対潜ヘリコプターの主要な兵装である。今回の場合、我々のHSS-2Bヘリは、艦のMk32短魚雷発射管（SVTT）から発射されるものと同じMk46短魚雷を搭載している。ヘリ搭載魚雷と艦載魚雷は同じ弾薬ストックから供給されるため、ヘリから魚雷を投下すると艦の魚雷在庫が減少する。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="注：すべての米国/NATO/日本のヘリは（デフォルトで）Mk46魚雷を2本しか搭載しないが、HSS-2BとSH-3Hは、ヘリが4本の魚雷を搭載できる「対潜兵器」兵装を備えている。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="また、航空投下魚雷は必然的に艦載魚雷よりも威力が低いことにも注意。ヘリコプターや航空機から投下された魚雷で撃沈を記録するには、複数回の命中が必要な場合があることを覚えておくこと！" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_3_briefing/t03_window_19_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_3_briefing/t03_window_21_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>