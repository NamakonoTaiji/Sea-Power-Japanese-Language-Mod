<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="ソノブイパターンの設定" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto" FontSize="12">
                    <TextBlock.Inlines>
                        <Run Text="ヘリコプターが使用できる兵器とセンサーの種類について説明したので、ヘリコプターを使ってノイズコンタクトを追跡しよう。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="フォーメーションマネージャーからHSS-2Bを選択し、ノイズコンタクトの周囲にソノブイのパターンを配置せよ。Ctrlキーを押しながらでプリセットパターンを、Shiftキーを押しながら戦術ディスプレイ上を右クリックすることで手動で配置できる。Ctrl+Shiftキーでより大きなパターンを設定可能。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="注意：ソノブイは変温層の上または下に配置できる。下部バーのAN/SSQ-53を右クリックして、上か下かを選択する。「断続放射」パターンを使用すると、1つを上に、次の1つを下に配置できる。コンタクトを探知する可能性を最大化するために、ブイを変温層の上と下の両方に配置することが推奨される！" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_3_briefing/t03_window_22_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_3_briefing/t03_window_24_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>