<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="攻撃の実行" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto">
                    <TextBlock.Inlines>
                        <Run
                            Text="ミサイルがアメリカ船団に命中するまで見守り続ける。何らかの理由で最初の一斉射撃ですべての船を沈められなかった場合は、必ずK-175からさらに4発のミサイルを発射すること。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="それでもすべてのアメリカ船を沈められない場合、最後の選択肢は、非常に短い距離まで接近し、オズモトリテルヌイに搭載されたSS-N-22ミサイルを使用して船団を沈めることである。しかし、12発のSS-N-3の一斉射撃で（比較的に）無防備な船団を沈めるには十分であるため、これが必要になる可能性は非常に低い。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="NATO船団がイージス巡洋艦やさらに多くの護衛艦によって防護されている、より困難なシナリオでは、多くのプラットフォームが貢献する完璧なToT攻撃を調整することが絶対に必要であることがわかるであろう！" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_25_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_27_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>