<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="攻撃の調整" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto">
                    <TextBlock.Inlines>
                        <Run Text="司令部から情報を受け取ったので、マークされた捜索範囲内のレーダー接触は敵性であると安全に想定できる。" />
                        <LineBreak />
                        <LineBreak />
                        <Run Text="偵察機をマークされた捜索範囲に近づけ続けること。また、艦船にマークされた範囲の近くにウェイポイントを与え、距離を詰めること。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="ヴァリャーグに搭載されたSS-N-3Bミサイルの射程は、下部バーのミサイルをクリックする（赤い射程円が表示される）か、ユニット参照を使用して最大射程を確認することで確認できることを覚えておくこと。攻撃を開始する前に、フォーメーションをSS-N-3Bミサイルの射程内に移動させること！" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_19_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <i:InvokeCommandAction Command="{Binding ExecuteTriggerCommand}"
                                    CommandParameter="Sidechange Echo" />
                                <i:InvokeCommandAction Command="{Binding OpenFileCommand}"
                                    CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_21_ja.xml" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>