<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="攻撃の連携" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto">
                    <TextBlock.Inlines>
                        <Run
                            Text="では、エコー級巡航ミサイル潜水艦K-175を見てみよう。編隊マネージャーまたは戦術ディスプレイからそれを選択し、ユニット参照を開いて確認すること。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="エコー級は旧式の巡航ミサイル潜水艦であり、8発のSS-N-3シャドック対艦ミサイルを搭載している。これらはヴァリャーグに搭載されているミサイルと同型である。これらは旧式のミサイルであるため、アメリカ軍を確実に撃破するためには、潜水艦と巡洋艦の間で目標到達時間差攻撃を連携させる必要がある。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="注：K-175はミサイルを発射するために浮上する必要があり、ミサイルに中間誘導を提供するために目標捕捉レーダーを有効にしたまま水上にとどまらなければならない。また、一度に4発のミサイルしか誘導できない。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_20_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_22_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>