<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="その他の探知手段" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto">
                    <TextBlock.Inlines>
                        <Run Text="必要に応じて時間圧縮を使用してシナリオを進めること。 " />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="では、「その他の探知方法」について説明しよう。これは、我々の艦船や航空機が利用できるセンサー以外のあらゆる方法を指す。通常、外部から探知された接触は、ゲーム内のポップアップメッセージやイベントログに保存される「インテル」メッセージの形で我々に届けられる。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="上級司令部から我々に伝えられる可能性のある探知方法には、水中聴音アレイ接触（SOSUS）、この地域上空のレーダー海洋偵察衛星（RORSAT）通過、さらには軍艦や潜望鏡を目撃した漁師からの無線報告さえも含まれる！この挙動はシナリオにプログラムされており、一般的に早期アクセスでは「動的」ではない。例については、「次へ」をクリックすること。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_17_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <i:InvokeCommandAction Command="{Binding ExecuteTriggerCommand}"
                                    CommandParameter="RORSAT message" />
                                <i:InvokeCommandAction Command="{Binding OpenFileCommand}"
                                    CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_19_ja.xml" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>