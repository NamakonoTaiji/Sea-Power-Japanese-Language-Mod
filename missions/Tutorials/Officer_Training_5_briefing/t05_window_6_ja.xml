<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="偵察のための艦載ヘリコプターの使用" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto">
                    <TextBlock.Inlines>
                        <Run
                            Text="Tu-95RTが北方で捜索を開始している間に、他の捜索資産に移行しよう。我々の艦船の一つ、ソヴレメンヌイ級駆逐艦「オズモトリテルヌイ」は、Ka-27PLヘリコプターを搭載している。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="これらのヘリコプターは、対潜水艦戦や、米国のSH-2Fと同様の空中レーダープラットフォームとして使用することができる。フライトデッキコントロールを使用して、Ka-27PLヘリコプターを空のロードアウト（最大航続距離のため）で発艦させ、その後、独自の捜索を開始するためにレーダーをオンにした状態で16,000フィートまで上昇するよう命令する。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_5_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_7_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>