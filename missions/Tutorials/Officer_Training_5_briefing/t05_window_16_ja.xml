<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="スパイ・トローラー" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto">
                    <TextBlock.Inlines>
                        <Run
                            Text="では、広大な海域を捜索する他の方法について説明しよう。我々はソ連軍としてプレイしているので、オケアン級スパイ・トローラーを利用できる。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="オケアン級トローラーは、東ドイツで建造された外航トロール船であり、ソ連によって世界中の情報収集任務に投入されている。これらのトロール船は驚異的な航続距離を持ち、冷戦中、NATOの戦闘群を追跡する光景がよく見られた。" />
                        <LineBreak />
                        <LineBreak />
                        <Run Text="オケアン級トロール船をクリックして、今すぐ調べてみよう。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_15_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_17_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>