<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=400}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="航空機の発艦 - AEW航空機の選択" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto" FontSize="12">
                    <TextBlock.Inlines>
                        <Run
                            Text="フライトデッキメニューには、空母で利用可能なすべての航空機が表示されます。ほとんどの場合、最初に発艦させるべき航空機は、早期警戒（AEW）航空機です。これらの航空機は、米国の用語ではAWACS（空中警戒管制システム）と呼ばれます。ドロップダウンメニューを使用して、航空機の種類を「" />
                        <Run Text="P-42RLDN" FontWeight="Bold" />
                        <Run Text="」に変更してください。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="AEW航空機は、非常に強力な長距離対空および対水上捜索レーダーを装備しており、空中指揮所および偵察プラットフォームとして機能します。" />
                        <LineBreak />
                        <LineBreak />
                        <Run Text="兵装を「早期警戒」のままにして、「" />
                        <Run Text="発艦" FontWeight="Bold" />
                        <Run Text="」を押してAEW航空機を1機発艦させてください。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_4_briefing/t04_window_3_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_4_briefing/t04_window_5_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>