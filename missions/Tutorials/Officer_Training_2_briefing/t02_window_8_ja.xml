<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical"
                Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15"
                    FontFamily="Roboto" FontSize="16" FontWeight="Bold" Text="リーダーへのウェイポイント設定" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto" FontSize="12">
                    <TextBlock.Inlines>
                        <Run
                            Text="次に、編隊へのウェイポイント追加について見ていこう。先ほどと同様に、リュッチェンスを選択していることを確認し、西側（方位およそ270）のどこかに新しいウェイポイントを編隊に与えよう。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="リュッチェンスにウェイポイントを指示すると、全艦が編隊長に追従して転舵する。注意：編隊に新しいウェイポイントを与える際は、必ず編隊長にのみ指示を出すこと！" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel
                    Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button
                        Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom"
                        Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_2_briefing/t02_window_7_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom"
                        Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_2_briefing/t02_window_9_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>