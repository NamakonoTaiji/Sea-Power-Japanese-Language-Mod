<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical"
                Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15"
                    FontFamily="Roboto" FontSize="16" FontWeight="Bold" Text="艦の編隊への復帰命令" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto" FontSize="12">
                    <TextBlock.Inlines>
                        <Run
                            Text="見事だ、司令官。では、ナルヴィクを右クリックし、『編隊（Formation）』、次に『編隊に復帰（Return to Formation）』をクリックして、編隊へ復帰するよう命令しよう。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="これにより、ナルヴィクは編隊内の元の配置位置に戻るよう命令される。再び時間圧縮を使い、艦が配置位置に戻る様子を観察できる。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel
                    Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button
                        Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom"
                        Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_2_briefing/t02_window_17_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom"
                        Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_2_briefing/t02_window_19_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>