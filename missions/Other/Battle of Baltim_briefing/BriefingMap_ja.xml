<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[NileDelta_Close]}" />
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5"
            BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform"
                    Source="{Binding Assets[EasternMedFar]}" Width="250" />
                <Border
                    BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Width="30" Height="20" Margin="125,0,0,45"
                    BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>
        <Border Canvas.Left="10" Canvas.Top="10"
            BorderThickness="5" BorderBrush="White">
            <Border.Effect>
                <DropShadowEffect
                    Opacity="0.25" />
            </Border.Effect>
            <Border.RenderTransform>
                <TransformGroup>
                    <RotateTransform Angle="5" CenterY="200" />
                </TransformGroup>
            </Border.RenderTransform>
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[IDFMissileBoatsAfterLatakia]}"
                    Width="250" />
            </Grid>
        </Border>
        <Border
            Canvas.Left="10" Canvas.Bottom="10" BorderThickness="3"
            BorderBrush="{StaticResource NTDS.FriendColour}" Background="#90a3b6" Width="250">
            <TextBlock Foreground="Blue" TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run Text="イスラエル海軍第3艦隊:" TextDecorations="Underline" />
                <LineBreak />
                <LineBreak />
                <Run Text="INS ミスガヴ" />
                <LineBreak />
                <Run Text="INS エイラート" />
                <LineBreak />
                <Run Text="INS レシェフ" />
                <LineBreak />
                <Run Text="INS ケシェット" />
                <LineBreak />
                <Run Text="INS スーファ" />
                <LineBreak />
                <Run Text="INS ヘレヴ" />
            </TextBlock>
        </Border>
        <TextBlock Foreground="SteelBlue"
            Text="地中海" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold"
            Canvas.Left="500" Canvas.Top="150" />
        <TextBlock Foreground="Black" Text="エジプト"
            HorizontalAlignment="Center" FontSize="18" FontWeight="Bold" Canvas.Left="530"
            Canvas.Top="600" />
        <TextBlock Foreground="Black" Text="バルティム"
            HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="625"
            Canvas.Top="420" />
        <StackPanel Orientation="Vertical" Canvas.Left="600"
            Canvas.Top="250">
            <TextBlock Foreground="Blue" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="第3艦隊ミサイル艇" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5"
                HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="300" Canvas.Top="325">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run
                    Text="エジプト海軍オーサ型ミサイル艇" />
            </TextBlock>
            <Canvas
                Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
        <Path Canvas.Left="545" Canvas.Top="315"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="250" />
            </Path.RenderTransform>
        </Path>
    </Canvas>
</Viewbox>