<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[Karachi_Close]}" />
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5"
            BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform"
                    Source="{Binding Assets[IndiaPakistanFar]}" Width="250" />
                <Border
                    BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Width="30" Height="20" Margin="50,0,0,120"
                    BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>
        <Border Canvas.Top="10" Canvas.Left="10"
            BorderThickness="5" BorderBrush="White">
            <Border.Effect>
                <DropShadowEffect
                    Opacity="0.25" />
            </Border.Effect>
            <Border.RenderTransform>
                <TransformGroup>
                    <RotateTransform Angle="5" CenterY="200" />
                </TransformGroup>
            </Border.RenderTransform>
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[photo_indian_navy_osa]}"
                    Width="250" />
            </Grid>
        </Border>
        <Border Canvas.Left="10"
            Canvas.Bottom="10" BorderThickness="3" BorderBrush="{StaticResource NTDS.FriendColour}"
            Background="#90a3b6" Width="250">
            <TextBlock Foreground="Blue"
                TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run
                    Text="カラチ攻撃部隊:" TextDecorations="Underline" />
                <LineBreak />
                <LineBreak />
                <Run Text="INS キルタン P79" />
                <LineBreak />
                <Run Text="INS カッチャル P81" />
                <LineBreak />
                <Run Text="INS ヴィール K82" />
                <LineBreak />
                <Run Text="INS ニパト K86" />
                <LineBreak />
                <Run Text="INS ニルガート K89" />
            </TextBlock>
        </Border>
        <TextBlock Foreground="SteelBlue" Text="アラビア海" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="150" Canvas.Top="400" />
        <TextBlock
            Foreground="Black" Text="パキスタン" HorizontalAlignment="Center" FontSize="18"
            FontWeight="Bold" Canvas.Left="1000" Canvas.Top="300" />
        <TextBlock
            Foreground="Black" Text="カラチ" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="700" Canvas.Top="125" />
        <StackPanel
            Orientation="Vertical" Canvas.Left="600" Canvas.Top="550">
            <TextBlock
                Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="カラチ攻撃部隊" />
            </TextBlock>
            <Canvas Width="22.5"
                Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Submarine}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="450" Canvas.Top="250">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="パキスタン海軍哨戒部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5"
                HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="650" Canvas.Top="350">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="パキスタン海軍哨戒部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5"
                HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
        <Path Canvas.Left="620" Canvas.Top="475"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="340" />
            </Path.RenderTransform>
        </Path>
    </Canvas>
</Viewbox>