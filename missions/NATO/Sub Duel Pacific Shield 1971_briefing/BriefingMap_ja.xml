<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas Width="1095" Height="662">
        <Image
            Source="{Binding Assets[EasternPacificCalifornia_Close]}" />
        <Border
            Canvas.Right="10" Canvas.Bottom="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[EasternPacificFar]}"
                    Width="250" />
                <Border BorderThickness="2"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="30" Height="20"
                    Margin="130,0,0,80" BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>
        <TextBlock Foreground="SteelBlue" Text="太平洋"
            HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold"
            Canvas.Left="300" Canvas.Top="500" />
        <TextBlock Foreground="Black"
            Text="カリフォルニア" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"
            Canvas.Left="975" Canvas.Top="50" />
        <StackPanel
            Orientation="Vertical" Canvas.Left="600" Canvas.Top="300">
            <TextBlock
                Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="潜水艦スキャンプ (SSN-588)" />
            </TextBlock>
            <Canvas
                Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Submarine}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="450"
            Canvas.Top="250">
            <TextBlock
                Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run
                    Text="ヤンキー級SSBN (推定)" />
            </TextBlock>
            <Canvas
                Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Submarine}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
    </Canvas>
</Viewbox>