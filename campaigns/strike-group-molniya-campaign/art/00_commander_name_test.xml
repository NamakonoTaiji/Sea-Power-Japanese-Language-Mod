<Page
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignWidth="1920"
  d:DesignHeight="1080">

    <StackPanel Orientation="Vertical" Margin="20">

        <TextBlock FontSize="24" Foreground="White">
        Comrade Captain, what is your name?
        </TextBlock>
		
        <TextBlock FontSize="16" Margin="0,10,0,15">
        This name will be used for all campaign events, briefings, messages, and awards. 
		<LineBreak/>
		<LineBreak/>
		Note: experimental - does not currently work!
        </TextBlock>
		
        <TextBox x:Name="CommanderNameBox" Width="300" MaxLength="100" Content="{Binding DataSource.PersistentData[CommanderName]}"/>

        <Button Width="120" Margin="0,15,0,0" Content="Submit" />
		
    </StackPanel>
</Page>