<!-- Campaign event template for standard USN-style "daily intentions message" (DIM) - formatting taken from real world examples -->

<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">

	<Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16" Padding="45">
		<Border.Effect>
			<DropShadowEffect />
		</Border.Effect>
		<Border.Background>
			<ImageBrush ImageSource="{Binding Assets[bkg_paper]}" Stretch="UniformToFill"/>
		</Border.Background>
		
        <StackPanel Orientation="Vertical">

		<Grid
		  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" >
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="3*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			
			<TextBlock Grid.Row="0" Grid.Column="0" Text="NAVAL MESSAGE" Margin="0" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Left"/>
			<TextBlock Grid.Row="0" Grid.Column="1" Text="*******S E C R E T*******" Margin="40,0,40,0" FontWeight="Bold" TextAlignment="Center"/>
			<TextBlock Grid.Row="0" Grid.Column="2" Text="NAVY DEPARTMENT" Margin="0" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Right"/>
			
		</Grid>
		
		<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,1"/>
		<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,10"/>

			<Grid
			  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
			<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="10"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="10"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" FontSize="16">
					ROUTINE<LineBreak/>
					R 011200Z JUL 85
				</TextBlock>
				
				<TextBlock Grid.Row="1" Grid.Column="3" FontSize="16" Text="ZYUW RUHGOAA0777 1821200"/>


				<TextBlock Grid.Row="3" Grid.Column="0" FontSize="16" Text="FM"/>
				<TextBlock Grid.Row="3" Grid.Column="2" FontSize="16" Text="CTF 77 YOKOSUKA JA"/>
				<TextBlock Grid.Row="4" Grid.Column="0" FontSize="16" Text="TO"/>
				<TextBlock Grid.Row="4" Grid.Column="2" FontSize="16">
					<Run Text="COMMANDER"/>
					<Run Text="{Binding DataSource.PersistentData[PlayerTaskForceName], Converter={StaticResource UppercaseConverter}}"/>
					<Run Text="NAHA OKINAWA JA"/>
				</TextBlock>
				<TextBlock Grid.Row="11" Grid.Column="0" FontSize="16" Text="INFO"/>
				<TextBlock Grid.Row="11" Grid.Column="2" FontSize="16" Text="CINCPACFLT PEARL HARBOR HI"/>
				<TextBlock Grid.Row="12" Grid.Column="2" FontSize="16" Text="COMUSJAPAN YOKOTA AB JA"/>
				<TextBlock Grid.Row="13" Grid.Column="2" FontSize="16" Text="CNO WASHINGTON DC"/>
				<TextBlock Grid.Row="14" Grid.Column="0" FontSize="16" Text="SUBJ"/>
				<TextBlock Grid.Row="14" Grid.Column="2" FontSize="16" Text="INTSUM 01/1200Z - 02/1200Z - WESTERN PACIFIC"/>

				<TextBlock Grid.Row="15" Grid.ColumnSpan="4" FontSize="16" TextWrapping="Wrap">
					<LineBreak/>
					SECRET
					<LineBreak/>
					BT
					<LineBreak/>
					<LineBreak/>
					1. (S) SUMMARY: Enemy offensive operations continue across WESTPAC. Soviet and Chinese forces are exploiting early Allied dislocation in Japan, Korea, Philippines, and Southeast Asia. Current enemy movements indicate southward operational focus toward South China Sea, with probable intent to isolate Singapore and sever Allied SLOCs to Indian Ocean.
					<LineBreak/>
				</TextBlock>
				<TextBlock Grid.Row="16" Grid.ColumnSpan="4" FontSize="16" TextWrapping="Wrap">
					2. (S) ENEMY SITUATION: KIEV carrier group transited Tsushima Strait 30JUN after destroying ROK surface forces attempting to oppose passage. KIEV remains unlocated. KIROV and SLAVA surface groups are also unlocated - current assessment places one or both groups moving south in support of broader enemy offensive.
					<LineBreak/>
				</TextBlock>
				<TextBlock Grid.Row="17" Grid.ColumnSpan="4" TextWrapping="Wrap">
					3. (S) FRIENDLY STATUS:
				</TextBlock>	
				<TextBlock Grid.Row="18" Grid.ColumnSpan="4" TextWrapping="Wrap" Margin="20,0,0,0">	
					- KITTY HAWK remains unavailable after striking mine outside Yokosuka. CVW-9 aircraft have been flown off and dispersed ashore pending reassignment.
					<LineBreak/>
					- CONSTELLATION and Battle Group DELTA are assuming Defense of Japan mission.
					<LineBreak/>
					- TF 77 surface striking force inport Okinawa after MAGIC THUNDER action in Taiwan Strait.
					<LineBreak/>
				</TextBlock>	
				<TextBlock Grid.Row="19" Grid.ColumnSpan="4" TextWrapping="Wrap">
					4. (S) ALLIED / REGIONAL STATUS: Japan and Korea are under heavy Soviet air, missile, and naval attack; surviving forces are committed to homeland defense. Malaysia and Singapore report attacks by Soviet and Vietnamese air forces. Indonesian central authority is paralyzed with President Suharto unaccounted for. India has declared neutrality, but current reporting indicates Soviet forces are utilizing Indian ports and airfields for resupply.
					<LineBreak/>
				</TextBlock>
				<TextBlock Grid.Row="21" Grid.ColumnSpan="4" TextWrapping="Wrap">
					5. (S) ASSESSMENT: Enemy intent is assessed as rapid exploitation before U.S. carrier and logistics forces can respond. Indonesian paralysis and tacit cooperation of India with USSR significantly reduces Allied options in southern flank.
					<LineBreak/>
				</TextBlock>
				<TextBlock Grid.Row="23" Grid.ColumnSpan="4" TextWrapping="Wrap">
					6. (S) COMMANDER'S COMMENTS: Pact forces have shown remarkable aggressiveness not anticipated in any pre-war planning. Defense of Singapore now depends on rapid concentration of available naval forces before Soviet and Vietnamese action can close the South China Sea approaches. Further orders will follow by separate traffic. Good luck and godspeed. CTF 77 sends.
					<LineBreak/>
				</TextBlock>
				<TextBlock Grid.Row="25" Grid.ColumnSpan="4" TextWrapping="Wrap">
					SIGNED: EDWARDS
					<LineBreak/>
					CTF 77
					<LineBreak/>
					<LineBreak/>
					BT
					<LineBreak/>
					SECRET DECL OADR
					<LineBreak/>
				</TextBlock>
			</Grid>
        </StackPanel>
    </Border>
</ScrollViewer>
