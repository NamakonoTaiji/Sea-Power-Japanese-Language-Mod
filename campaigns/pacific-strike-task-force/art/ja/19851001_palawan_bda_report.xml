<!-- Pacific Strike battle damage assessment event: naval-message paper format. -->
<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16" Padding="45">
    <Border.Effect>
      <DropShadowEffect />
    </Border.Effect>
    <Border.Background>
      <ImageBrush ImageSource="{Binding Assets[bkg_paper]}" Stretch="UniformToFill"/>
    </Border.Background>

    <StackPanel Orientation="Vertical">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="3*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="海軍電信" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Left"/>
        <TextBlock Grid.Column="1" Text="*******極  秘*******" Margin="40,0,40,0" FontWeight="Bold" TextAlignment="Center"/>
        <TextBlock Grid.Column="2" Text="海軍省" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Right"/>
      </Grid>

      <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,1"/>
      <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,10"/>

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" HorizontalAlignment="Left" FontSize="16">
          至急（IMMEDIATE）<LineBreak/>
          O 011200Z OCT 85
        </TextBlock>

        <TextBlock Grid.Row="0" Grid.Column="3" FontSize="16" Text="ZYUW RUHGOAA0777 2741200"/>
      </Grid>

      <Grid Margin="0,18,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" FontSize="16" Text="発"/>
        <TextBlock Grid.Row="0" Grid.Column="2" FontSize="16" Text="第77任務部隊（フィリピン、プエルト・プリンセサ）"/>
        <TextBlock Grid.Row="1" Grid.Column="0" FontSize="16" Text="宛"/>
        <TextBlock Grid.Row="1" Grid.Column="2" FontSize="16" Text="太平洋艦隊総司令官（ハワイ州パールハーバー）"/>
        <TextBlock Grid.Row="2" Grid.Column="0" FontSize="16" Text="報"/>
        <TextBlock Grid.Row="2" Grid.Column="2" FontSize="16">
          第17海兵両用部隊指揮官（陸上展開中）<LineBreak/>
          在フィリピン米軍司令官（マニラ、フィリピン）<LineBreak/>
          統合参謀本部（ワシントンDC）
        </TextBlock>
        <TextBlock Grid.Row="3" Grid.Column="0" FontSize="16" Text="件名"/>
        <TextBlock Grid.Row="3" Grid.Column="2" FontSize="16" Text="戦闘被害評価（BDA）報告――プエルト・プリンセサ／パラワン島続行作戦"/>
      </Grid>

      <TextBlock TextWrapping="Wrap" FontSize="16" Margin="0,24,0,0">
        極秘
        <LineBreak/>
        BT
        <LineBreak/><LineBreak/>
        参照：
        <LineBreak/><LineBreak/>
        A. 第77任務部隊（TF77）搭乗員デブリーフィングおよび空襲後写真解析。
        <LineBreak/>
        B. 第17海兵両用部隊（17MAU）状況報告 85年10月1日1030Z。
        <LineBreak/>
        C. フィリピン軍パラワン地上部隊報告 85年10月1日1045Z。
        <LineBreak/><LineBreak/>
        1. (S) 要約：チャレンジャー作戦により、17MAUおよびフィリピン軍部隊がプエルト・プリンセサに上陸した。着上陸海岸の安全は確保されている。友軍は市街の一部を掌握し、内陸への進路を確保中である。本報告は参照AからCに基づく初期情報である。
        <LineBreak/><LineBreak/>
        2. (S) 被害評価――プエルト・プリンセサ：アントニオ・バウティスタ飛行場の滑走路は爆破され、クレーターが形成されている。燃料および貯蔵区域が損傷。接近経路周辺の既知のレーダー、高射砲（AAA）、沿岸ミサイル陣地は破壊、損傷、または陣地転換を余儀なくされた。港湾施設は損傷しているが、工兵および潜水隊による啓開作業の後は限定的な兵站支援が可能とみられる。
        <LineBreak/><LineBreak/>
        3. (S) 続行作戦：17MAUは橋頭堡を拡大し、市郊外の敵残存拠点を掃討中である。機雷・地雷、ブービートラップ、および残留したミサイル班の存在が警戒される。滑走路および燃料システムの修復が完了するまでは、パラワン島からの同盟軍固定翼機の運用は不可能である。
        <LineBreak/><LineBreak/>
        4. (S) ケソン／西パラワン：パラワン島西岸のケソン付近では敵部隊が依然として活動中である。同拠点はチャレンジャー作戦による制圧を受けていない。現在の分析では、指揮および補給の結節点であり、増援部隊や物資を受け入れる能力を保持している可能性が高い。
        <LineBreak/><LineBreak/>
        5. (S) 評価：プエルト・プリンセサは占領したものの、パラワン島全域の安全は確保されていない。ケソンが開放されたままであれば、敵指揮官は依然として海上から増援を送り込むことが可能である。TF77は限定的な再補給を伴う続行掃討作戦を計画し、西パラワンへ向かういかなる船団も緊急の脅威として扱うべきである。
        <LineBreak/><LineBreak/>
        署名：情報参謀
        <LineBreak/>
        第77任務部隊情報参謀（CTF77 N2）
        <LineBreak/><LineBreak/>
        BT
        <LineBreak/>
        極秘 DECL OADR
      </TextBlock>
    </StackPanel>
  </Border>
</ScrollViewer>