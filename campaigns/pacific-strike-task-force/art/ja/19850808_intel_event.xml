<!-- Campaign event template for standard USN-style "daily intentions message" (DIM) - formatting taken from real world examples -->

<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">

    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16" Padding="45">
        <Border.Effect>
            <DropShadowEffect />
        </Border.Effect>
        <Border.Background>
            <ImageBrush ImageSource="{Binding Assets[bkg_paper]}" Stretch="UniformToFill"/>
        </Border.Background>
        
        <StackPanel Orientation="Vertical">

        <Grid
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Row="0" Grid.Column="0" Text="海軍電信" Margin="0" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Left"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="*******極  秘*******" Margin="40,0,40,0" FontWeight="Bold" TextAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="海軍省" Margin="0" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Right"/>
            
        </Grid>
        
        <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,1"/>
        <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,10"/>

            <Grid
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
            <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" FontSize="16">
                    至急（IMMEDIATE）<LineBreak/>
                    O 082100Z AUG 85
                </TextBlock>
                
                <TextBlock Grid.Row="1" Grid.Column="3" FontSize="16" Text="ZYUW RUHGOAA0777 2202100"/>

                <TextBlock Grid.Row="3" Grid.Column="0" FontSize="16" Text="発"/>
                <TextBlock Grid.Row="3" Grid.Column="2" FontSize="16" Text="第77任務部隊指揮官（豪北部準州ダーウィン）"/>
                <TextBlock Grid.Row="4" Grid.Column="0" FontSize="16" Text="宛"/>
                <TextBlock Grid.Row="4" Grid.Column="2" FontSize="16">
                    <Run Text="第"/>
                    <Run Text="{Binding DataSource.PersistentData[PlayerTaskForceName], Converter={StaticResource UppercaseConverter}}"/>
                    <Run Text="任務部隊指揮官（豪北部準州ダーウィン）"/>
                </TextBlock>
                <TextBlock Grid.Row="11" Grid.Column="0" FontSize="16" Text="報"/>
                <TextBlock Grid.Row="11" Grid.Column="2" FontSize="16" Text="太平洋艦隊総司令官（ハワイ州パールハーバー）"/>
                <TextBlock Grid.Row="12" Grid.Column="2" FontSize="16" Text="オーストラリア艦隊司令官（豪首都特別地域キャンベラ）"/>
                <TextBlock Grid.Row="13" Grid.Column="2" FontSize="16" Text="オーストラリア王立空軍航空軍司令部（豪ニューサウスウェールズ州グレンブルック）"/>
                <TextBlock Grid.Row="14" Grid.Column="0" FontSize="16" Text="件名"/>
                <TextBlock Grid.Row="14" Grid.Column="2" FontSize="16" Text="情報要約 08/1200Z - 09/1200Z"/>

                <TextBlock Grid.Row="15" Grid.ColumnSpan="4" FontSize="16" TextWrapping="Wrap">
                    <LineBreak/>
                    極秘
                    <LineBreak/>
                    BT
                    <LineBreak/>
                    <LineBreak/>
                    1. (S) 要約：東南アジアの同盟軍は、主要な集結基地としてダーウィンまで後退した。敵軍はシンガポールを孤立させ、残された同盟軍の海上交通路（SLOC）を遮断するため、ジャワ海、南シナ海、およびインド洋東部への進入路となる各海峡の封鎖を企てている。
                    <LineBreak/>
                </TextBlock>
                <TextBlock Grid.Row="16" Grid.ColumnSpan="4" FontSize="16" TextWrapping="Wrap">
                    2. (S) 敵情：
                    <LineBreak/>
                </TextBlock>
                <TextBlock Grid.Row="17" Grid.ColumnSpan="4" TextWrapping="Wrap" Margin="20,0,0,0">
                    - ソ連軍の特殊部隊がインドネシア軍の指揮混乱に乗じてバリ島に上陸し、デンパサール飛行場および周辺の支援施設を占領した。
                    <LineBreak/>
                    - 敵の水上・潜水艦・航空部隊は、スンダ、ロンボク、およびオンバイ／ウェタル海峡への接近経路における探査を継続している。
                    <LineBreak/>
                    - KIROV水上戦闘群が約2週間前にカムラン湾を出港した後、インド洋のいずれかの海域で断続的に探知されている。現在の針路および意図は不明。
                    <LineBreak/>
                </TextBlock>
                <TextBlock Grid.Row="19" Grid.ColumnSpan="4" TextWrapping="Wrap">
                    3. (S) 友軍状況：
                    <LineBreak/>
                </TextBlock>    
                <TextBlock Grid.Row="20" Grid.ColumnSpan="4" TextWrapping="Wrap" Margin="20,0,0,0"> 
                    - TF 77はシンガポール接近経路から撤退し、ダーウィンに集結した後も戦闘能力を維持している。
                    <LineBreak/>
                    - CVW-9の一部部隊は、CTF 77の調整の下、ダーウィンの陸上基地から運用されている。
                    <LineBreak/>
                    - シンガポールおよびマレーシアは激しい制圧攻撃を受け、その海空戦力の大半が壊滅した。
                    <LineBreak/>
                    - インドネシアは依然として大統領が行方不明であり、混乱が続いている。米国務省の分析では、ソ連が彼らに中立化の取引を持ちかけようとしている模様。
                    <LineBreak/>
                    - KITTY HAWKは横須賀での触雷による損傷のため引き続き作戦行動不可能。戦線復帰は遅くとも1月1日の見込み。
                    <LineBreak/>
                </TextBlock>
                <TextBlock Grid.Row="22" Grid.ColumnSpan="4" TextWrapping="Wrap">
                    4. (S) 評価：敵によるパラワン島、バリ島、およびインドネシア諸海峡の制圧により、ワルシャワ条約機構軍は南シナ海とインド洋を結ぶ主要な進入路を実質的に支配下に置いた。インドがソ連軍の基地利用および補給活動を容認し、東南アジア諸国の戦力が制圧され、インドネシアが政治的に麻痺している現状では、ソ連部隊はカムラン湾、インド洋の出撃拠点、およびオーストラリア周辺への接近経路の間を、ほとんど妨害を受けることなく移動可能である。
                    <LineBreak/>
                </TextBlock>
                <TextBlock Grid.Row="25" Grid.ColumnSpan="4" TextWrapping="Wrap">
                    署名：第77任務部隊情報参謀（CTF 77 N2）
                    <LineBreak/>
                    <LineBreak/>
                    BT
                    <LineBreak/>
                    極秘 DECL OADR
                    <LineBreak/>
                </TextBlock>
            </Grid>
        </StackPanel>
    </Border>
</ScrollViewer>