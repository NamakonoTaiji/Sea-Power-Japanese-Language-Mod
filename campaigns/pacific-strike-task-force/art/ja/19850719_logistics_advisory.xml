<!-- Pacific Strike classified logistics event: naval-message paper format. -->
<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16" Padding="45">
    <Border.Effect>
      <DropShadowEffect />
    </Border.Effect>
    <Border.Background>
      <ImageBrush ImageSource="{Binding Assets[bkg_paper]}" Stretch="UniformToFill"/>
    </Border.Background>

    <StackPanel Orientation="Vertical">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="3*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="海軍電信" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Left"/>
        <TextBlock Grid.Column="1" Text="*******極  秘*******" Margin="40,0,40,0" FontWeight="Bold" TextAlignment="Center"/>
        <TextBlock Grid.Column="2" Text="海軍省" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Right"/>
      </Grid>

      <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,1"/>
      <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,10"/>

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" HorizontalAlignment="Left" FontSize="16">
          普通<LineBreak/>
          R 192200Z JUL 85
        </TextBlock>

        <TextBlock Grid.Row="0" Grid.Column="3" FontSize="16" Text="ZYUW RAYOC0777 2002200"/>
      </Grid>

      <Grid Margin="0,18,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" FontSize="16" Text="発"/>
        <TextBlock Grid.Row="0" Grid.Column="2" FontSize="16" Text="太平洋艦隊兵站支援司令部 ダーウィン派遣隊（豪北部準州ダーウィン）"/>
        <TextBlock Grid.Row="1" Grid.Column="0" FontSize="16" Text="宛"/>
        <TextBlock Grid.Row="1" Grid.Column="2" FontSize="16" Text="太平洋艦隊総司令官（ハワイ州パールハーバー）"/>
        <TextBlock Grid.Row="2" Grid.Column="0" FontSize="16" Text="報"/>
        <TextBlock Grid.Row="2" Grid.Column="2" FontSize="16">
          第77任務部隊（豪北部準州ダーウィン）<LineBreak/>
          <Run Text="第"/>
          <Run Text="{Binding DataSource.PersistentData[PlayerTaskForceName], Converter={StaticResource UppercaseConverter}}"/>
          <Run Text="任務部隊指揮官（豪北部準州ダーウィン）"/><LineBreak/>
          オーストラリア艦隊司令官（豪首都特別地域キャンベラ）
        </TextBlock>
        <TextBlock Grid.Row="3" Grid.Column="0" FontSize="16" Text="件名"/>
        <TextBlock Grid.Row="3" Grid.Column="2" FontSize="16" Text="N4戦備勧告――ダーウィン集積弾薬"/>
      </Grid>

      <TextBlock TextWrapping="Wrap" FontSize="16" Margin="0,24,0,0">
        極秘
        <LineBreak/>
        BT
        <LineBreak/><LineBreak/>
        1. (S) 要約：フィリピンの備蓄から回航された重要弾薬輸送船団が、ロンボク海峡の南下航行に成功し、7月19日にダーウィンへ到着した。現在、太平洋艦隊兵站支援司令部（COMSERVPAC）の管理下で陸揚げ作業が進行中である。
        <LineBreak/><LineBreak/>
        2. (S) 物資状況：
      </TextBlock>

      <Border Padding="8" Margin="0,4,0,8">
        <Grid TextElement.FontSize="16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="品目 / 系列"/>
          <TextBlock Grid.Row="0" Grid.Column="1" Text="状況"/>

          <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,12,0" Text="RIM-66E / RIM-67B Standard"/>
          <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="ダーウィンにて、対応するMk13/Mk26ランチャー搭載艦向けの戦術弾薬を受領。"/>

          <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,12,0" Text="RGM-84C/D Harpoon"/>
          <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="キャニスター封入弾および単体弾を受領。対応艦艇で利用可能。"/>

          <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,12,0" Text="火砲用弾薬"/>
          <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="5インチ/54、5インチ/38、76mm、40mm、および20mm弾の備蓄を受領。"/>

          <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,12,0" Text="個別防御兵器"/>
          <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="20mm CIWS弾、チャフ、デコイ、およびノイズメーカー。"/>

          <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6,12,0" Text="対潜兵器資材"/>
          <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="Mk46艦載/航空魚雷、RUR-5 ASROC、ソノブイ、および爆雷。"/>
        </Grid>
      </Border>

      <TextBlock TextWrapping="Wrap" FontSize="16">
        3. (S) 計画：全面的な分配には、艦艇の優先度、弾薬庫の適合性、および予定される任務に基づく統制下での交付を要する。弾薬消費規制の一般的な緩和は承認されない。
        <LineBreak/><LineBreak/>
        4. (S) 当司令部は、ロンボク海峡の通航が、通報先任務部隊から派遣された1隻の米海軍艦艇によって可能となった点に留意する。敵の航空、水上、および潜水艦の脅威下で同艦が海峡を死守したことにより、ソ連の襲撃部隊による航路封鎖は阻止され、船団が南方へ脱出するために必要な時間が稼がれた。
        <LineBreak/><LineBreak/>
        5. (S) 所見：ロンボク海峡における作戦成功の直接的な成果として、ダーウィンにおける兵站状況が改善した旨を、太平洋艦隊総司令官（CINCPACFLT）から第77任務部隊（CTF 77）へ通知することを推奨する。
        <LineBreak/><LineBreak/>
        署名：R・M・ハルヴァーソン
        <LineBreak/>
        海軍補給大佐、米国海軍
        <LineBreak/>
        太平洋艦隊兵站支援司令部 ダーウィン派遣隊 / N4
        <LineBreak/><LineBreak/>
        BT
        <LineBreak/>
        極秘 DECL OADR
      </TextBlock>
    </StackPanel>
  </Border>
</ScrollViewer>