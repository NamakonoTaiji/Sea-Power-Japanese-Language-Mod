<Page
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
  Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=600}">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TabControl Grid.Row="0">
      <TabItem Header="概要">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="16,14,16,18">
            <TextBlock Text="パシフィック・ストライク '85 ―― タスクフォースモード" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,14"/>

            <TextBlock Text="指揮官、ようこそ！" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="欧州および太平洋で戦争が勃発した。貴官は同盟軍の第一防衛線として、敵対行動の開始と同時に日本に配備された。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14"/>

            <TextBlock Text="作戦目標" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Text="・キャンペーンポイントを消費して任務部隊（タスクフォース）を編成せよ。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="{Binding StartingPointsRuleText}" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・連動する一連の作戦で部隊を指揮せよ。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・兵装再補給：特定のミッション前に無料で利用可能。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・修理：特定のミッション前に利用可能。損害の修理にはポイントが必要。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・損害、喪失、修理、航空機、そしてアップグレードされた兵装（ロードアウト）は、展開していくキャンペーンの戦況に大きな影響を与える。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14"/>

            <TextBlock Text="開始前により詳細な情報を確認したい場合は、他のタブを参照せよ。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap"/>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="指揮官">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="16,14,16,18">
            <TextBlock Text="指揮官ルール" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,14"/>

            <TextBlock Text="連合司令部" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Text="敵対行動の開始時、米・日・豪の海軍部隊は太平洋での大規模な同盟軍演習に向けて準備を進めていた。危機が戦争へと発展した際、これらの部隊は統合司令部へと編入された。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14"/>
            <TextBlock Text="貴官はアメリカ、日本、またはオーストラリアの指揮官としてキャンペーンを率いることができる。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14"/>
            <TextBlock Text="指揮官の国籍によって、ミッションルール、艦艇や航空機の性能、または戦闘能力が変化することはない。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14"/>
            <Border Height="1" Background="{StaticResource Brush.Glyph.Normal}" Opacity="0.45" Margin="0,0,0,14"/>

            <TextBlock Text="自国ユニットの購入割引" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5">
              <Run Text="・指揮官は自国のユニットを購入する際、"/><Run Text="{Binding SameNationDiscountPercentText}"/><Run Text="％のポイント割引を受けられる。"/>
            </TextBlock>
            <TextBlock Text="・利用可能なユニットの大半はアメリカ製であるため、米軍の指揮官を選択すると最も柔軟な編成が可能となる。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・日本またはオーストラリアの指揮官を選択すると、ミッション自体の内容を変えることなく、より高い難易度に挑むことができる。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14"/>
            <Border Height="1" Background="{StaticResource Brush.Glyph.Normal}" Opacity="0.45" Margin="0,0,0,14"/>

            <TextBlock Text="勲章と昇進" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Text="・指揮官のキャンペーンにおける進捗は「従軍経歴（Service Record）」に記録される。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・従軍経歴には、昇進、勲章、総撃破数、損失数、救助した生存者数、およびスコアが含まれる。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・勲章や略綬（リボン）を選択すると、その詳細な授与理由（サイテーション）を読むことができる。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap"/>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="ユニットカタログ">
        <Grid Margin="16,14,16,18">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Text="ユニット価格" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
          <TextBlock Grid.Row="2" Text="利用可能なユニットのクラスとポイントコストを確認せよ。クラス名を選択するとユニットリファレンスが開く。タスクフォースビルダーを使用して、ユニットを貴官の任務部隊に追加せよ。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap"/>

          <Grid Grid.Row="4" Margin="0,0,16,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="210"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="150"/>
              <ColumnDefinition Width="220"/>
              <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>
            <Button Content="国籍" Command="{Binding SortRosterPriceRowsCommand}" CommandParameter="Nation" Height="28" Padding="8,0" HorizontalContentAlignment="Left"/>
            <Button Grid.Column="1" Content="クラス名" Command="{Binding SortRosterPriceRowsCommand}" CommandParameter="ClassName" Height="28" Padding="8,0" HorizontalContentAlignment="Left"/>
            <Button Grid.Column="2" Content="カテゴリー" Command="{Binding SortRosterPriceRowsCommand}" CommandParameter="Category" Height="28" Padding="8,0" HorizontalContentAlignment="Left"/>
            <Button Grid.Column="3" Content="種別" Command="{Binding SortRosterPriceRowsCommand}" CommandParameter="Type" Height="28" Padding="8,0" HorizontalContentAlignment="Left"/>
            <Button Grid.Column="4" Content="価格" Command="{Binding SortRosterPriceRowsCommand}" CommandParameter="Price" Height="28" Padding="8,0" HorizontalContentAlignment="Right"/>
          </Grid>

          <Border Grid.Row="5" Height="1" Background="#59606B" Margin="0,0,16,0"/>

          <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding RosterPriceRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="#253140" BorderThickness="0,0,0,1" Margin="0,0,16,0">
                  <Grid MinHeight="34" Margin="0,2,0,2">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="210"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="150"/>
                      <ColumnDefinition Width="220"/>
                      <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                      <Image Source="{Binding NationFlag}" Width="30" Height="20" Stretch="Uniform" Margin="0,0,8,0"/>
                      <TextBlock Text="{Binding NationName}" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{Binding OpenReferenceCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8,0"
                            HorizontalContentAlignment="Left">
                      <TextBlock Text="{Binding ClassName}" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap"/>
                    </Button>
                    <TextBlock Grid.Column="2" Text="{Binding CategoryName}" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding TypeName}" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock Grid.Column="4" Text="{Binding PriceText}" FontSize="15" Foreground="#D8DDE8" TextAlignment="Right" TextWrapping="Wrap" VerticalAlignment="Center" Margin="8,0"/>
                  </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </TabItem>

      <TabItem Header="キャンペーンルール">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="16,14,16,18">
            <TextBlock Text="キャンペーンルール" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,14"/>

            <TextBlock Text="データの永続性" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Text="・損害、弾薬の使用状況、および損失は、次のミッションへと引き継がれる。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・艦艇はミッション間に損害を僅かに自己修理できるが、完全な修理にはキャンペーンポイントを消費する。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・損害を受けた艦艇は、修理が利用可能なタイミングで修理できるが、それにはキャンペーンポイントが必要となる。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・大破（深刻な損害）した艦艇は修理できず、退役（除籍）させることしかできない。小破または中破の艦艇はポイントを消費して修理可能。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・兵装の再補給は特定のミッション間でのみ利用可能。ミッション前に艦艇の補給が完了している場合、タスクフォースマネージャーに緑色の「補給済（Rearmed）」アイコンが表示される。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14"/>
            <Border Height="1" Background="{StaticResource Brush.Glyph.Normal}" Opacity="0.45" Margin="0,0,0,14"/>
            <TextBlock Text="任務部隊の編成と管理" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Text="・キャンペーンマップ上部のタスクフォースバーから部隊を管理せよ。ここには現在のポイント、部隊のステータス、およびミッション間に利用可能なアクションが表示される。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5">
              <Run Text="・タスクフォースバーから "/><Hyperlink Command="{Binding OpenTaskForceBuilderCommand}">タスクフォースビルダー</Hyperlink><Run Text=" を開き、艦艇、潜水艦、ヘリコプター、航空機を貴官の任務部隊に追加せよ。"/>
            </TextBlock>
            <TextBlock Text="・選択したユニットは、任務部隊の編成を確定するまで購入されない。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・ユニットの利用可能性はミッション間で変化する場合がある。例えば、日本近海を離れた後は、日本のユニットが利用できなくなる可能性がある。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5">
              <Run Text="・タスクフォースバーを使用して、損害の修理、兵器の確認、兵装の変更、熟練度の表示、および航空機の割り当て管理を行え。"/>
            </TextBlock>
            <TextBlock Text="・「ユニットカタログ」タブには、利用可能なユニットのクラスとポイントコストがリストされている。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14"/>
            <Border Height="1" Background="{StaticResource Brush.Glyph.Normal}" Opacity="0.45" Margin="0,0,0,14"/>

            <TextBlock Text="タスクフォースビルダーの利用制限" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Text="・一部のミッションでは、任務部隊は味方基地から遠く離れた海域へと進出する。洋上で作戦行動中の場合、ミッション間に新たなユニットを追加できないことがある。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・新たなユニットの追加は、タスクフォースビルダーが利用可能な場合に限られる。部隊が味方基地に到達するまでキャンペーンを進めよ。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・再補給や増援に関する制限は、出撃前のミッション説明に明記される。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14"/>
            <Border Height="1" Background="{StaticResource Brush.Glyph.Normal}" Opacity="0.45" Margin="0,0,0,14"/>

            <TextBlock Text="キャンペーンポイント" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Text="・消費したポイントは確定となり、払い戻すことはできない。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="- 新たなユニットはタスクフォースビルダーが利用可能な時のみ追加できる。部隊が友軍基地に到達するまでキャンペーンを続行せよ。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="{Binding PurchaseLoadoutsRuleText}" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5">
              <Run Text="・タスクフォースマネージャーからユニットを解隊すると、そのポイント価値の "/><Run Text="{Binding DismissRefundPercentText}"/><Run Text="％が返還される。"/>
            </TextBlock>
            <TextBlock FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5">
              <Run Text="・修理不可能な大破ユニットを退役させると、そのポイント価値の "/><Run Text="{Binding DecommissionRefundPercentText}"/><Run Text="％が返還される。"/>
            </TextBlock>
            <TextBlock Text="・戦闘で艦艇を喪失した場合、ポイントは一切返還されない。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="・ポイントは、キャンペーンが進行し、ミッションをクリアするごとに追加で与えられる。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14"/>
            <Border Height="1" Background="{StaticResource Brush.Glyph.Normal}" Opacity="0.45" Margin="0,0,0,14"/>

            <TextBlock Text="乗組員の熟練度" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Text="ユニットはミッションを生き残ることで熟練度レベルが上昇する。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="熟練度が高くなると、戦闘効率、センサー処理速度、損害管制（ダメコン）能力が向上し、被弾時に致命傷（一撃死）となる確率が減少する。" FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <Border Width="1120" HorizontalAlignment="Center" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="1" Background="{StaticResource Brush.Window.Background}" Margin="0,0,0,14">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="126"/>
                  <ColumnDefinition Width="112"/>
                  <ColumnDefinition Width="150"/>
                  <ColumnDefinition Width="150"/>
                  <ColumnDefinition Width="132"/>
                  <ColumnDefinition Width="174"/>
                  <ColumnDefinition Width="144"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource Brush.Window.BackgroundDark}" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1">
                  <TextBlock Text="熟練度" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource Brush.Window.BackgroundDark}" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1">
                  <TextBlock Text="生存ミッション数" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center" TextWrapping="Wrap" ToolTip="この熟練度レベルに達するために、ユニットが生き残る必要のあるミッションの数。"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="2" Background="{StaticResource Brush.Window.BackgroundDark}" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1">
                  <TextBlock Text="接敵目標処理" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center" TextWrapping="Wrap" ToolTip="目標捕捉、ソナー目標運動解析（TMA）、ESM識別、および音響信頼度上昇に対する倍率。"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="3" Background="{StaticResource Brush.Window.BackgroundDark}" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1">
                  <TextBlock Text="船体・浸水・火災修理" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center" TextWrapping="Wrap" ToolTip="浸水率低下、浸水修理、構造修理、および火災深刻度修理に対する倍率。"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="4" Background="{StaticResource Brush.Window.BackgroundDark}" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1">
                  <TextBlock Text="システム修理" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center" TextWrapping="Wrap" ToolTip="損傷した艦船システムの修理に対する倍率。"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="5" Background="{StaticResource Brush.Window.BackgroundDark}" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1">
                  <TextBlock Text="航空機関砲迎撃" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center" TextWrapping="Wrap" ToolTip="航空機／ミサイルに対する、航空機関砲による迎撃ボーナス。"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="6" Background="{StaticResource Brush.Window.BackgroundDark}" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1">
                  <TextBlock Text="クリティカルボーナス" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center" TextWrapping="Wrap" ToolTip="攻撃成功時に、深刻な損害または即座に致命的な結果を引き起こす追加確率。"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="7" Background="{StaticResource Brush.Window.BackgroundDark}" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,0,1">
                  <TextBlock Text="致命傷リスク" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center" TextWrapping="Wrap" ToolTip="被弾時に、ユニットが即座に致命的な結果を被る確率。"/>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1">
                  <Border Width="84" Padding="4,2" Background="{StaticResource Brush.CrewSkill.Green}" HorizontalAlignment="Center">
                    <TextBlock Text="新兵" FontSize="13" Foreground="#18261B" TextAlignment="Center"/>
                  </Border>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1"><TextBlock Text="0" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
