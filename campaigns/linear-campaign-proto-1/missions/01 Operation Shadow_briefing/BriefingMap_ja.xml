<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas Width="1095" Height="662">
        <Image
            Source="{Binding Assets[Arctic_KirkenesNorth_Close]}" />
        <Border
            Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[EuropeNorthFar]}" Width="250" />
                <Border BorderThickness="2" HorizontalAlignment="Left"
                    VerticalAlignment="Bottom" Width="30" Height="20" Margin="145,0,0,150"
                    BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>
        <Border Canvas.Left="10" Canvas.Top="10"
            BorderThickness="5" BorderBrush="White" Background="White">
            <Border.Effect>
                <DropShadowEffect Opacity="0.25" />
            </Border.Effect>
            <Border.RenderTransform>
                <TransformGroup>
                    <RotateTransform Angle="12" CenterY="200" />
                </TransformGroup>
            </Border.RenderTransform>
            <StackPanel
                Orientation="Vertical">
                <Image Stretch="Uniform"
                    Source="{Binding Assets[screenshot_cape_girardeau]}" Width="250" />
                <TextBlock Foreground="Black" TextAlignment="Left" VerticalAlignment="Center"
                    Margin="5"
                    FontFamily="Courier New" FontWeight="Bold">
                    <Run
                        Text="USNS ケープ・ジラードー T-AK-2039" />
                    <LineBreak />
                    <Run
                        Text="19-LCM-978108 - 艦船局写真" />
                </TextBlock>
            </StackPanel>
        </Border>
        <TextBlock Foreground="SteelBlue" Text="バレンツ海"
            HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold"
            Canvas.Left="500" Canvas.Top="100" />
        <StackPanel
            Orientation="Vertical" HorizontalAlignment="Center" Canvas.Left="475" Canvas.Top="300">
            <Ellipse Width="150" Height="150" Opacity="0.25"
                Fill="{StaticResource NTDS.FriendColour}" />
            <TextBlock
                Foreground="{StaticResource NTDS.FriendColour}" Text="哨戒区域"
                HorizontalAlignment="Center" />
        </StackPanel>
        <StackPanel
            Orientation="Vertical" Canvas.Left="330" Canvas.Top="400">
            <TextBlock
                Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="ノルウェー海軍 コッベン級 x 2" />
            </TextBlock>
            <Canvas
                Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Submarine}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="500" Canvas.Top="250">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="USNS ケープ・ジラードー T-AK-2039" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="700" Canvas.Top="300">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="ソ連水上戦闘群" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5"
                HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
    </Canvas>
</Viewbox>