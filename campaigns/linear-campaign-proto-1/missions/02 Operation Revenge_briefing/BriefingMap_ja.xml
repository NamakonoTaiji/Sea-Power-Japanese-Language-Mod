<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas Width="1095" Height="662">
        <Image
            Source="{Binding Assets[Kuriles_NorthEastPacific_Close]}" />
        <Border
            Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[PacificFar]}" Width="250" />
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Width="30" Height="20" Margin="60,0,0,140"
                    BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>
        <Border Canvas.Left="10"
            Canvas.Bottom="10" BorderThickness="3" BorderBrush="{StaticResource NTDS.FriendColour}"
            Background="#90a3b6" Width="250">
            <TextBlock Foreground="Blue"
                TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run
                    Text="ヴォストーク機動部隊:" TextDecorations="Underline" />
                <LineBreak />
                <Run
                    Text="ストーイキー EM-679" />
                <LineBreak />
                <Run
                    Text="オズマトリテルヌイ EM-672" />
                <LineBreak />
                <Run Text="スラヴァ RKR-103" />
                <LineBreak />
                <Run Text="アドミラル・イサチェンコフ BPK-686" />
                <LineBreak />
                <LineBreak />
                <Run
                    Text="航空戦力:" />
                <LineBreak />
                <Run Text="Tu-95RT 第392独立長距離偵察航空連隊" />
                <LineBreak />
                <Run Text="Tu-22M2 第924親衛海軍ミサイル航空連隊 x 2" />
                <LineBreak />
                <LineBreak />
                <Run Text="第10潜水艦師団:" />
                <LineBreak />
                <Run Text="K-175 (675型)" />
            </TextBlock>
        </Border>
        <TextBlock Foreground="SteelBlue" Text="北太平洋"
            HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold"
            Canvas.Left="750" Canvas.Top="300" />
        <StackPanel
            Orientation="Vertical" HorizontalAlignment="Center" Canvas.Left="475" Canvas.Top="300">
            <Ellipse Width="200" Height="200" Opacity="0.25"
                Fill="{StaticResource NTDS.HostileColour}" />
            <TextBlock
                Foreground="{StaticResource NTDS.HostileColour}" Text="米機動部隊"
                HorizontalAlignment="Center" />
            <TextBlock
                Foreground="{StaticResource NTDS.HostileColour}" Text="推定位置"
                HorizontalAlignment="Center" />
        </StackPanel>
        <StackPanel
            Orientation="Vertical" Canvas.Left="400" Canvas.Top="200">
            <TextBlock
                Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="ヴォストーク機動部隊" />
            </TextBlock>
            <Canvas
                Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="450" Canvas.Top="150">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="Tu-95RT 第392独立長距離偵察航空連隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Air}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="450" Canvas.Top="50">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="Tu-22M2 第924親衛海軍ミサイル航空連隊 x 2" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Air}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="450" Canvas.Top="600">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="K-175" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Submarine}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="532" Canvas.Top="380">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="米機動部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5"
                HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
        <Path Canvas.Left="450" Canvas.Top="445"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.HostileColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="250" />
            </Path.RenderTransform>
        </Path>
    </Canvas>
</Viewbox>