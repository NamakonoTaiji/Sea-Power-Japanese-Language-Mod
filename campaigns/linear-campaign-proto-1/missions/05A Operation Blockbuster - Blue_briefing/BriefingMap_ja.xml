<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[NorwegianSeaSouth_Close]}" />
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[AtlanticFar]}" Width="250" />
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Width="30" Height="20" Margin="170,0,0,135"
                    BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>

        <TextBlock Foreground="SteelBlue" Text="ノルウェー海" HorizontalAlignment="Center"
            FontStyle="Italic" FontSize="16" FontWeight="Bold" Canvas.Left="350" Canvas.Top="100" />
        <TextBlock Foreground="Black" Text="アイスランド" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="25" Canvas.Top="350" />
        <TextBlock Foreground="Black" Text="フェロー諸島" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="450" Canvas.Top="575" />

        <Border Canvas.Left="10" Canvas.Bottom="10" BorderThickness="3"
            BorderBrush="{StaticResource NTDS.FriendColour}" Background="#90a3b6" Width="250">
            <TextBlock Foreground="Blue" TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run Text="第65.7任務部隊 (TF 65.7):" TextDecorations="Underline" />
                <LineBreak />
                <LineBreak />
                <Run Text="原子力空母アイゼンハワーCVN-69" />
                <LineBreak />
                <Run Text="戦艦ニュージャージーBB-62" />
                <LineBreak />
                <Run Text="ミサイル巡洋艦バレー・フォージCG-50" />
                <LineBreak />
                <Run Text="ミサイル巡洋艦デイルCG-19" />
                <LineBreak />
                <Run Text="駆逐艦メルダースD-186" />
                <LineBreak />
                <Run Text="ミサイルフリゲート・アンダーウッドFFG-36" />
                <LineBreak />
                <Run Text="フリゲート トーマス・C・ハートFF-1092" />
                <LineBreak />
                <Run Text="フリゲート・スタヴァンゲルF303" />
            </TextBlock>
        </Border>

        <StackPanel Orientation="Vertical" Canvas.Left="300" Canvas.Top="350">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="第65.7任務部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="690" Canvas.Top="45">
            <TextBlock Foreground="Red" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="キーロフ水上戦闘群" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <Path Canvas.Left="600" Canvas.Top="150"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.HostileColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="230" />
            </Path.RenderTransform>
        </Path>
    </Canvas>
</Viewbox>