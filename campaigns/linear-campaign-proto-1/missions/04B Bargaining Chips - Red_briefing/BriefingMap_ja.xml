<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas
        Width="1095" Height="662">
        <Image
            Source="{Binding Assets[BargainingChips_Attu_Close]}" />
        <Border
            Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[PacificFar]}" Width="250" />
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Width="30" Height="20" Margin="80,0,0,150"
                    BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>
        <Border Canvas.Left="10" Canvas.Bottom="140"
            BorderThickness="3" BorderBrush="{StaticResource NTDS.FriendColour}"
            Background="#90a3b6" Width="250">
            <TextBlock Foreground="Blue"
                TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run
                    Text="ヴォストーク機動部隊:" TextDecorations="Underline" />
                <LineBreak />
                <LineBreak />
                <Run Text="ストーイキー EM-679" />
                <LineBreak />
                <Run Text="スラヴァ RKR-103" />
                <LineBreak />
                <Run Text="ヴァシリー・チャパエフ BPK-511" />
            </TextBlock>
        </Border>
        <Border Canvas.Left="10" Canvas.Bottom="10" BorderThickness="3"
            BorderBrush="{StaticResource NTDS.FriendColour}" Background="#90a3b6" Width="250">
            <TextBlock Foreground="Blue" TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run Text="侵攻部隊:" TextDecorations="Underline" />
                <LineBreak />
                <LineBreak />
                <Run Text="ボエヴォイ EM-678" />
                <LineBreak />
                <Run Text="ペトロパブロフスク BPK-591" />
                <LineBreak />
                <Run Text="アドミラル・オクチャブリスキー BPK-573" />
                <LineBreak />
                <Run
                    Text="イワン・ロゴフ" />
                <LineBreak />
                <Run Text="ゲンリフ・ガサノフ" />
            </TextBlock>
        </Border>
        <TextBlock Foreground="SteelBlue" Text="ベーリング海"
            HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold"
            Canvas.Left="500" Canvas.Top="100" />
        <TextBlock Foreground="SteelBlue"
            Text="北太平洋" HorizontalAlignment="Center" FontStyle="Italic" FontSize="16"
            FontWeight="Bold" Canvas.Left="500" Canvas.Top="600" />
        <TextBlock
            Foreground="Black" Text="アッツ" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="775" Canvas.Top="290" />
        <StackPanel
            Orientation="Vertical" HorizontalAlignment="Center" Canvas.Left="575" Canvas.Top="325">
            <Ellipse Width="100" Height="100" Opacity="0.25"
                Fill="{StaticResource NTDS.FriendColour}" />
            <TextBlock
                Foreground="{StaticResource NTDS.FriendColour}" Text="侵攻部隊発進地点"
                HorizontalAlignment="Center" />
            <TextBlock
                Foreground="{StaticResource NTDS.FriendColour}" Text="" HorizontalAlignment="Center" />
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="800"
            Canvas.Top="600">
            <TextBlock Foreground="Red" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="第75.3機動部隊 (?)" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="600" Canvas.Top="200">
            <TextBlock Foreground="Red" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="アルファ水上戦闘群" />
            </TextBlock>
            <Canvas Width="22.5"
                Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="815" Canvas.Top="280">
            <TextBlock Foreground="Red" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="アッツ空軍基地" />
            </TextBlock>
            <Canvas Width="22.5"
                Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Airbase}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="750" Canvas.Top="350">
            <TextBlock Foreground="Red" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="P-3C" />
            </TextBlock>
            <Canvas Width="22.5"
                Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Air}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="400" Canvas.Top="450">
            <TextBlock Foreground="{StaticResource NTDS.FriendColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="ヴォストーク機動部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="350" Canvas.Top="400">
            <TextBlock Foreground="{StaticResource NTDS.FriendColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="侵攻部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="100" Canvas.Top="200">
            <TextBlock Foreground="{StaticResource NTDS.FriendColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run
                    Text="Tu-95RT 第392独立長距離偵察航空連隊" />
            </TextBlock>
            <Canvas
                Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Air}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="150" Canvas.Top="250">
            <TextBlock Foreground="{StaticResource NTDS.FriendColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run
                    Text="MiG-25PD 第786戦闘航空連隊" />
            </TextBlock>
            <Canvas
                Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Air}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <Path Canvas.Left="550" Canvas.Top="400"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="75" />
            </Path.RenderTransform>
        </Path>
        <Path
            Canvas.Left="750" Canvas.Top="525"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.HostileColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="320" />
            </Path.RenderTransform>
        </Path>
    </Canvas>
</Viewbox>