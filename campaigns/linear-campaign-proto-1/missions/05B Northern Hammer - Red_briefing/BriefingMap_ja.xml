<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas
        Width="1095" Height="662">
        <Image Source="{Binding Assets[NorwegianSeaSouth_Close]}" />
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[AtlanticFar]}"
                    Width="250" />
                <Border BorderThickness="2"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="30" Height="20"
                    Margin="170,0,0,135" BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>
        <TextBlock Foreground="SteelBlue" Text="ノルウェー海"
            HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold"
            Canvas.Left="350" Canvas.Top="100" />
        <TextBlock Foreground="Black" Text="アイスランド"
            HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="25"
            Canvas.Top="350" />
        <TextBlock Foreground="Black" Text="フェロー諸島"
            HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="450"
            Canvas.Top="575" />
        <Border Canvas.Left="10" Canvas.Bottom="10"
            BorderThickness="3" BorderBrush="{StaticResource NTDS.FriendColour}"
            Background="#90a3b6" Width="250">
            <TextBlock Foreground="Blue"
                TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run
                    Text="キーロフ打撃群:" TextDecorations="Underline" />
                <LineBreak />
                <LineBreak />
                <Run Text="キーロフ RKR-181" />
                <LineBreak />
                <Run Text="クロンシュタット BPK-662" />
                <LineBreak />
                <Run Text="ベズプレチヌイ EM-820" />
                <LineBreak />
                <Run
                    Text="ヴィツェ・アドミラル・クラコフ BPK-401" />
                <LineBreak />
                <Run
                    Text="キエフ TAVKR" />
            </TextBlock>
        </Border>
        <StackPanel
            Orientation="Vertical" Canvas.Left="300" Canvas.Top="350">
            <TextBlock
                Foreground="Red" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="米空母群" />
            </TextBlock>
            <Canvas Width="22.5"
                Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="690" Canvas.Top="45">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="キーロフ打撃群" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <Path Canvas.Left="625" Canvas.Top="150"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="230" />
            </Path.RenderTransform>
        </Path>
    </Canvas>
</Viewbox>