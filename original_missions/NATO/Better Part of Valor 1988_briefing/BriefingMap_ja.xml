<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas Width="1095" Height="662">
        <Image
            Source="{Binding Assets[YucatanStrait_Close]}" />                 <Border
            Canvas.Left="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[CaribbeanGulfOfMexicoFar]}"
                    Width="250" />
                <Border BorderThickness="2"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="30" Height="20"
                    Margin="120,0,0,70" BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>                 <TextBlock
            Foreground="Black" Text="キューバ"
            HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="925"
            Canvas.Top="150" />         <TextBlock Foreground="Black" Text="メキシコ"
            HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="100"
            Canvas.Top="475" />         <TextBlock Foreground="SteelBlue" Text="カリブ海"
            HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="800"
            Canvas.Top="500" /> 0 <TextBlock Foreground="SteelBlue" Text="メキシコ湾"
            HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="550"
            Canvas.Top="50" />         <TextBlock Foreground="SteelBlue" Text="ユカタン海峡"
            HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="375"
            Canvas.Top="350" />                         <StackPanel Orientation="Vertical"
            Canvas.Left="500" Canvas.Top="150">
            <TextBlock Foreground="Blue"
                TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run
                    Text="ミサイル哨戒艇ペガサス(PHM-1)" />
            </TextBlock>
            <Canvas
                Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
                            <StackPanel
            Orientation="Vertical" Canvas.Left="600" Canvas.Top="350">
            <TextBlock Foreground="Red" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="キューバ沿岸部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
                    <Path
            Canvas.Left="572" Canvas.Top="275"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="170" />
            </Path.RenderTransform>
        </Path>
    </Canvas>
</Viewbox>