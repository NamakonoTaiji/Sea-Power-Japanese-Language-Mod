<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[GIGapWest_Close]}" />
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5"
            BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform"
                    Source="{Binding Assets[AtlanticFar]}" Width="250" />
                <Border
                    BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Width="30" Height="20" Margin="140,0,0,130"
                    BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>
        <Border Canvas.Right="10" Canvas.Bottom="10"
            BorderThickness="3" BorderBrush="{StaticResource NTDS.FriendColour}"
            Background="#90a3b6" Width="250">
            <TextBlock Foreground="Blue"
                TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run
                    Text="ニュージャージー水上打撃群(SAG):" TextDecorations="Underline" />
                <LineBreak />
                <LineBreak />
                <Run Text="戦艦ニュージャージー (BB-62)" />
                <LineBreak />
                <Run
                    Text="ミサイル巡洋艦ヨークタウン (CG-48)" />
            </TextBlock>
        </Border>
        <TextBlock Foreground="Black" Text="アイスランド" HorizontalAlignment="Center"
            FontSize="16" FontWeight="Bold" Canvas.Left="875" Canvas.Top="375" />
        <TextBlock
            Foreground="Black" Text="グリーンランド" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="200" Canvas.Top="50" />
        <TextBlock
            Foreground="SteelBlue" Text="北大西洋" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="200" Canvas.Top="600" />
        <StackPanel
            Orientation="Vertical" Canvas.Left="250" Canvas.Top="500">
            <TextBlock
                Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="ニュージャージー水上打撃群" />
            </TextBlock>
            <Canvas
                Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="800" Canvas.Top="475">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="P-3C 第5哨戒飛行隊 'Mad Foxes'" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Air}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>
        <StackPanel Orientation="Vertical" Canvas.Left="650" Canvas.Top="150">
            <TextBlock Foreground="Red" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="キーロフ水上打撃群 (推定)" />
            </TextBlock>
            <Canvas
                Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path
                    StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse
                    Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325"
                    Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>
        <Path Canvas.Left="425" Canvas.Top="410"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="50" />
            </Path.RenderTransform>
        </Path>
        <Path Canvas.Left="725" Canvas.Top="420"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="300" />
            </Path.RenderTransform>
        </Path>
        <Path Canvas.Left="590" Canvas.Top="250"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.HostileColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="230" />
            </Path.RenderTransform>
        </Path>
    </Canvas>
</Viewbox>