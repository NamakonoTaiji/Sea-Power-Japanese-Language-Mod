<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[FaroeIslands_Close]}" />
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[AtlanticFar]}" Width="250" />
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Width="30" Height="20" Margin="165,0,0,125"
                    BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>
        <TextBlock Foreground="SteelBlue" Text="大西洋" HorizontalAlignment="Center" FontStyle="Italic"
            FontSize="16" FontWeight="Bold" Canvas.Left="350" Canvas.Top="100" />
        <TextBlock Foreground="Black" Text="フェロー諸島" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="700" Canvas.Top="175" />
        <TextBlock Foreground="Black" Text="アイスランド" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="15" Canvas.Top="15" />
        <TextBlock Foreground="Black" Text="スコットランド" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="900" Canvas.Top="600" />

        <Border Canvas.Left="10" Canvas.Bottom="95" BorderThickness="3"
            BorderBrush="{StaticResource NTDS.FriendColour}" Background="#90a3b6" Width="250">
            <TextBlock Foreground="Blue" TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run Text="TG Greyhound:" TextDecorations="Underline" />
                <LineBreak />
                <LineBreak />
                <Run Text="USSヴァリー・フォージ CG-50" />
                <LineBreak />
                <Run Text="USSトーマス・C・ハート FF-1092" />
                <LineBreak />
                <Run Text="USSジャック・ウィリアムズ FFG-24" />
            </TextBlock>
        </Border>

        <Border Canvas.Left="10" Canvas.Bottom="10" BorderThickness="3"
            BorderBrush="{StaticResource NTDS.FriendColour}" Background="#90a3b6" Width="250">
            <TextBlock Foreground="Blue" TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run Text="SAU Alpha:" TextDecorations="Underline" />
                <LineBreak />
                <LineBreak />
                <Run Text="USSジョン・ロジャース DD-983" />
                <LineBreak />
                <Run Text="USSアンダーウッド FFG-36" />
            </TextBlock>
        </Border>

        <StackPanel Orientation="Vertical" Canvas.Left="500" Canvas.Top="200">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="TG Greyhound" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="650" Canvas.Top="300">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="SAU Alpha" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="350" Canvas.Top="300">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="P-3C 第47哨戒飛行隊 'Golden Swordsmen'" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Air}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="850" Canvas.Top="335">
            <TextBlock Foreground="Red" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="?" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Submarine}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="690" Canvas.Top="45">
            <TextBlock Foreground="Red" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="?" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Submarine}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <Path Canvas.Left="750" Canvas.Top="400"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.HostileColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="250" />
            </Path.RenderTransform>
        </Path>
        <Path Canvas.Left="600" Canvas.Top="150"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.HostileColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="230" />
            </Path.RenderTransform>
        </Path>
    </Canvas>
</Viewbox>