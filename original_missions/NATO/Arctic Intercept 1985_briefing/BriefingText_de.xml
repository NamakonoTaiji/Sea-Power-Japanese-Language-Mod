<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
	<!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" Text="1985-8-18" FontSize="{StaticResource Font.Size.Header}"/-->
	<TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" FontSize="{StaticResource Font.Size.Header}">
		29JAN1985
	</TextBlock>
    <!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Right" Text="05:00Z (06:00L)" FontSize="{StaticResource Font.Size.Header}"/-->

    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="VON"/>
    <TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="COMLANTFLT"/>
    <TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="AN"/>
    <TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="KDT USS PARGO SSN-650"/>
    <TextBlock Grid.Row="7" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="BETR"/>
    <TextBlock Grid.Row="7" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="FRAGORD 01 - SOFORTIGE UMPLANUNG"/>
	    <!--
	<Image Grid.Row="1" Width="250" Grid.ColumnSpan="4" Grid.RowSpan="6" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{Binding Assets[ts_banner]}"/>
	-->
    <TextBlock Grid.Row="9" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap">
		BLITZ - STRENG GEHEIM
		<LineBreak/>
		<LineBreak/>
		1. (TS) DIE NATIONALE TECHNISCHE AUFKLÄRUNG WEIST AUF EINE SOWJETISCHE TRÄGERKAMPFGRUPPE MIT DEM TRÄGER KIEV ALS KERN HIN, DIE SÜDWESTWÄRTS IN RICHTUNG DÄNEMARKSTRASSE VERLEGT.
		<LineBreak/>
		<LineBreak/> 
		2. (TS) EIN LETZTER SATELLITENÜBERFLUG AM 28JAN ZEIGT DIE GRUPPE AUF KURS 230, FAHRT 20 KNOTEN, ETWA 150 SM NÖRDLICH VON JAN MAYEN. 
		<LineBreak/>
		<LineBreak/> 
		3. (S) VON IHREM ZUGEWIESENEN PATROUILLENSEKTOR AUS MIT HÖCHSTER FAHRT NORDWÄRTS VERLEGEN, ANSCHLIESSEND DIE KIEV-KAMPFGRUPPE ABFANGEN UND ZERSTÖREN. 
		<LineBreak/> 
		<LineBreak/> 
		4. (S) FEINDKRÄFTE BESTEHEN AUS: KIEV, 1 × KRESTA-KREUZER, 2 × KRIVAK-FREGATTEN, 1 × UDALOY-ZERSTÖRER. 
		<LineBreak/> 
		<LineBreak/> 
		5. (S) KIEV IST HAUPTZIEL. POSITION DER VERSENKUNG MELDEN, ANSCHLIESSEND WEITERE BEFEHLE ABWARTEN. VIEL GLÜCK UND WAIDMANNSHEIL. 
		<LineBreak/> 
		<LineBreak/> 
		GEHEIM 
		<LineBreak/> 
		NICHT FREIGEBEN OHNE GENEHMIGUNG DES EMPFÄNGERS
	  </TextBlock>
</Grid>