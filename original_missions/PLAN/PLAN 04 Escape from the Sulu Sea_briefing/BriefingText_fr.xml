<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
	<!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" Text="1985-8-18" FontSize="{StaticResource Font.Size.Header}"/-->
	<TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" FontSize="{StaticResource Font.Size.Header}">
		<Run Text="26 MARS 1988"/>
	</TextBlock>
    <!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Right" Text="05:00Z (06:00L)" FontSize="{StaticResource Font.Size.Header}"/-->
    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="DE"/>
    <TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="COMMANDANT FLOTTE MER DU SUD"/>
    <TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="A"/>
    <TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="COMMANDANT FORCE DE RECONNAISSANCE MER DE SULU"/>
    <TextBlock Grid.Row="7" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="SUJET"/>
    <TextBlock Grid.Row="7" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="MODIFICATION OPERATION MER DE SULU"/>
	    <!--
	<Image Grid.Row="1" Width="250" Grid.ColumnSpan="4" Grid.RowSpan="6" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{Binding Assets[ts_banner]}"/>
	-->
    <TextBlock Grid.Row="9" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap">
		SECRET
		<LineBreak/>
		<LineBreak/>
		1. AVEC EFFET IMMÉDIAT, INTERRUPTION DE L'EXERCICE DANS LA ZONE DE LA MER DE SULU.
		<LineBreak/>
		<LineBreak/>
		2. RETOUR AUX EAUX TERRITORIALES PAR LE DÉTROIT DE BALABAC À LA MEILLEURE VITESSE.
		<LineBreak/>
		<LineBreak/>
		3. NOTE : À L'HEURE ACTUELLE, UN ÉTAT DE GUERRE DE FAIT EXISTE AVEC LES FORCES PHILIPPINES. LE DERNIER SURVOL DE RECONNAISSANCE A MONTRÉ QUE LES FORCES PHILIPPINES DE SURFACE TENTENT DE FERMER LE DÉTROIT.
		<LineBreak/>
		<LineBreak/>
		4. LE RENSEIGNEMENT PENSE QUE DES FRAPPES AÉRIENNES CONDUITES PAR LES FORCES PHILIPPINES SONT ÉGALEMENT PROBABLES QUAND VOUS ATTEINDREZ LE DÉTROIT.
		<LineBreak/>
		<LineBreak/>
		5. AVERTISSEMENT : UN GROUPE DE SURFACE AMÉRICAIN A ÉTÉ APERÇU POUR LA DERNIÈRE FOIS PRÈS DU PASSAGE DE PALAWAN. LES AMÉRICAINS NE SOUTIENNENT PAS ENCORE LEURS ALLIÉS PHILIPPINS, MAIS IL EST IMPÉRATIF QU'ILS NE S'ENGAGENT PAS. TOUS LES CONTACTS DOIVENT ÊTRE IDENTIFIÉS AVEC PRÉCISION AVANT D'ATTAQUER. BONNE CHANCE.
		<LineBreak/>
		<LineBreak/>
		SECRET
	</TextBlock>
</Grid>