<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[ParacelsCrescentGroup_Close]}" />
        <Border Canvas.Left="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[WesternPacificFar]}" Width="250" />
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Width="30" Height="20" Margin="70,0,0,100"
                    BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>
        <TextBlock Foreground="SteelBlue" Text="南シナ海" HorizontalAlignment="Center"
            FontStyle="Italic" FontSize="16" FontWeight="Bold" Canvas.Left="400" Canvas.Top="100" />
        <TextBlock Foreground="Black" Text="クレセント群島" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="500" Canvas.Top="350" />

        <StackPanel Orientation="Vertical" Canvas.Left="850" Canvas.Top="350">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="第1水上部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="950" Canvas.Top="375">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="第2水上部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="300" Canvas.Top="250">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="RVNN攻撃部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="600" Canvas.Top="275">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="RVNN占領部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

    </Canvas>
</Viewbox>