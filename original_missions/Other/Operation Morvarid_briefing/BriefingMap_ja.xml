<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[NorthPersianGulf_Close]}" />
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[PersianGulf_Far]}" Width="250" />
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Width="30" Height="20" Margin="40,0,0,140"
                    BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>

        <Border Canvas.Left="10" Canvas.Bottom="10" BorderThickness="3"
            BorderBrush="{StaticResource NTDS.FriendColour}" Background="#90a3b6" Width="250">
            <TextBlock Foreground="Blue" TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run Text="第421任務部隊:" TextDecorations="Underline" />
                <LineBreak />
                <LineBreak />
                <Run Text="P225ジョシャン" />
                <LineBreak />
                <Run Text="P224パイカン" />
            </TextBlock>
        </Border>

        <TextBlock Foreground="SteelBlue" Text="ペルシャ湾" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="800" Canvas.Top="350" />
        <TextBlock Foreground="Black" Text="イラク" HorizontalAlignment="Center" FontSize="18"
            FontWeight="Bold" Canvas.Left="100" Canvas.Top="100" />
        <TextBlock Foreground="Black" Text="クウェート" HorizontalAlignment="Center" FontSize="18"
            FontWeight="Bold" Canvas.Left="100" Canvas.Top="350" />
        <TextBlock Foreground="Black" Text="ウム・カスル" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="275" Canvas.Top="150" />
        <TextBlock Foreground="Black" Text="アル・ファウ" HorizontalAlignment="Center" FontSize="16"
            FontWeight="Bold" Canvas.Left="550" Canvas.Top="100" />

        <StackPanel Orientation="Vertical" Canvas.Left="650" Canvas.Top="300">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="第421任務部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="850" Canvas.Top="450">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="F-14A第82戦術飛行隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Air}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="825" Canvas.Top="500">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="F-4E第91戦術飛行隊(2機)" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Air}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="475" Canvas.Top="200">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="イラク軍オーサ型艇部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="650" Canvas.Top="175">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="イラク軍魚雷艇部隊" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="400" Canvas.Top="120">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="イラク軍中型揚陸艦(LSM)" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="300" Canvas.Top="50">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="イラク航空戦力(?)" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Air}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="550" Canvas.Top="115">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Radar}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="525" Canvas.Top="100">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.AAA}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="575" Canvas.Top="115">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.AAA}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="600" Canvas.Top="250">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="ホール・アル・アマヤ石油ターミナル" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Installation}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="575" Canvas.Top="350">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="ミナ・アル・バクル石油ターミナル" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Installation}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <Path Canvas.Left="750" Canvas.Top="430"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="300" />
            </Path.RenderTransform>
        </Path>

    </Canvas>
</Viewbox>