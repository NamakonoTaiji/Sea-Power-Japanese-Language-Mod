<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
	<!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" Text="1985-8-18" FontSize="{StaticResource Font.Size.Header}"/-->
	<TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" FontSize="{StaticResource Font.Size.Header}">
		8 OKTOBER 1973
	</TextBlock>
    <!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Right" Text="05:00Z (06:00L)" FontSize="{StaticResource Font.Size.Header}"/-->

    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="VON:"/>
    <TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="KDT ISRAEL SEA CORPS"/>
    <TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="AN:"/>
    <TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="KDT SHAYETET 3"/>
    <TextBlock Grid.Row="7" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="BETR:"/>
    <TextBlock Grid.Row="7" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="NEUE BEFEHLE - OPERATION SINAI"/>
	    <!--
	<Image Grid.Row="1" Width="250" Grid.ColumnSpan="4" Grid.RowSpan="6" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{Binding Assets[ts_banner]}"/>
	-->
    <TextBlock Grid.Row="9" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap">
		GEHEIM
		<LineBreak/>
		<LineBreak/>
		1. Mit dem bevorstehenden Gegenangriff der IDF-Bodentruppen in den Sinai benötigt das Oberkommando die Unterstützung der 3. Flottille.
		<LineBreak/>
		<LineBreak/>
		2. Mit höchstmöglicher Geschwindigkeit westwärts verlegen und vor Port Said mit INS MIZNAK sowie Commander Barkai zusammentreffen.
		<LineBreak/>
		<LineBreak/>
		3. Nachrichtendienstliche Erkenntnisse gehen davon aus, dass sich bis zu 4 × Lenkwaffenschnellboote der OSA-Klasse mit STYX-Flugkörpern im Einsatzgebiet befinden.
		<LineBreak/>
		<LineBreak/>
		4. Sobald der Druck des Bodenangriffs ägyptische Seestreitkräfte zum Auslaufen aus ihren Häfen zwingt, sind diese aufzuklären und zu vernichten. Viel Glück.
		<LineBreak/>
		<LineBreak/>
		GEHEIM
	  </TextBlock>
</Grid>