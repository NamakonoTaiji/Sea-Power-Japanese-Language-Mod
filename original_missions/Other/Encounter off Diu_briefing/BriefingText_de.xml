<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
	<!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" Text="1985-8-18" FontSize="{StaticResource Font.Size.Header}"/-->
	<TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" FontSize="{StaticResource Font.Size.Header}">
		4. DEZEMBER 1971
	</TextBlock>
    <!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Right" Text="05:00Z (06:00L)" FontSize="{StaticResource Font.Size.Header}"/-->

    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="VON:"/>
    <TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="NAVY NHQ, KARACHI"/>
    <TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="AN:"/>
    <TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="KDT AHMAD TASNIM, PNS HANGOR (S131)"/>
    <TextBlock Grid.Row="7" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="BETR:"/>
    <TextBlock Grid.Row="7" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="NEUE BEFEHLE - OPERATION FALCON"/>
	    <!--
	<Image Grid.Row="1" Width="250" Grid.ColumnSpan="4" Grid.RowSpan="6" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{Binding Assets[ts_banner]}"/>
	-->
    <TextBlock Grid.Row="9" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap">
		GEHEIM
		<LineBreak/>
		<LineBreak/>
		1. Das Marinehauptquartier (NHQ) bestätigt den Eingang Ihrer Meldung vom 03DEZ über das Annähern einer indischen Kampfgruppe.
		<LineBreak/>
		<LineBreak/>
		2. Sie sind ermächtigt, sämtliche angetroffenen indischen Kriegsschiffe unter Feuer zu nehmen und zu zerstören.
		<LineBreak/>
		<LineBreak/>
		3. Hinweis: Die Stärke des indischen westlichen Flottenkommandos wird auf 4 × Korvetten der PETYA-III-Klasse sowie 2 × Fregatten der BLACKWOOD-Klasse geschätzt. Iljuschin-Seefernaufklärer können die Aufklärung unterstützen.
		<LineBreak/>
		<LineBreak/>
		4. Verbleiben Sie in Ihrem Patrouillengebiet. Bei Angriffen durch feindliche U-Jagd-Einheiten sind diese zu vernichten und anschließend westwärts auszuweichen. Viel Glück.
		<LineBreak/>
		<LineBreak/>
		GEHEIM
	  </TextBlock>
</Grid>