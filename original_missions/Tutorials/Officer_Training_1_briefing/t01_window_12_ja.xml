<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:SeapowerUI"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=400}"
    Padding="5,5,5,5">
    <ScrollViewer>
        <StackPanel Orientation="Vertical">
            <TextBlock
                TextWrapping="Wrap" Margin="15" FontFamily="Roboto">
                <TextBlock.Inlines>
                    <Run FontWeight="Bold" Text="艦船の操作 - レーダー探知" FontSize="16" />
                    <LineBreak />
                    <LineBreak />
                    <Run Text="センサーがオンラインになったことで、戦術ディスプレイに"
                        FontSize="12" />
                    <Run FontWeight="Bold" Text="黄色" FontSize="12"
                        Foreground="#D5A876" />
                    <Run
                        Text="の目標が追加されたことに気づくだろう。これは未識別のレーダー探知目標である。全ての未識別目標は黄色で表示され、ID番号が付与される。"
                        FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="レーダーが目標を探知している場合は(R)の記号でマークされる。目標のレーダー放射を探知している場合は(E)も表示され、目視で探知している場合は(V)が表示される。ソナー探知目標は(S)とマークされる。"
                        FontSize="12" />
                </TextBlock.Inlines>
            </TextBlock>
            <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                <Button
                    Width="100" Height="50" Margin="0,0,15,0" FontSize="16"
                    VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_11_ja.xml" />
                <Button Width="100" Height="50" Margin="0" FontSize="16" VerticalAlignment="Bottom"
                    Content="次へ" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_13_ja.xml" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>