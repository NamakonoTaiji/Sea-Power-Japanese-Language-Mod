<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=400}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical">
                <TextBlock TextWrapping="Wrap" Margin="15" FontFamily="Roboto">
                    <TextBlock.Inlines>
                        <Run FontWeight="Bold" Text="士官訓練 1 - 艦船の基本操作" FontSize="16" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="ようこそ、指揮官！このチュートリアルでは、艦船の基本操作、砲やミサイルによる目標への攻撃方法、そして水上艦からのヘリコプターの発着艦方法を学ぶ。貴官はオリバー・ハザード・ペリー級フリゲート「USS ギャラリー FFG-26」を指揮する。"
                            FontSize="12" />
                        <LineBreak />
                        <LineBreak />
                        <Run Text="このウィンドウの「戻る」「次へ」ボタンで、いつでもチュートリアルを進めることができる。" FontSize="12" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="このウィンドウは、右下のイベントログを開き、「フリーコンテンツウィンドウ」をクリックすることで、いつでも再度表示可能だ。"
                            FontSize="12" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0"
                    HorizontalAlignment="Center">
                    <Button Width="100" Height="50"
                        Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="次へ"
                        Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_2_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>