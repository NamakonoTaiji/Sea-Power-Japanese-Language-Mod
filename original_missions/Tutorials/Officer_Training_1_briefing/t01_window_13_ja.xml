<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:SeapowerUI"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=400}"
    Padding="5,5,5,5">
    <ScrollViewer>
        <StackPanel Orientation="Vertical">
            <TextBlock
                TextWrapping="Wrap" Margin="15" FontFamily="Roboto">
                <TextBlock.Inlines>
                    <Run FontWeight="Bold" Text="艦船の操作 - レーダー探知目標の識別" FontSize="16" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="レーダーエコーに基づいて目標を探知できたからといって、それが友軍、中立、あるいは敵であると確実に識別できるわけではない。目標を分類し、識別するためには、他の探知方法を使用しなければならない。"
                        FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="既知の敵レーダー波を放射しているレーダー探知目標は、レーダーエコーと放射波の組み合わせにより敵性（Hostile）と分類される。しかし、最も信頼性の高い識別方法は目視識別（VID）である。任意のユニットに未識別目標のVIDを命じると、そのユニットは目視可能な距離まで移動する。ただし、未識別目標が敵であった場合、これは危険を伴う可能性がある点に注意せよ！"
                        FontSize="12" />
                </TextBlock.Inlines>
            </TextBlock>
            <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                <Button
                    Width="100" Height="50" Margin="0,0,15,0" FontSize="16"
                    VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_12_ja.xml" />
                <Button Width="100" Height="50" Margin="0" FontSize="16" VerticalAlignment="Bottom"
                    Content="次へ">
                    <i:Interaction.Triggers>
                        <i:EventTrigger
                            EventName="Click">
                            <i:InvokeCommandAction
                                Command="{Binding ExecuteTriggerCommand}"
                                CommandParameter="QST Standard" />
                            <i:InvokeCommandAction
                                Command="{Binding OpenFileCommand}"
                                CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_14_ja.xml" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>