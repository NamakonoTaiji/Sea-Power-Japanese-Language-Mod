<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:SeapowerUI"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=400}"
    Padding="5,5,5,5">
    <ScrollViewer>
        <StackPanel Orientation="Vertical">
            <TextBlock
                TextWrapping="Wrap" Margin="15" FontFamily="Roboto">
                <TextBlock.Inlines>
                    <Run FontWeight="Bold" Text="マップ操作 - 戦術ディスプレイ" FontSize="16" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="次にマップ操作だが、非常に重要なツールが左下にある戦術ディスプレイだ。左マウスボタンをクリック＆ドラッグでマップを移動できる。スクロールホイールでズームイン・ズームアウトが可能。"
                        FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run Text="観測中のユニットにミニマップの中心を合わせるには、Cキーを押す。" FontSize="12" />
                    <LineBreak />
                    <LineBreak />
                    <Run
                        Text="戦術ディスプレイをゲームウィンドウ内で移動させたい場合は、タイトルバーをクリック＆ドラッグする。また、戦術ディスプレイウィンドウの境界をクリック＆ドラッグすることで、サイズを変更することもできる。"
                        FontSize="12" />
                </TextBlock.Inlines>
            </TextBlock>
            <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                <Button
                    Width="100" Height="50" Margin="0,0,15,0" FontSize="16"
                    VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_4_ja.xml" />
                <Button Width="100" Height="50" Margin="0" FontSize="16" VerticalAlignment="Bottom"
                    Content="次へ" Command="{Binding OpenFileCommand}"
                    CommandParameter="missions/Tutorials/Officer_Training_1_briefing/t01_window_6_ja.xml" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>