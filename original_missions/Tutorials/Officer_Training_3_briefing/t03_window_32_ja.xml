<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="データムの捜索とコンタクトの破壊" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto" FontSize="12">
                    <TextBlock.Inlines>
                        <Run
                            Text="データムA01は我々の水上任務群からかなり離れている点に注意。この場合、P-3Cとヘリコプターを使用してこのデータムを捜索するのが最も効率的である。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="両機に当該区域への移動を命じ、P-3Cでデータム円の周囲に「断続放射」に設定したソノブイのパターン敷設を開始せよ。敵潜水艦を発見できるか試し、発見した場合はこのチュートリアルで学んだスキルを駆使して追跡、破壊せよ。健闘を祈る！" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_3_briefing/t03_window_31_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_3_briefing/t03_window_33_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>