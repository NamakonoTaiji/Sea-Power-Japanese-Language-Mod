<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="士官訓練 3 - 対潜戦闘" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto" FontSize="12">
                    <TextBlock.Inlines>
                        <Run
                            Text="まず、艦船を基盤とした対潜戦術から始める。海上自衛隊の水上護衛艦は、高感度ソナーと対潜兵装に重点を置いているため、特に対潜戦闘に適している。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="水上護衛部隊の旗艦である護衛艦「ひえい」を選択すること。戦術ディスプレイまたは編隊マネージャーから艦船をクリックできる。注：2番艦の護衛艦「きくづき」をクリックした場合、マウスの中ボタン（MMB）をクリックすることで、編隊リーダーである「ひえい」に素早く戻ることができる。" />
                        <LineBreak />
                        <LineBreak />
                        <Run Text="このチュートリアルの間、特に指示がない限り、艦船は放射管制(EMCON)状態を維持し、すべてのセンサーを無効にしておくこと。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_3_briefing/t03_window_2_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_3_briefing/t03_window_4_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>