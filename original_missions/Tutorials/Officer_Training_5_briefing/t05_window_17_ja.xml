<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="スパイ・トローラーの配置" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto">
                    <TextBlock.Inlines>
                        <Run Text="司令部はこのトロール船を、アメリカ船団を発見するために、ハワイからアッツ島への主要な既知航路の一つに沿って配置した。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="注：トロール船は、日本の漁師が頻繁に利用する既知の漁場にも配置されている。これは、レーダー観測からトロール船や小型高速攻撃艇を隠す効果的な手法である！アメリカ軍は、発砲する前に、すべての船を目視で確認するために接近しなければならない。 " />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="「Sea Power」のオケアン級は、敵軍がVIDのために非常に近い距離まで接近するまで、中立のトロール船として未発見のままでいられる特別な属性を持っている。今のところ、トロール船を現在の場所に残し、敵軍を発見できるかどうか見てみよう。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_16_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_18_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>