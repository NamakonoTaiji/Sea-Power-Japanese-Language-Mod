<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="航跡情報パネル" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto">
                    <TextBlock.Inlines>
                        <Run Text="接触（レーダーエコー、ESM接触、音響接触など、あらゆる種類）を分析するために使用できるもう1つの機能は、「情報」パネルである。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="未識別の航跡を右クリックし、「情報」をクリックする。これにより、レーダーエコーのサイズ、推進機構/ブレード数（接触が音響の場合のみ表示）、レーダー放射など、航跡のすべての側面がリスト表示される。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="確実に収集された航跡の側面は緑色で表示される。この航跡の分類可能性は、分類の確率が高い順に左側にリストされていることに注意すること。この航跡を検出しているあなたのユニットも、接触時間（分/秒）とともに上部に表示される。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_14_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <i:InvokeCommandAction Command="{Binding ExecuteTriggerCommand}"
                                    CommandParameter="Sidechange AGI" />
                                <i:InvokeCommandAction Command="{Binding OpenFileCommand}"
                                    CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_16_ja.xml" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>