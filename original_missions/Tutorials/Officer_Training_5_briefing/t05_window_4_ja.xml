<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="任務背景" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto">
                    <TextBlock.Inlines>
                        <Run
                            Text="このシナリオでは、君の任務群はペトロパブロフスクを出港し、ハワイからアッツ島に向かう小規模なアメリカ船団を捜索・撃滅するよう命じられた。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="君はカムチャッカから発進したTu-95RT長距離偵察機によって支援されている。また、艦隊は米軍の動向を監視するため、北太平洋周辺にスパイ・トローラーを配置している。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="この海域は、中立国の商船が頻繁に航行する海上交通路である。我々の目標の一つは、不必要な民間人の犠牲を防ぐことであり、そのためには交戦前に米艦船を確実に識別する必要がある。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_3_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <i:InvokeCommandAction Command="{Binding ExecuteTriggerCommand}"
                                    CommandParameter="Search area marker" />
                                <i:InvokeCommandAction Command="{Binding OpenFileCommand}"
                                    CommandParameter="missions/Tutorials/Officer_Training_5_briefing/t05_window_5_ja.xml" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>