<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical"
                Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15"
                    FontFamily="Roboto" FontSize="16" FontWeight="Bold" Text="直接制御によるフォーメーション命令の上書き" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto" FontSize="12">
                    <TextBlock.Inlines>
                        <Run
                            Text="直接制御は、射界に制限のあるランチャーを素早く展開して飛来する敵ミサイルを迎撃したい場合や、艦が陸地に向かって航行するのを防ぎたい場合に役立つ。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="艦には衝突回避ルーチンが組み込まれており、通常は衝突を回避できるが、場合によっては自分で命令を下した方が手っ取り早いこともある。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel
                    Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button
                        Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom"
                        Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_2_briefing/t02_window_14_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom"
                        Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_2_briefing/t02_window_16_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>