<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical"
                Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15"
                    FontFamily="Roboto" FontSize="16" FontWeight="Bold" Text="編隊からの離脱" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto" FontSize="12">
                    <TextBlock.Inlines>
                        <Run
                            Text="ナルヴィクが遠方のピケット（哨戒）位置へ移動したところで、次は編隊から艦を離脱させたり、追加したりする方法を見ていこう。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="もし今、敵部隊が発見された場合、水上護衛艦を分離して高速で交戦に向かわせつつ、タンカーは反対方向へ退避を続けさせたい、と考えるかもしれない。これを実現する最善の方法は、タンカーを選択して編隊から離脱させることだ。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="これは、タンカーを右クリックし、『編隊（Formation）』、次に『編隊離脱（Leave Formation）』をクリックすることで実行できる。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel
                    Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button
                        Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom"
                        Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_2_briefing/t02_window_10_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom"
                        Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_2_briefing/t02_window_12_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>