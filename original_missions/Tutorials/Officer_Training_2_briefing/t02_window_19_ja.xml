<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical"
                Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15"
                    FontFamily="Roboto" FontSize="16" FontWeight="Bold" Text="士官訓練 2 - まとめ" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto" FontSize="12">
                    <TextBlock.Inlines>
                        <Run
                            Text="編隊内での艦隊行動、見事であった！ これで編隊内での艦船管理をマスターしたことになる。これは Sea Power における極めて重要なスキルであり、今後のチュートリアルでも役立つだろう。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="この時間を使って、自由に編隊管理の練習をするとよい。例えば、北西から敵の脅威が接近していると仮定し、タンカーを最大限防護できるような隊形に3隻を再配置してみたり、あるいはナルヴィクを東へ50海里離れたレーダーピケット（哨戒）地点に配置してみるのもいいだろう。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="これで第2回士官訓練は終了だ。ご苦労だった、司令官！" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0"
                    HorizontalAlignment="Center">
                    <Button Width="100" Height="50"
                        Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="戻る"
                        Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_2_briefing/t02_window_18_ja.xml" />
                    <Button Width="110" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom"
                        Content="ミッション終了" Command="{Binding ExecuteTriggerCommand}"
                        CommandParameter="Exit" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>