<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical"
                Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15"
                    FontFamily="Roboto" FontSize="16" FontWeight="Bold"
                    Text="編隊構成ユニットへのウェイポイント設定" />
                <TextBlock TextWrapping="Wrap"
                    Margin="0" FontFamily="Roboto" FontSize="12">
                    <TextBlock.Inlines>
                        <Run
                            Text="編隊内の艦の制御に関する最後の注意点として、編隊長に設定されたウェイポイントには編隊全体が追従するが、編隊内の他のユニットに与えられたウェイポイントは、そのユニットの編隊命令を上書きする。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="では、フリゲート『ナルヴィク』を選択し、リュッチェンスとは反対の東側のどこかにウェイポイントを与えて、これを試してみよう。早送りを使い、ナルヴィクが配置位置を離れて、新たに与えられたウェイポイントへ移動する様子を観察しよう。" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel
                    Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button
                        Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom"
                        Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_2_briefing/t02_window_16_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom"
                        Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_2_briefing/t02_window_18_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>