<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1920"
    d:DesignHeight="1080"
    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualWidth, FallbackValue=700}"
    Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentControl}}, Path=ActualHeight, FallbackValue=700}"
    Padding="5,5,5,5">
    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Margin="15">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontFamily="Roboto" FontSize="16"
                    FontWeight="Bold" Text="電子戦機" />
                <TextBlock TextWrapping="Wrap" Margin="0" FontFamily="Roboto" FontSize="12">
                    <TextBlock.Inlines>
                        <Run
                            Text="電子戦機は、マップ上に表示される紫色の円錐の内側にある敵の航跡を妨害するために、ある軸に沿って狙いを定めることができる強力な妨害装置を搭載している。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="航跡やエリアを妨害するには、EW機で利用可能な「攻撃的ECM」兵器を使用し、敵の航跡または戦術ディスプレイのエリアを右クリックして妨害する。妨害されたユニットは、航跡の横に小さな「太陽」アイコンが表示され、妨害されていることを示す。" />
                        <LineBreak />
                        <LineBreak />
                        <Run
                            Text="EW機は、敵のレーダーを標的にするために使用できる対レーダーミサイル（ARM）も搭載できる。敵のレーダーを対レーダーミサイルが捉えるためには、敵が積極的にレーダー放射をしている必要があることに注意せよ！" />
                    </TextBlock.Inlines>
                </TextBlock>
                <LineBreak />
                <StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="戻る" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_4_briefing/t04_window_14_ja.xml" />
                    <Button Width="100" Height="50" Margin="15" FontSize="16"
                        VerticalAlignment="Bottom" Content="次へ" Command="{Binding OpenFileCommand}"
                        CommandParameter="missions/Tutorials/Officer_Training_4_briefing/t04_window_16_ja.xml" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>