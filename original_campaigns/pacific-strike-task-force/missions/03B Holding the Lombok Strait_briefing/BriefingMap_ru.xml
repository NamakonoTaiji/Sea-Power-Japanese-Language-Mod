<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">
	<Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[Ship01_BaliLombokStrait_Close]}"/>
		<!-- Small Map -->
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[WesternPacificFar]}" Width="250"/>
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="15" Height="10" Margin="85,0,0,25" BorderBrush="{StaticResource Brush.Border.FocusAccent}"/>
            </Grid>
        </Border>

		<!-- Map Labels -->
		<TextBlock Foreground="SteelBlue" Text="Ломбокский пролив" HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold" Canvas.Left="515" Canvas.Top="425"/>
		<TextBlock Foreground="Black" Text="Бали" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="300" Canvas.Top="315"/>
		<TextBlock Foreground="Black" Text="Ломбок" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="800" Canvas.Top="425"/>
		
		<!-- {FlagshipName} -->
		<StackPanel Orientation="Vertical" Canvas.Left="400" Canvas.Top="400">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="{FlagshipName}"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>

		<!-- SH-2F HSL-35 'Magicians' -->
		<StackPanel Orientation="Vertical" Canvas.Left="300" Canvas.Top="425">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
				<Run Text="SH-2F «Сиспрайт»"/>
				<LineBreak/>
				<Run Text="HSL-35 'Magicians'"/>
			</TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Helicopter}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- P-3C 10 Sqdn RAAF -->
		<StackPanel Orientation="Vertical" Canvas.Left="900" Canvas.Top="600">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="P-3C «Орион» 10 Sqdn RAAF"/>
				<LineBreak/>
				<Run Text="(примерно через 45 минутt)"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Air}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- USSR Surface Raiding Force -->
		<StackPanel Orientation="Vertical" Canvas.Left="400" Canvas.Top="150">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="Советская КУГ"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- USSR sub -->
		<StackPanel Orientation="Vertical" Canvas.Left="600" Canvas.Top="200">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="?"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Submarine}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- USSR air -->
		<StackPanel Orientation="Vertical" Canvas.Left="750" Canvas.Top="150">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="?"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Air}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- USSR air -->
		<StackPanel Orientation="Vertical" Canvas.Left="500" Canvas.Top="100">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="?"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Air}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>

		<!-- Arrows -->
		<!-- Tool for making paths: https://yqnn.github.io/svg-path-editor/ -->
		
		<Path Canvas.Left="825" Canvas.Top="550" Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z" Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="300"/>
            </Path.RenderTransform>
        </Path>
		
		<Path Canvas.Left="590" Canvas.Top="350" Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z" Fill="{StaticResource NTDS.HostileColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="190"/>
            </Path.RenderTransform>
        </Path>
	</Canvas>
</Viewbox>