<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">
	<Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[03_PalawanPassage_Close]}"/>
		<!-- Small Map -->
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[WesternPacificFar]}" Width="250"/>
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="30" Height="20" Margin="90,0,0,70" BorderBrush="{StaticResource Brush.Border.FocusAccent}"/>
            </Grid>
        </Border>
		
		<!-- Mission Area Ellipse -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Canvas.Left="560" Canvas.Top="170" >
			<Ellipse Width="100" Height="100" Opacity="0.25" Fill="{StaticResource NTDS.HostileColour}"/>
			<!-- Mission Area Text -->
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" Text="Минное поле" HorizontalAlignment="Center"/>
		</StackPanel>
		
	    <!-- Map Labels -->
		<TextBlock Foreground="SteelBlue" HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold" Canvas.Left="70" Canvas.Top="90">
			<Run Text="   Опасная Зона"/>
			<LineBreak/>
			Южно-Китайского
			<LineBreak/>
			<Run Text="             моря"/>
		</TextBlock>
		<TextBlock Foreground="SteelBlue" Text="Палаванский пролив" HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold" Canvas.Left="330" Canvas.Top="200"/>
		<TextBlock Foreground="SteelBlue" Text="Море Сулу" HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold" Canvas.Left="850" Canvas.Top="250"/>
		<TextBlock Foreground="SteelBlue" Text="Пролив Балабак" HorizontalAlignment="Center" FontStyle="Italic" FontSize="14" FontWeight="Bold" Canvas.Left="525" Canvas.Top="375"/>
		<TextBlock Foreground="Black" Text="о. Баламбанган" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold" Canvas.Left="490" Canvas.Top="480"/>
		<TextBlock Foreground="Black" Text="о. Палаван" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Canvas.Left="660" Canvas.Top="50"/>
		<TextBlock Foreground="Black" Text="о. Борнео" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Canvas.Left="575" Canvas.Top="600"/>
		
		<!-- {TaskForceName} group icon and text -->
		<StackPanel Orientation="Vertical" Canvas.Left="525" Canvas.Top="115">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="{TaskForceName}"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
				
		<!-- USSR sub -->
		<StackPanel Orientation="Vertical" Canvas.Left="550" Canvas.Top="330">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="?"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Submarine}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- USSR sub -->
		<StackPanel Orientation="Vertical" Canvas.Left="750" Canvas.Top="450">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="?"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Submarine}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- USSR sub -->
		<StackPanel Orientation="Vertical" Canvas.Left="450" Canvas.Top="425">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="?"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Submarine}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- USSR sub -->
		<StackPanel Orientation="Vertical" Canvas.Left="450" Canvas.Top="225">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="?"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Submarine}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>

		<!-- Silkworm site -->
		<StackPanel Orientation="Vertical" Canvas.Left="530" Canvas.Top="420">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="ПУ ПКР"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Installation}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>

		<!-- Arrows -->
		<!-- Tool for making paths: https://yqnn.github.io/svg-path-editor/ -->
        <Path Canvas.Left="515" Canvas.Top="220" Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z" Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="200"/>
            </Path.RenderTransform>
        </Path>
		<Path Canvas.Left="665" Canvas.Top="400" Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z" Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="120"/>
            </Path.RenderTransform>
        </Path>
		<Path Canvas.Left="750" Canvas.Top="600" Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z" Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="160"/>
            </Path.RenderTransform>
        </Path>

	</Canvas>
</Viewbox>