<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">
	<Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[07_JavaSea_Close]}"/>
		<!-- Small Map -->
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[WesternPacificFar]}" Width="250"/>
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="15" Height="10" Margin="85,0,0,25" BorderBrush="{StaticResource Brush.Border.FocusAccent}"/>
            </Grid>
        </Border>
		
		<!-- Photo inset -->
        <Border Canvas.Left="30" Canvas.Bottom="15" BorderThickness="5" BorderBrush="White" Background="White">
			<Border.Effect>
				<DropShadowEffect Opacity="0.25"/>
			</Border.Effect>
			<Border.RenderTransform>
				<TransformGroup>
					<RotateTransform Angle="-5" CenterY="200"/>
				</TransformGroup>
			</Border.RenderTransform>
            <StackPanel Orientation="Vertical">
                <Image Stretch="Uniform" Source="{Binding Assets[07_senyavin]}" Width="250"/>
				<TextBlock Foreground="Black" TextAlignment="Left" VerticalAlignment="Center" Margin="5" FontFamily="Courier New" FontWeight="Bold">
					<Run Text="ENCL(2)5-445-607/ADMIRAL SENYAVIN"/><LineBreak/>
					<Run Text="02 FEB 72 - VP-40 PHOTO/SECRET"/>
				</TextBlock>
            </StackPanel>	
        </Border>
		
		<!-- Player unit summary -->
		<Border Canvas.Right="10" Canvas.Bottom="10" BorderThickness="3" BorderBrush="{StaticResource NTDS.FriendColour}" Background="#90a3b6" Width="250">
			<TextBlock Foreground="Blue" TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run Text="{TaskForceName}:" TextDecorations="Underline"/><LineBreak/><LineBreak/>
                {TaskForceVesselSummaryRuns}
           </TextBlock>
		</Border>

		<!-- Map Labels -->
		<TextBlock Foreground="SteelBlue" Text="Java Sea" HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold" Canvas.Left="550" Canvas.Top="150"/>
		<TextBlock Foreground="Black" Text="Java" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="550" Canvas.Top="450"/>
		<TextBlock Foreground="Black" Text="INDONESIA" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Canvas.Left="450" Canvas.Top="500"/>
		
		<!-- {TaskForceName} -->
		<StackPanel Orientation="Vertical" Canvas.Left="500" Canvas.Top="250">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="{TaskForceName}"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- Admiral Senyavin SAG -->
		<StackPanel Orientation="Vertical" Canvas.Left="200" Canvas.Top="200">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="Admiral Senyavin SAG"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- USSR sub -->
		<StackPanel Orientation="Vertical" Canvas.Left="390" Canvas.Top="175">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="Foxtrot-class SSK"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Submarine}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
				
		<!-- USSR air -->
		<StackPanel Orientation="Vertical" Canvas.Left="300" Canvas.Top="50">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="?"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Air}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- USSR air -->
		<StackPanel Orientation="Vertical" Canvas.Left="50" Canvas.Top="150">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="?"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Air}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>

		<!-- Juanda Intl (Surabaya) -->
		<StackPanel Orientation="Vertical" Canvas.Left="675" Canvas.Top="475">
			<TextBlock Foreground="{StaticResource NTDS.FriendColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="Juanda Intl (Surabaya)"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Enemy.Airbase}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>

		<!-- Arrows -->
		<!-- Tool for making paths: https://yqnn.github.io/svg-path-editor/ -->
		
		<Path Canvas.Left="400" Canvas.Top="250" Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z" Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="280"/>
            </Path.RenderTransform>
        </Path>
	</Canvas>
</Viewbox>