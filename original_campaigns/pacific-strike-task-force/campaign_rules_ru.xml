                  </Border>
                </Border>
                <Border Grid.Row="4" Grid.Column="1" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1"><TextBlock Text="4" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
                <Border Grid.Row="4" Grid.Column="2" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1"><TextBlock Text="2.5x" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
                <Border Grid.Row="4" Grid.Column="3" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1"><TextBlock Text="2.5x" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
                <Border Grid.Row="4" Grid.Column="4" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1"><TextBlock Text="1,75x" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
                <Border Grid.Row="4" Grid.Column="5" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1"><TextBlock Text="+15 / +4" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
                <Border Grid.Row="4" Grid.Column="6" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,1"><TextBlock Text="+4%" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
                <Border Grid.Row="4" Grid.Column="7" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,0,1"><TextBlock Text="6%" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>

                <Border Grid.Row="5" Grid.Column="0" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,0">
                  <Border Width="84" Padding="4,2" Background="{StaticResource Brush.CrewSkill.Ultra}" HorizontalAlignment="Center">
                    <TextBlock Text="Элита" FontSize="13" Foreground="#18261B" TextAlignment="Center"/>
                  </Border>
                </Border>
                <Border Grid.Row="5" Grid.Column="1" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,0"><TextBlock Text="7" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
                <Border Grid.Row="5" Grid.Column="2" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,0"><TextBlock Text="3x" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
                <Border Grid.Row="5" Grid.Column="3" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,0"><TextBlock Text="3x" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
                <Border Grid.Row="5" Grid.Column="4" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,0"><TextBlock Text="2x" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
                <Border Grid.Row="5" Grid.Column="5" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,0"><TextBlock Text="+20 / +5" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
                <Border Grid.Row="5" Grid.Column="6" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,1,0"><TextBlock Text="+6%" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
                <Border Grid.Row="5" Grid.Column="7" Padding="8,6" BorderBrush="{StaticResource Brush.Glyph.Normal}" BorderThickness="0,0,0,0"><TextBlock Text="5%" FontSize="14" Foreground="{StaticResource Brush.Foreground.Normal}" TextAlignment="Center"/></Border>
              </Grid>
            </Border>
            <Border Height="1" Background="{StaticResource Brush.Glyph.Normal}" Opacity="0.45" Margin="0,0,0,14"/>

            <TextBlock Text="Самолеты и подводные лодки" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Text="Корабли, приобретенные в Планировщике, включают в себя бесплатную авиагруппу (если позволяет выбранный режим сложности), и эти машины назначаются на судно автоматически. Самолеты и вертолёты должны быть приобретены отдельно, если они были потеряны." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="Вертолеты доступны сразу после начала кампании. Информация о поддерживаемых типах отображается в карточке корабля в Планировщике группы." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="Самолеты не доступны для покупки в начале кампании, но станут доступны позже." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="Приобретённые самолеты доступны в миссиях с авиабаз, которые их поддерживают. Если авиабаза отсутствует, самолеты не развертываются и находятся в резерве." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="Некоторые миссии включают в себя слоты для самолетов, которые могут начать миссию уже в воздухе. Подготовьте авиабазу к выбранной миссии и используйте вкладку 'Задачи авиагруппы', чтобы назначить подходящие неназначенные самолеты перед запуском." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="Каждая строка в 'Задачах авиагруппы' представляет собой одну формацию. Более крупные формации должны использовать тот же тип самолета, но могут быть частично заполнены, если доступно слишком мало самолетов." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="Подводные лодки действуют независимо от оперативной группы. Они появляются в отдельных (но связанных) дополнительных побочных миссиях, которые дают различные преимущества при выполнении, но не продвигают основную кампанию." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14"/>
            <Border Height="1" Background="{StaticResource Brush.Glyph.Normal}" Opacity="0.45" Margin="0,0,0,14"/>

            <TextBlock Text="Флагман" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Text="Для развертывания вашей оперативной группы требуется флагманский корабль." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="Первый корабль в вашей оперативной группе является флагманом по умолчанию. Вы можете назначить любой корабль флагманом в менеджере оперативной группы." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="Флагман должен выжить в каждой миссии. Другие подразделения в оперативной группе могут быть потеряны, но если флагман будет уничтожен, миссия будет провалена." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14"/>
            <Border Height="1" Background="{StaticResource Brush.Glyph.Normal}" Opacity="0.45" Margin="0,0,0,14"/>

            <TextBlock Text="Поиск и спасение" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Text="Спасательные плоты могут появиться, когда корабли потоплены или самолеты сбиты. Подведите к плотам вертолет или корабль, чтобы подобрать выживших. Скорость корабля при этом должна быть менее 10 узлов, а высота вертолёта должна быть минимальной." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="Вертолёты и корабли оснащены системой поиска которая показывает количество плотов и расстояние до ближайшего. Эта информация отображается в разделе 'Статус' на нижней панели юнита в миссии." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,14">
              <Run Text="- За каждые "/><Run Text="{Binding CSARPointModifierText}"/><Run Text=" выживших, спасенных в ходе миссии, вы получаете 1 очко кампаниии в конце миссии. На данный момент за меньшее число награды нет."/>
            </TextBlock>
            <Border Height="1" Background="{StaticResource Brush.Glyph.Normal}" Opacity="0.45" Margin="0,0,0,14"/>

            <TextBlock Text="Результаты миссии" FontSize="17" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Text="Провал миссии не повредит вашей группе и не приведет к дополнительным штрафам." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="Проваленная миссия должна быть переиграна и успешно завершена для продвижения вперед." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="Завершенные миссии могут быть переиграны с оригинальной группой, сформированной перед этой миссией." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="После завершения кампании все миссии разблокируются для переигрования с любой оперативной группой, который вы создадите." FontSize="15" Foreground="#D8DDE8" TextWrapping="Wrap"/>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <Button Grid.Row="2"
            HorizontalAlignment="Right"
            Width="110"
            Height="32"
            Content="{Binding Path=LanguageDictionary[genericskip], Source={StaticResource LanguageResourceInterface}, FallbackValue='Skip'}"
