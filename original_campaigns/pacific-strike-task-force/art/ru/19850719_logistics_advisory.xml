<!-- Pacific Strike classified logistics event: naval-message paper format. -->
<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16" Padding="45">
    <Border.Effect>
      <DropShadowEffect />
    </Border.Effect>
    <Border.Background>
      <ImageBrush ImageSource="{Binding Assets[bkg_paper]}" Stretch="UniformToFill"/>
    </Border.Background>

    <StackPanel Orientation="Vertical">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="3*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="ВОЕННО-МОРСКОЕ СООБЩЕНИЕ" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Left"/>
        <TextBlock Grid.Column="1" Text="******* E C R E T*******" Margin="40,0,40,0" FontWeight="Bold" TextAlignment="Center"/>
        <TextBlock Grid.Column="2" Text="МИНИСТЕРСТВО ВМС" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Right"/>
      </Grid>

      <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,1"/>
      <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,10"/>

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" HorizontalAlignment="Left" FontSize="16">
          ОБЫЧНОЕ<LineBreak/>
          R 192200Z JUL 85
        </TextBlock>

        <TextBlock Grid.Row="0" Grid.Column="3" FontSize="16" Text="ZYUW RAYOC0777 2002200"/>
      </Grid>

      <Grid Margin="0,18,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" FontSize="16" Text="От кого:"/>
        <TextBlock Grid.Row="0" Grid.Column="2" FontSize="16" Text="COMSERVPAC DET DARWIN NT AU"/>
        <TextBlock Grid.Row="1" Grid.Column="0" FontSize="16" Text="Кому:"/>
        <TextBlock Grid.Row="1" Grid.Column="2" FontSize="16" Text="CINCPACFLT PEARL HARBOR HI"/>
        <TextBlock Grid.Row="2" Grid.Column="0" FontSize="16" Text="Копия:"/>
        <TextBlock Grid.Row="2" Grid.Column="2" FontSize="16">
          CTF 77 DARWIN NT AU<LineBreak/>
          <Run Text="COMMANDER"/>
          <Run Text="{Binding DataSource.PersistentData[PlayerTaskForceName], Converter={StaticResource UppercaseConverter}}"/>
          <Run Text="DARWIN NT AU"/><LineBreak/>
          COMAUSFLT CANBERRA ACT AU
        </TextBlock>
        <TextBlock Grid.Row="3" Grid.Column="0" FontSize="16" Text="Тема:"/>
        <TextBlock Grid.Row="3" Grid.Column="2" FontSize="16" Text="N4 READINESS ADVISORY - DARWIN MUNITIONS"/>
      </Grid>

      <TextBlock TextWrapping="Wrap" FontSize="16" Margin="0,24,0,0">
        СЕКРЕТНО
        <LineBreak/>
        BT
        <LineBreak/><LineBreak/>
        1. (S) РЕЗЮМЕ: Конвой критических боеприпасов, отведенный от запасов Филиппины, прибыл на Дарвин 19JUL после успешного транзита на юг Ломбокский пролив. Загрузка осуществляется под контролем COMSERVPAC.
        <LineBreak/><LineBreak/>
        2. (S) МАТЕРИЙ СТАТУС:
      </TextBlock>

      <Border Padding="8" Margin="0,4,0,8">
        <Grid TextElement.FontSize="16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="ITEM / FAMILY"/>
          <TextBlock Grid.Row="0" Grid.Column="1" Text="STATUS"/>

          <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,12,0" Text="Стандарт RIM-66E/RIM-67B"/>
          <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="Боевые нагрузки, полученные для совместимых кораблей Mk 13/Mk 26 на Дарвин."/>

          <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,12,0" Text="RGM-84C/D Harpoon"/>
          <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="Канистеризованные и одиночные патроны, полученные и доступные для совместимых судов"/>

          <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,12,0" Text="Боеприпасы"/>
          <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="5-дюймовый/54, 5-дюймовый/38, 76 мм, 40 мм и 20 мм запасы получены"/>

          <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,12,0" Text="Точка защиты"/>
          <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="20 мм CIWS, мякоть, приманки и шумовщик"/>

          <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6,12,0" Text="магазины ASW"/>
          <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="Mk 46 корабельные/воздушные торпеды, RUR-5 ASROC, сонобуи и глубинные бомбы"/>
        </Grid>
      </Border>

      <TextBlock TextWrapping="Wrap" FontSize="16">
        3. (S) ШЕДУЛЬ: Полное распространение потребует контролируемой проблемы с приоритетом корпуса, совместимостью журнала и ожидаемой задачей. Релаксация общих расходов не разрешена.
        <LineBreak/><LineBreak/>
        4. (S) Эта команда отмечает, что транзит Ломбокский пролив стал возможным благодаря одному американскому военному кораблю, отделенному от адресованного оперативная группа. Удерживая пролив под вражеской воздушной, надводной и подводной угрозой, этот корабль не позволил советским рейдерам закрыть проход и купил конвой.
        <LineBreak/><LineBreak/>
        5. (S) Комментарий: Рекомендуем CINCPACFLT уведомить КГ 77 о том, что состояние логистики в Дарвин улучшилось в результате успешного действия Ломбокский пролив.
        <LineBreak/><LineBreak/>
        Подпись: Р. М. Халверсон
        <LineBreak/>
        CAPT, SC, USN
        <LineBreak/>
        COMSERVPAC DET DARWIN / N4
        <LineBreak/><LineBreak/>
        BT
        <LineBreak/>
        SECRET DECL OADR
      </TextBlock>
    </StackPanel>
  </Border>
</ScrollViewer>
