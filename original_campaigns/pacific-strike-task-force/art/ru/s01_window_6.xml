<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">

	<Border Background="#2b2d31" HorizontalAlignment="Center" VerticalAlignment="Center" Height="Auto" Width="900" TextElement.Foreground="#949aa1" TextElement.FontWeight="Bold" TextElement.FontSize="16" Padding="20">

        <StackPanel Orientation="Vertical">

			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100"/>
					<ColumnDefinition Width="3*"/>
					<ColumnDefinition Width="100"/>
				</Grid.ColumnDefinitions>
				
				<Button Grid.Row="0" Grid.Column="0" Width="100" Height="50" Margin="0,0,0,0" FontSize="16" VerticalAlignment="Center" Content="&lt;&lt;" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/ru/s01_window_5.xml"/>
							
				<TextBlock HorizontalAlignment="Center" FontSize="36" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
					ВСТУПЛЕНИЕ
				</TextBlock>
				
				<Button Grid.Row="0" Grid.Column="2" Width="100" Height="50" Margin="0,0,0,0" FontSize="16" VerticalAlignment="Center" Content="&gt;&gt;" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/ru/s01_window_7.xml"/>
			
			</Grid>

			<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="#949aa1" Margin="0,10,0,10"/>
			
			<Image Source="{Binding Assets[s01_kitty_hawk_drydock]}" Margin="0,0,0,0" Height="500"/>
			
			<TextBlock Text="USS Китти Хок в сухом доке после подрыва на мине близ Йокосуки." FontStyle="Italic" HorizontalAlignment="Center" FontFamily="Roboto" FontSize="12"/>

			<TextBlock> <LineBreak/> </TextBlock>
			<TextBlock Text="Неудачи в море" HorizontalAlignment="Center"  FontSize="24"/>
			
			<TextBlock TextWrapping="Wrap" Height="200">
				<LineBreak/>
				Американские военные силы были приведены в полную боевую готовность, когда президент Рейган начал операцию «Рефорджер» в Европе и приказал Тихоокеанскому флоту выйти в море. USS Энтерпрайз остался в Индийском океане, в то время как USS Констеллэйшн вышел из Перл-Харбора для участия в военных действиях в северной части Тихого океана.
				<LineBreak/>
				<LineBreak/>
				Однако проблемы начались незамедлительно: USS Китти Хок, при выходе из Йокосуки, подорвался на мине, поставленной подводной лодкой, а близ Сан-Диего, USS Карл Винсон получил серъёзные затопления в результате саботажа уплотнителей валолинии. Оба авианосца встали на длительный ремонт.
			</TextBlock>	
			
			<StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
				<Button Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="Назад" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/ru/s01_window_5.xml"/>
				<TextBlock VerticalAlignment="Center" FontSize="36" Text="                              "/>
				<Button Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="Дальше" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/ru/s01_window_7.xml"/>
		</StackPanel>
        </StackPanel>
    </Border>
</ScrollViewer>