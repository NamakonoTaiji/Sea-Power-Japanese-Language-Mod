<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">

	<Border Background="#2b2d31" HorizontalAlignment="Center" VerticalAlignment="Center" Height="Auto" Width="900" TextElement.Foreground="#949aa1" TextElement.FontWeight="Bold" TextElement.FontSize="16" Padding="20">

        <StackPanel Orientation="Vertical">

			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100"/>
					<ColumnDefinition Width="3*"/>
					<ColumnDefinition Width="100"/>
				</Grid.ColumnDefinitions>
				
				<Button Grid.Row="0" Grid.Column="0" Width="100" Height="50" Margin="0,0,0,0" FontSize="16" VerticalAlignment="Center" Content="&lt;&lt;" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/ru/s01_window_6.xml"/>
			
				<TextBlock HorizontalAlignment="Center" FontSize="36" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
					ВСТУПЛЕНИЕ
				</TextBlock>
				
				<Button Grid.Row="0" Grid.Column="2" Width="100" Height="50" Margin="0,0,0,0" FontSize="16" VerticalAlignment="Center" Content="&gt;&gt;" Command="{Binding NextCommand}"/>
			
			</Grid>

			<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="#949aa1" Margin="0,10,0,10"/>
			
			<Image Source="{Binding Assets[s01_pacific_strike]}" Margin="0,0,0,0" Height="500"/>
			
			<TextBlock Text="USS Скотт в бою. 26 Июня 1985, к западу от Окинавы." FontStyle="Italic" HorizontalAlignment="Center" FontFamily="Roboto" FontSize="12"/>
			
			<TextBlock> <LineBreak/> </TextBlock>
			<TextBlock Text="Держать оборону!" HorizontalAlignment="Center"  FontSize="24"/>
			
			<TextBlock TextWrapping="Wrap" Height="150">
				<LineBreak/>
				Поскольку три из четырех тихоокеанских авианосцев не доступны, оборона союзников будет обеспечиваться легкими силами: крейсерами, эсминцами, фрегатами, подводными лодками, их экипажами и командирами.
				<LineBreak/>
				<LineBreak/>
				Вы - один из таких командиров. Примите командование эсминцем USS Скотт (DDG-995) и оперативной группой 77.3 в самый разгар боевых действий. Это...
			</TextBlock>
			
			<TextBlock TextWrapping="Wrap" FontSize="60" Foreground="#fcbc23" FontStyle="Italic" FontFamily="Arial" HorizontalAlignment="Center">
				<TextBlock.Effect>
					<DropShadowEffect />
				</TextBlock.Effect>
				ТИХООКЕАНСКИЙ УДАР '85
			</TextBlock>
			
			<StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
				<Button Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="Назад" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/ru/s01_window_6.xml"/>
				<TextBlock VerticalAlignment="Center" FontSize="36" Text="                              "/>
				<Button Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="Дальше" Command="{Binding NextCommand}"/>
			</StackPanel>
        </StackPanel>
    </Border>
</ScrollViewer>