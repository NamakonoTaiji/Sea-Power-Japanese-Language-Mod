<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">

	<Border Background="#2b2d31" HorizontalAlignment="Center" VerticalAlignment="Center" Height="Auto" Width="900" TextElement.Foreground="#949aa1" TextElement.FontWeight="Bold" TextElement.FontSize="16" Padding="20">

        <StackPanel Orientation="Vertical">

			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100"/>
					<ColumnDefinition Width="3*"/>
					<ColumnDefinition Width="100"/>
				</Grid.ColumnDefinitions>
				
				<Button Grid.Row="0" Grid.Column="0" Width="100" Height="50" Margin="0,0,0,0" FontSize="16" VerticalAlignment="Center" Content="&lt;&lt;" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/ru/s01_window_2.xml"/>
							
				<TextBlock HorizontalAlignment="Center" FontSize="36" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
					ВСТУПЛЕНИЕ
				</TextBlock>
				
				<Button Grid.Row="0" Grid.Column="2" Width="100" Height="50" Margin="0,0,0,0" FontSize="16" VerticalAlignment="Center" Content="&gt;&gt;" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/ru/s01_window_4.xml"/>
			
			</Grid>

			<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="#949aa1" Margin="0,0,0,10"/>
			
			<Image Source="{Binding Assets[s01_ussr_pacific_fleet]}" Margin="0,0,0,0" Height="500"/>
			
			<TextBlock Text="Советские ракетные крейсера во Владивостоке." FontStyle="Italic" HorizontalAlignment="Center" FontFamily="Roboto" FontSize="12"/>

			<TextBlock> <LineBreak/> </TextBlock>
			<TextBlock Text="Наращивание сил" HorizontalAlignment="Center"  FontSize="24"/>
			
			<TextBlock TextWrapping="Wrap" Height="200">
				<LineBreak/>
				В течение последних нескольких лет Советский Союз незаметно перебрасывал корабли и авиацию на Дальний Восток. Эти силы теперь сосредоточены во Владивостоке и Петропавловске-Камчатском, а также на ВМБ Камрань во Вьетнаме.
				<LineBreak/>
				<LineBreak/>
				В Китае стратеги НОАК обратили свой взгляд на Тайвань. К лету 1985 года СССР и Китай были готовы оспорить контроль союзников над Индо-Тихоокеанским регионом.
			</TextBlock>	
			
			<StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
				<Button Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="Назад" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/ru/s01_window_2.xml"/>
				<TextBlock VerticalAlignment="Center" FontSize="36" Text="                              "/>
				<Button Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="Дальше" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/ru/s01_window_4.xml"/>
			</StackPanel>
        </StackPanel>
    </Border>
</ScrollViewer>