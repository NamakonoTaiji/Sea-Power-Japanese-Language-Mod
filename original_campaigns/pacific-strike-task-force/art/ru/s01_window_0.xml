<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">

	<Border Background="#2b2d31" HorizontalAlignment="Center" VerticalAlignment="Center" Height="Auto" Width="900" TextElement.Foreground="#949aa1" TextElement.FontWeight="Bold" TextElement.FontSize="16" Padding="20">

        <StackPanel Orientation="Vertical">
			<TextBlock HorizontalAlignment="Center" FontSize="36">
				INTRODUCTION
			</TextBlock>
			
			<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="#949aa1" Margin="0,0,0,10"/>
			
			<Image Source="{Binding Assets[s01_sunset]}" Margin="0,0,0,15"/>
			
			<TextBlock TextWrapping="Wrap">
				<Run Text="Приливы" FontWeight="Bold" FontFamily="Roboto"/>
				<LineBreak/>
				<LineBreak/>
				Тихий океан — театр, определяемый расстоянием. 
				<LineBreak/>
				<LineBreak/>
				Контроль здесь принадлежит стороне, которая может перемещать, снабжать и защищать свои силы на этом огромном пространстве. Для союзных государств Тихого океана это бремя ложится в первую очередь на Седьмой флот ВМС США.
			</TextBlock>	
			
			<StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
				<Button Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="Дальше" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/ru/s01_window_1.xml"/>
			</StackPanel>
        </StackPanel>
    </Border>
</ScrollViewer>
