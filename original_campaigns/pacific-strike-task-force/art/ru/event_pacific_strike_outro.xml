<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  TextElement.Foreground="#D8DCE0"
  TextElement.FontFamily="Roboto">
  <Grid.Resources>
    <Style x:Key="SlideArrowButton" TargetType="{x:Type Button}">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#8E969E"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontSize" Value="58"/>
      <Setter Property="FontWeight" Value="Light"/>
      <Setter Property="Opacity" Value="0.58"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#28383B3F"/>
                <Setter Property="Opacity" Value="0.82"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#40383B3F"/>
                <Setter Property="Opacity" Value="0.9"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Grid.Resources>

  <Grid.ColumnDefinitions>
    <ColumnDefinition Width="122"/>
    <ColumnDefinition Width="*"/>
    <ColumnDefinition Width="122"/>
  </Grid.ColumnDefinitions>

  <Button Grid.Column="0" Width="96" Height="190" Style="{StaticResource SlideArrowButton}" Content="&lt;" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/ru/event_task_force_77_combat_record.xml" VerticalAlignment="Center"/>
  <Button Grid.Column="2" Width="96" Height="190" Style="{StaticResource SlideArrowButton}" Content="&gt;" Command="{Binding NextCommand}" VerticalAlignment="Center"/>

  <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,18">
    <Border Background="White" HorizontalAlignment="Center" VerticalAlignment="Top" Width="900" Padding="45" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16">
      <Border.Effect>
        <DropShadowEffect />
      </Border.Effect>

      <StackPanel Orientation="Vertical">
        <Rectangle HorizontalAlignment="Stretch" Height="3" Fill="Black" Margin="15,22,15,0"/>

        <TextBlock Text="PACIFIC STRIKE CONTINUES" FontWeight="Bold" FontSize="34" TextWrapping="Wrap" TextAlignment="Center" Margin="0,20,0,0"/>
        <TextBlock Text="TASK GROUP 77.3 - ACTION IN THE WESTERN PACIFIC" FontWeight="Bold" FontSize="20" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>

        <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="15,18,15,0"/>

        <TextBlock Text="Поздравляю с завершением первых глав кампании «Пацифическая война 85»." FontWeight="Bold" FontSize="18" TextWrapping="Wrap" TextAlignment="Center" Margin="25,22,25,0"/>

        <TextBlock Text="Война в Тихом океане не закончилась. Силы противника были проверены в Юго-Восточной Азии, но активные бои продолжаются вокруг Япония, Кореи, Тайвань и Южно-Китайское море." FontSize="16" TextWrapping="Wrap" TextAlignment="Center" Margin="35,22,35,0"/>

        <TextBlock Text="Последующие операции будут продолжены в будущем обновлении." FontSize="16" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Margin="35,18,35,0"/>

        <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="15,24,15,0"/>

        <TextBlock Text="THANK YOU FOR PLAYING PACIFIC STRIKE '85." FontWeight="Bold" FontSize="28" TextWrapping="Wrap" TextAlignment="Center" Margin="15,22,15,0"/>
        <TextBlock Text="- THE TRIASSIC GAMES TEAM" FontWeight="Bold" FontSize="18" TextWrapping="Wrap" TextAlignment="Center" Margin="15,6,15,0"/>
      </StackPanel>
    </Border>
  </ScrollViewer>
</Grid>
