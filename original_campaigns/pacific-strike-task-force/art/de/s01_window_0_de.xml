<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">

	<Border Background="#2b2d31" HorizontalAlignment="Center" VerticalAlignment="Center" Height="Auto" Width="900" TextElement.Foreground="#949aa1" TextElement.FontWeight="Bold" TextElement.FontSize="16" Padding="20">

        <StackPanel Orientation="Vertical">
			<TextBlock HorizontalAlignment="Center" FontSize="36">
				EINFÜHRUNG
			</TextBlock>
			
			<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="#949aa1" Margin="0,0,0,10"/>
			
			<Image Source="{Binding Assets[s01_sunset]}" Margin="0,0,0,15"/>
			
			<TextBlock TextWrapping="Wrap">
				<Run Text="Die Gezeiten" FontWeight="Bold" FontFamily="Roboto"/>
				<LineBreak/>
				<LineBreak/>
				Der Pazifik ist ein Einsatzraum, der durch Entfernungen geprägt ist.
				<LineBreak/>
				<LineBreak/>
				Die Kontrolle gehört hier der Seite, die ihre Kräfte über dieses gewaltige Areal hinweg bewegen, versorgen und schützen kann. Für die alliierten Nationen des Pazifiks fällt diese Last vor allem der Seventh Fleet der United States Navy zu.
			</TextBlock>	
			
			<StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
				<Button Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="Next" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/de/s01_window_1_de.xml"/>
			</StackPanel>
        </StackPanel>
    </Border>
</ScrollViewer>
