<Viewbox xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Stretch="Uniform"
  StretchDirection="Both">
  <Grid Width="1560" Height="920" TextElement.Foreground="#D8DCE0" TextElement.FontFamily="Roboto">
    <Grid.Resources>
      <Style x:Key="SlideArrowButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#8E969E"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="58"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="Opacity" Value="0.58"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Background="{TemplateBinding Background}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#28383B3F"/>
                  <Setter Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter Property="Background" Value="#40383B3F"/>
                  <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </Grid.Resources>

    <Grid.RowDefinitions>
      <RowDefinition Height="76"/>
      <RowDefinition Height="1"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="64"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="EINFÜHRUNG" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    <Border Grid.Row="0" Width="76" Height="38" BorderBrush="#3E454B" BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0">
      <TextBlock Text="5 / 7" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
    <Rectangle Grid.Row="1" Fill="#3E454B" Margin="22,0"/>

    <Grid Grid.Row="2" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="122"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="122"/>
      </Grid.ColumnDefinitions>

      <Button Grid.Column="0" Width="96" Height="190" Style="{StaticResource SlideArrowButton}" Content="&lt;" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/de/s01_window_4_de.xml"/>
      <Button Grid.Column="2" Width="96" Height="190" Style="{StaticResource SlideArrowButton}" Content="&gt;" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/pacific-strike-task-force/art/de/s01_window_6_de.xml"/>

      <StackPanel Grid.Column="1" Orientation="Vertical">
        <Image Source="{Binding Assets[s01_map_pacific_offensive_de]}" Height="510" Stretch="Uniform" HorizontalAlignment="Center"/>
        <TextBlock Text="Bewegungen sowjetischer und chinesischer Seestreitkräfte zu Beginn der Kampfhandlungen am 25. Juni 1985." FontStyle="Italic" FontSize="11" Foreground="#99A1A8" HorizontalAlignment="Center" Margin="0,8,0,0"/>
        <TextBlock Text="Die Pazifikoffensive beginnt" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,22,0,14"/>
        <TextBlock TextWrapping="Wrap" FontSize="16" LineHeight="25" Foreground="#D0D4D8">
          Wochen vor Beginn der Kämpfe in Europa liefen sowjetische Seestreitkräfte im Pazifik zu groß angelegten Manövern im Japanischen Meer aus, während chinesische Kräfte parallel dazu Manöver im Südchinesischen Meer und im Ostchinesischen Meer durchführten.
          <LineBreak/><LineBreak/>
          Als die Streitkräfte des Warschauer Pakts Ende Juni in die Fulda-Lücke vorstießen, gaben beide Marinen den Vorwand friedenszeitlicher Manöver auf und griffen an. Sie schalteten alliierte Stellungen aus und führten Schläge gegen verwundbare Stützpunkte, Schifffahrt und Außenposten im gesamten westlichen Pazifik durch.
        </TextBlock>
      </StackPanel>
    </Grid>

  </Grid>
</Viewbox>
