<!-- Pacific Strike 17 MAU targeting intelligence event: naval-message paper format. -->
<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16" Padding="45">
    <Border.Effect>
      <DropShadowEffect />
    </Border.Effect>
    <Border.Background>
      <ImageBrush ImageSource="{Binding Assets[bkg_paper]}" Stretch="UniformToFill"/>
    </Border.Background>

    <StackPanel Orientation="Vertical">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="3*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="NAVAL MESSAGE" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Left"/>
        <TextBlock Grid.Column="1" Text="*******S E C R E T*******" Margin="40,0,40,0" FontWeight="Bold" TextAlignment="Center"/>
        <TextBlock Grid.Column="2" Text="NAVY DEPARTMENT" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Right"/>
      </Grid>

      <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,1"/>
      <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,10"/>

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" HorizontalAlignment="Left" FontSize="16">
          IMMEDIATE<LineBreak/>
          O 212300Z SEP 85
        </TextBlock>

        <TextBlock Grid.Row="0" Grid.Column="3" FontSize="16" Text="ZYUW RUHQHQA0777 2642300"/>
      </Grid>

      <Grid Margin="0,18,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" FontSize="16" Text="FM"/>
        <TextBlock Grid.Row="0" Grid.Column="2" FontSize="16" Text="CINCPAC HONOLULU HI"/>
        <TextBlock Grid.Row="1" Grid.Column="0" FontSize="16" Text="TO"/>
        <TextBlock Grid.Row="1" Grid.Column="2" FontSize="16" Text="COMMANDER 17 MAU AFLOAT"/>
        <TextBlock Grid.Row="2" Grid.Column="0" FontSize="16" Text="INFO"/>
        <TextBlock Grid.Row="2" Grid.Column="2" FontSize="16">
          CTF 77 SANDAKAN MY<LineBreak/>
          CINCPACFLT PEARL HARBOR HI<LineBreak/>
          COMSUBPAC PEARL HARBOR HI<LineBreak/>
          MARITIME HQ DARWIN NT AU
        </TextBlock>
        <TextBlock Grid.Row="3" Grid.Column="0" FontSize="16" Text="SUBJ"/>
        <TextBlock Grid.Row="3" Grid.Column="2" FontSize="16" Text="TARGET INTEL - PUERTO PRINCESA INSTALLATIONS"/>
      </Grid>

      <TextBlock TextWrapping="Wrap" FontSize="16" Margin="0,24,0,0">
        SECRET
        <LineBreak/>
        BT
        <LineBreak/><LineBreak/>
        REFS:
        <LineBreak/>
        A. ORION INTREP 20-85/PP, PERISCOPE PHOTO AND ES FIX.
        <LineBreak/>
        B. CINCPAC JIC TARGET FOLDER PP-CHALLENGER-17.
        <LineBreak/>
        C. TF 77 AIR/FIRE SUPPORT NOTE 21SEP85/CHALLENGER.
        <LineBreak/><LineBreak/>
        1. (S) SUMMARY: HMAS ORION reconnaissance has identified eleven enemy installations in the Puerto Princesa assault area. Data below is passed to 17 MAU staff for strike planning and beach approach risk reduction.
        <LineBreak/><LineBreak/>
        2. (S) TARGETING DATA:
      </TextBlock>

      <Border Padding="8" Margin="0,4,0,12">
        <Grid TextElement.FontSize="16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="235"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="REGION"/>
          <TextBlock Grid.Row="0" Grid.Column="1" Text="QTY"/>
          <TextBlock Grid.Row="0" Grid.Column="2" Text="INSTALLATION"/>
          <TextBlock Grid.Row="0" Grid.Column="3" Text="COORDINATES LAT/LONG"/>

          <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,12,0" Text="AIRBASE/RPVP"/>
          <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,12,0" Text="4"/>
          <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,6,12,0" Text="AIRFIELD/RUNWAY"/>
          <TextBlock Grid.Row="1" Grid.Column="3" Margin="0,6,0,0" Text="09-44-21.6N / 118-44-57.0E"/>

          <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,4,12,0" Text="AIRBASE/RPVP"/>
          <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,4,12,0" Text="4"/>
          <TextBlock Grid.Row="2" Grid.Column="2" Margin="0,4,12,0" Text="AAA POSITION A"/>
          <TextBlock Grid.Row="2" Grid.Column="3" Margin="0,4,0,0" Text="09-44-01.8N / 118-45-09.6E"/>

          <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,4,12,0" Text="AIRBASE/RPVP"/>
          <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,4,12,0" Text="4"/>
          <TextBlock Grid.Row="3" Grid.Column="2" Margin="0,4,12,0" Text="AAA POSITION B"/>
          <TextBlock Grid.Row="3" Grid.Column="3" Margin="0,4,0,0" Text="09-44-03.6N / 118-45-02.4E"/>

          <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,4,12,0" Text="AIRBASE/RPVP"/>
          <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,4,12,0" Text="4"/>
          <TextBlock Grid.Row="4" Grid.Column="2" Margin="0,4,12,0" Text="SA-10/S-300 SAM SITE"/>
          <TextBlock Grid.Row="4" Grid.Column="3" Margin="0,4,0,0" Text="09-45-14.4N / 118-45-28.2E"/>

          <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,4,12,0" Text="SOUTH APPROACH"/>
          <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,4,12,0" Text="5"/>
          <TextBlock Grid.Row="5" Grid.Column="2" Margin="0,4,12,0" Text="SILKWORM TEL A"/>
          <TextBlock Grid.Row="5" Grid.Column="3" Margin="0,4,0,0" Text="09-40-34.8N / 118-44-21.6E"/>

          <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,4,12,0" Text="SOUTH APPROACH"/>
          <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,4,12,0" Text="5"/>
          <TextBlock Grid.Row="6" Grid.Column="2" Margin="0,4,12,0" Text="SILKWORM TEL B"/>
          <TextBlock Grid.Row="6" Grid.Column="3" Margin="0,4,0,0" Text="09-40-36.0N / 118-44-25.8E"/>

          <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,4,12,0" Text="SOUTH APPROACH"/>
          <TextBlock Grid.Row="7" Grid.Column="1" Margin="0,4,12,0" Text="5"/>
          <TextBlock Grid.Row="7" Grid.Column="2" Margin="0,4,12,0" Text="SA-8 TEL A"/>
          <TextBlock Grid.Row="7" Grid.Column="3" Margin="0,4,0,0" Text="09-40-32.4N / 118-44-18.6E"/>

          <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,4,12,0" Text="SOUTH APPROACH"/>
          <TextBlock Grid.Row="8" Grid.Column="1" Margin="0,4,12,0" Text="5"/>
          <TextBlock Grid.Row="8" Grid.Column="2" Margin="0,4,12,0" Text="SA-8 TEL B"/>
          <TextBlock Grid.Row="8" Grid.Column="3" Margin="0,4,0,0" Text="09-40-39.6N / 118-44-24.0E"/>

          <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,4,12,0" Text="SOUTH APPROACH"/>
          <TextBlock Grid.Row="9" Grid.Column="1" Margin="0,4,12,0" Text="5"/>
          <TextBlock Grid.Row="9" Grid.Column="2" Margin="0,4,12,0" Text="SON-9 FIRE CONTROL"/>
          <TextBlock Grid.Row="9" Grid.Column="3" Margin="0,4,0,0" Text="09-40-36.6N / 118-44-22.2E"/>

          <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,4,12,0" Text="NORTH APPROACH"/>
          <TextBlock Grid.Row="10" Grid.Column="1" Margin="0,4,12,0" Text="2"/>
          <TextBlock Grid.Row="10" Grid.Column="2" Margin="0,4,12,0" Text="HY-1 TEL A"/>
          <TextBlock Grid.Row="10" Grid.Column="3" Margin="0,4,0,0" Text="09-45-25.8N / 118-45-51.6E"/>

          <TextBlock Grid.Row="11" Grid.Column="0" Margin="0,4,12,0" Text="NORTH APPROACH"/>
          <TextBlock Grid.Row="11" Grid.Column="1" Margin="0,4,12,0" Text="2"/>
          <TextBlock Grid.Row="11" Grid.Column="2" Margin="0,4,12,0" Text="HY-1 TEL B"/>
          <TextBlock Grid.Row="11" Grid.Column="3" Margin="0,4,0,0" Text="09-45-28.8N / 118-45-58.2E"/>
        </Grid>
      </Border>

      <TextBlock TextWrapping="Wrap" FontSize="16">
        3. (S) REGION SUMMARY: Antonio Bautista Airbase (RPVP) sector contains four identified installations. South approach contains five identified installations. North approach contains two identified installations. Total identified count is eleven.
        <LineBreak/><LineBreak/>
        4. (S) PLANNING EFFECT: SA-10/S-300 fire control, coastal missile TELs, and associated radar should be treated as first-order suppression targets before landing craft enter the harbor approaches. AAA and runway facilities remain strike targets for follow-on isolation of the landing area.
        <LineBreak/><LineBreak/>
        5. (S) HANDOFF: Coordinates derived from refs A and B, then formatted for ref C strike planning. Pass to battalion landing team, naval gunfire liaison, air liaison, and supporting aviation planners.
        <LineBreak/><LineBreak/>
        SIGNED: CINCPAC WATCH CENTER
        <LineBreak/><LineBreak/>
        BT
        <LineBreak/>
        SECRET DECL OADR
      </TextBlock>
    </StackPanel>
  </Border>
</ScrollViewer>
