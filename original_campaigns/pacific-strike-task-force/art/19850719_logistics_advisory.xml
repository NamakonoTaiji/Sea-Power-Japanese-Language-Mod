<!-- Pacific Strike classified logistics event: naval-message paper format. -->
<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16" Padding="45">
    <Border.Effect>
      <DropShadowEffect />
    </Border.Effect>
    <Border.Background>
      <ImageBrush ImageSource="{Binding Assets[bkg_paper]}" Stretch="UniformToFill"/>
    </Border.Background>

    <StackPanel Orientation="Vertical">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="3*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="NAVAL MESSAGE" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Left"/>
        <TextBlock Grid.Column="1" Text="*******S E C R E T*******" Margin="40,0,40,0" FontWeight="Bold" TextAlignment="Center"/>
        <TextBlock Grid.Column="2" Text="NAVY DEPARTMENT" FontFamily="Arial Narrow Bold" FontSize="26" FontWeight="Bold" TextAlignment="Right"/>
      </Grid>

      <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,1"/>
      <Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,10"/>

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" HorizontalAlignment="Left" FontSize="16">
          ROUTINE<LineBreak/>
          R 192200Z JUL 85
        </TextBlock>

        <TextBlock Grid.Row="0" Grid.Column="3" FontSize="16" Text="ZYUW RAYOC0777 2002200"/>
      </Grid>

      <Grid Margin="0,18,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" FontSize="16" Text="FM"/>
        <TextBlock Grid.Row="0" Grid.Column="2" FontSize="16" Text="COMSERVPAC DET DARWIN NT AU"/>
        <TextBlock Grid.Row="1" Grid.Column="0" FontSize="16" Text="TO"/>
        <TextBlock Grid.Row="1" Grid.Column="2" FontSize="16" Text="CINCPACFLT PEARL HARBOR HI"/>
        <TextBlock Grid.Row="2" Grid.Column="0" FontSize="16" Text="INFO"/>
        <TextBlock Grid.Row="2" Grid.Column="2" FontSize="16">
          CTF 77 DARWIN NT AU<LineBreak/>
          <Run Text="COMMANDER"/>
          <Run Text="{Binding DataSource.PersistentData[PlayerTaskForceName], Converter={StaticResource UppercaseConverter}}"/>
          <Run Text="DARWIN NT AU"/><LineBreak/>
          COMAUSFLT CANBERRA ACT AU
        </TextBlock>
        <TextBlock Grid.Row="3" Grid.Column="0" FontSize="16" Text="SUBJ"/>
        <TextBlock Grid.Row="3" Grid.Column="2" FontSize="16" Text="N4 READINESS ADVISORY - DARWIN MUNITIONS"/>
      </Grid>

      <TextBlock TextWrapping="Wrap" FontSize="16" Margin="0,24,0,0">
        SECRET
        <LineBreak/>
        BT
        <LineBreak/><LineBreak/>
        1. (S) SUMMARY: Critical munitions convoy diverted from Philippines stockpiles arrived Darwin 19JUL after successful southbound transit of Lombok Strait. Offload is underway under COMSERVPAC control.
        <LineBreak/><LineBreak/>
        2. (S) MATERIEL STATUS:
      </TextBlock>

      <Border Padding="8" Margin="0,4,0,8">
        <Grid TextElement.FontSize="16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="ITEM / FAMILY"/>
          <TextBlock Grid.Row="0" Grid.Column="1" Text="STATUS"/>

          <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,12,0" Text="RIM-66E / RIM-67B Standard"/>
          <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="Combat loads received for compatible Mk 13/Mk 26 ships at Darwin."/>

          <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,12,0" Text="RGM-84C/D Harpoon"/>
          <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="Canisterized and single rounds received and available for compatible ships"/>

          <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,12,0" Text="Gun ammunition"/>
          <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="5-inch/54, 5-inch/38, 76mm, 40mm, and 20mm stocks received"/>

          <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,12,0" Text="Point defense"/>
          <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="20mm CIWS, chaff, decoys, and noisemaker"/>

          <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6,12,0" Text="ASW stores"/>
          <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" Text="Mk 46 ship/air torpedoes, RUR-5 ASROC, sonobuoys, and depth charges"/>
        </Grid>
      </Border>

      <TextBlock TextWrapping="Wrap" FontSize="16">
        3. (S) SCHEDULE: Full distribution will require controlled issue by hull priority, magazine compatibility, and expected tasking. No general expenditure relaxation authorized.
        <LineBreak/><LineBreak/>
        4. (S) This command notes the Lombok Strait transit was made possible by a single U.S. warship detached from the addressed task force. By holding the strait under hostile air, surface, and submarine threat, that ship prevented Soviet raiders from closing the passage and bought the convoy the hours required to clear south.
        <LineBreak/><LineBreak/>
        5. (S) COMMENT: Recommend CINCPACFLT notify CTF 77 that logistics condition at Darwin has improved as a direct result of successful Lombok Strait action.
        <LineBreak/><LineBreak/>
        SIGNED: R. M. HALVERSON
        <LineBreak/>
        CAPT, SC, USN
        <LineBreak/>
        COMSERVPAC DET DARWIN / N4
        <LineBreak/><LineBreak/>
        BT
        <LineBreak/>
        SECRET DECL OADR
      </TextBlock>
    </StackPanel>
  </Border>
</ScrollViewer>
