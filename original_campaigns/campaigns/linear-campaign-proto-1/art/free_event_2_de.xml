<Page
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignWidth="1920"
  d:DesignHeight="1080">
    <Viewbox>
        <Border Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" Height="1272" Padding="45" 
            TextElement.FontFamily="Times New Roman" TextElement.Foreground="Black" TextElement.FontSize="16">
            <Border.Effect>
                <DropShadowEffect />
            </Border.Effect>
            <StackPanel Orientation="Vertical">
                <Border Background="red" Margin="0,0,0,5" HorizontalAlignment="Left" Width="205" Height="15">
                    <TextBlock Text="TV: S.24/25   Sport: S.30" Foreground="White" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" TextAlignment="Justify" Margin="15,0,0,0"/>
                </Border>
                <Canvas>
                    <Image Source="{Binding Assets[WAS]}" Width="200" Margin="0,60,0,15" Canvas.Left="0" Stretch="Uniform"/>
                </Canvas>
                <Rectangle HorizontalAlignment="Left" Width="205" Height="3" Fill="Black"/>
                <TextBlock Text="15.Mai 1988" Margin="0,5,0,0" FontSize="20"/>
                <TextBlock Text="Nr. 42 | 1,50 DM" Margin="0,0,0,0" FontSize="20"/>
                <!--Rectangle HorizontalAlignment="Stretch" Height="5" Fill="Black"/-->
                <!--Image Source="{Binding Assets[world_news_logo]}" Stretch="UniformToFill" Margin="0,15,0,15"/-->
                <!--Image Source="Assets/WDP3_logo.png" Stretch="UniformToFill" Margin="0,15,0,10"/-->
                <!--Rectangle HorizontalAlignment="Stretch" Height="5" Fill="Black"/-->
                <Border Background="Black" Margin="0,-80" HorizontalAlignment="Right" Width="590" Height="600">
                    <TextBlock Text="ESKALATION IM SCHWARZEN MEER:" Foreground="White" FontWeight="Bold" FontSize="30" TextWrapping="Wrap" TextAlignment="Center" Margin="15,10,10,15"/>
                </Border>
                <Rectangle HorizontalAlignment="Center" Width="590" Height="10" Margin="220,-920,0,15" Fill="red"/>
                <Border Background="Black" Margin="0,-60" HorizontalAlignment="Right" Width="590" Height="130">
                    <TextBlock Text="SOWJETISCHE KRIEGSSCHIFFE RAMMEN U.S. NAVY!" TextDecorations="Underline" Foreground="White" FontWeight="Bold" FontSize="55" TextWrapping="Wrap" TextAlignment="Justify" Margin="15,-400,10,15"/>
                </Border>
                <Border Background="Black" Margin="-120,-380,0,0" HorizontalAlignment="Center" Width="250" Height="130">
                    <TextBlock Text="Die sowjetische Fregatte Bezzavetnyy kollidierte mit dem US-Kreuzer Yorktown." Foreground="White" FontWeight="Bold" FontSize="18" TextWrapping="Wrap" TextAlignment="Justify" Margin="15,0,10,15"/>
                </Border>
                <Border Background="Black" Margin="-120,-180,0,0" HorizontalAlignment="Center" Width="250" Height="250">
                    <TextBlock Text=" Die absichtlichen Ramm-manöver ereigneten sich im Rahmen einer Kon-frontation zwischen der US Navy, die eine Freedom of Navigation-Übung durchführten und sowjet-ischen Seestreitkräften, die ihre territorialen Ansprüche untermauerten." Foreground="White" FontWeight="Bold" FontSize="18" TextWrapping="Wrap" TextAlignment="Justify" Margin="15,0,10,15"/>
                </Border>
                <!--Image Source="{Binding Assets[02_yorktown_collision]}" Stretch="Uniform"/-->
                <Canvas>
                    <Image Source="{Binding Assets[02_yorktown_collision]}" Width="300" Margin="0,-270,20,50" Canvas.Right="0" Stretch="Uniform"/>
                </Canvas>
                <Border Width="200" Height="320" Margin="0,-320,0,0" HorizontalAlignment="Left" BorderBrush="Black" BorderThickness="2">
                    <Grid>
                        <Rectangle Fill="OrangeRed" Opacity="0.4"/>
                        <TextBlock Text="Schiffe umgeleitet"
               Margin="15,0,10,15"
               Foreground="Black"
               FontWeight="Bold"
               FontSize="30"
               TextWrapping="Wrap"
               TextAlignment="center"/>
                        <TextBlock Text="ROTA, SPANIEN — Als Machtdemonstration hat die U.S. Navy eine Surface Action Group (SAG) von ihren Mittelmeereinsätzen in die Nordsee verlegt. Anlass ist die verstärkte sowjetische Marineaktivität im Nordatlantik und der Barentssee. (Seite 3)"
               Margin="15,80,10,15"
               Foreground="Black"
               FontWeight="Bold"
               FontSize="16"
               TextWrapping="Wrap"
               TextAlignment="Justify"/>
                    </Grid>
                </Border>
                <Grid Margin="0,15,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                </Grid>
                <Rectangle HorizontalAlignment="Stretch" Height="3" Fill="Black" Margin="0,-20,0,3"/>
                <Grid Margin="0,-10,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="2" Orientation="Vertical">
                        <TextBlock Text="VOLLE ABSICHT!" TextDecorations="Underline" FontSize="40" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="Alles zur sowjetischen Rammaktion auf hoher See" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,15,15"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Justify" Margin="0,0,25,15">
						NORFOLK, VIRGINIA — Die Spannungen spitzten sich gestern zu, als zwei sowjetische Kriegsschiffe absichtlich mit US-Marineeinheiten im Schwarzen Meer kollidierten. Der Vorfall ereignete sich nahe der Halbinsel Krim und betraf den Lenkwaffenkreuzer USS Yorktown (CG-48) sowie den Zerstörer USS Caron (DD-970), die laut Angaben der US-Marine auf einer sogenannten „Durchfahrt“ durch internationale Gewässer waren.
						<LineBreak/>
						US-Behörden zufolge kreuzten die sowjetische Fregatte Bezzavetnyy der Krivak-Klasse und eine Fregatte der Mirka-Klasse aggressiv den Weg der amerikanischen Schiffe und berührten diese bei geringer Geschwindigkeit. Es wurden keine Verletzten gemeldet, jedoch erlitt die Caron leichte Schäden an ihrer Backbordseite.
                        <LineBreak/>
                        Verteidigungsminister Frank Carlucci verurteilte das sowjetische Vorgehen als „leichtsinnig und eskalativ“. Der Kreml rechtfertigte das Rammen als Verteidigungsmaßnahme und warf den USA „provozierende Aufklärungstätigkeiten“ in der Nähe sensibler sowjetischer Einrichtungen vor. (siehe ZUSAMMENSTOSS auf S. 2)
                        </TextBlock>
                    </StackPanel>
                    <Canvas>
                        <Rectangle HorizontalAlignment="Left" Width="15" Height="550" Fill="red"/>
                        <Rectangle HorizontalAlignment="Center" Width="15" Height="550" Fill="red" Margin="400,0,0,0"/>
                        <Rectangle HorizontalAlignment="Right" Width="15" Height="550" Fill="red" Margin="795,0,0,0"/>
                        <Rectangle HorizontalAlignment="Center" Width="385" Height="3" Fill="black" Margin="15,200,0,0"/>
                    </Canvas>
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <TextBlock Text="SOWJETS FÜHREN TESTS MIT ATOMRAKETEN DURCH" TextDecorations="Underline" FontSize="40" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Margin="15,0,0,15"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Justify" Margin="20,15,0,15">
						MOSKAU — In einem Schritt, der die ohnehin angespannten Ost-West-Beziehungen weiter belastet, hat die Sowjetunion eine Reihe geplanter Raketentests in der Barentssee angekündigt. Die Tests, die innerhalb der nächsten zwei Wochen stattfinden sollen, umfassen sowohl von U-Booten aus gestartete als auch landgestützte ballistische Raketen. Innerhalb der NATO wachsen die Befürchtungen hinsichtlich der militärischen Absichten Moskaus.
						<LineBreak/>
						Der Kreml bezeichnet die Raketenstarts als Teil einer „routinemäßigen Einsatzübung“, die dazu dienen soll, die Verteidigungsfähigkeit der Sowjetunion zu überprüfen. Westliche Analysten hingegen befürchten, dass der Zeitpunkt der Tests – mitten in einer Reihe maritimer Konfrontationen – eher als Machtdemonstration denn als gewöhnliches Manöver zu werten ist. (siehe RAKETEN auf S. 7)
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <Rectangle HorizontalAlignment="Stretch" Height="3" Fill="Black" Margin="0,-36,0,15"/>
            </StackPanel>
        </Border>
    </Viewbox>
</Page>