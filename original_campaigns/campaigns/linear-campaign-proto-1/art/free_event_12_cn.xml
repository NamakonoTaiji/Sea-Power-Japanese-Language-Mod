<Page
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignWidth="1920"
  d:DesignHeight="1080">
  <Viewbox>
  <Grid Width="1920" Height="1080">
  <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="1120" Height="864" Padding="45" 
            TextElement.Foreground="Black" TextElement.FontSize="16" Background="#FFFAEBD7">
        <Border.RenderTransform>
          <TransformGroup>
            <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
            <SkewTransform/>
            <RotateTransform Angle="-8"/>
            <TranslateTransform X="178" Y="136"/>
          </TransformGroup>
        </Border.RenderTransform>
	  <Border.Effect>
	    <DropShadowEffect />
	  </Border.Effect>
			
	
      <Grid>
		<Grid.RowDefinitions>
		  <RowDefinition Height="Auto"/>
		  <RowDefinition Height="*"/>
		  <RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
        <Image Grid.Row="0" Source="{Binding Assets[NavyDSM]}" Width="153" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-30,0,0"/>
        <Image Grid.Row="2" Source="{Binding Assets[Seal_of_the_United_States_Department_of_Defense]}" Width="100" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
		<StackPanel Grid.Row="1" Orientation="Vertical">
          <TextBlock Text="海军部" TextWrapping="Wrap" FontFamily="Imprint MT Shadow" FontSize="45" HorizontalAlignment="Center" Margin="0,10,0,0"/>
          <TextBlock Text="向所有见证之人致意，兹证明海军部长于今日将" TextWrapping="Wrap"  FontFamily="Imprint MT Shadow" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,5,0,0"/>
          <TextBlock Text="杰出服役勋章" FontFamily="Imprint MT Shadow" FontSize="45" HorizontalAlignment="Center" Margin="-15,10,-15,0"/>
		  <TextBlock Text="授予" TextWrapping="Wrap" FontFamily="Imprint MT Shadow" TextAlignment="Center" FontSize="24" HorizontalAlignment="Center" Margin="0,5,0,0"/>
          <TextBlock Text="小李·加德纳" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Courier New" FontWeight="Bold" FontSize="26" Margin="0,5,0,0"/>
          <TextBlock Text="以表彰其作为第84舰载战斗机中队（VF-84）于1988年6月2日在阿图岛为美国建立的卓著功勋。凭借着出众的能力和个人积极性，加德纳为自己赢得了巨大的荣誉，也发扬了美国海军的光荣传统。" TextWrapping="Wrap" Margin="0,10,0,0" FontFamily="Courier New" FontSize="20" FontWeight="Bold"/>
		</StackPanel>
		<TextBlock Grid.Row="2" TextWrapping="Wrap" FontFamily="Imprint MT Shadow" VerticalAlignment="Center" FontSize="12">
于华盛顿特区签署
<LineBreak/>
日期：<Run FontFamily="Courier New" FontWeight="Bold" FontSize="18">1988年</Run><Run FontFamily="Courier New" FontWeight="Bold" FontSize="18">6月18日</Run>
		</TextBlock>
		<StackPanel Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center">
		  <TextBlock Text="戴维·J·奥斯伯恩" FontFamily="Brush Script MT" FontSize="60" Margin="0,0,0,-15"/>
		  <Rectangle Height="1" Fill="#FF000000" Margin="15,0,15,0"/>
          <TextBlock FontFamily="Imprint MT Shadow" Text="" TextAlignment="Center"/>
		</StackPanel>
      </Grid>
    </Border>
    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="1120" Height="864" Padding="45" 
            TextElement.Foreground="Black" TextElement.FontSize="16" Background="#FFFAEBD7">
        <Border.RenderTransform>
          <TransformGroup>
            <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
            <SkewTransform/>
            <RotateTransform Angle="-20"/>
            <TranslateTransform X="-382" Y="204"/>
          </TransformGroup>
        </Border.RenderTransform>
	  <Border.Effect>
	    <DropShadowEffect />
	  </Border.Effect>
			
	
      <Grid>
		<Grid.RowDefinitions>
		  <RowDefinition Height="Auto"/>
		  <RowDefinition Height="*"/>
		  <RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
        <Image Grid.Row="0" Source="{Binding Assets[Navy_Cross]}" Width="153" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-30,0,0"/>
        <Image Grid.Row="2" Source="{Binding Assets[Seal_of_the_United_States_Department_of_Defense]}" Width="100" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
		<StackPanel Grid.Row="1" Orientation="Vertical">
          <TextBlock Text="美利坚合众国" TextWrapping="Wrap" FontFamily="Imprint MT Shadow" FontSize="45" HorizontalAlignment="Center" Margin="0,10,0,0"/>
          <TextBlock TextWrapping="Wrap"  FontFamily="Imprint MT Shadow" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,5,0,0" Text="美利坚合众国总统将"/>
          <TextBlock Text="海军十字勋章" FontFamily="Imprint MT Shadow" FontSize="45" HorizontalAlignment="Center" Margin="-15,10,-15,0"/>
		  <TextBlock Text="授予" TextWrapping="Wrap" FontFamily="Imprint MT Shadow" TextAlignment="Center" FontSize="24" HorizontalAlignment="Center" Margin="0,5,0,0"/>
          <TextBlock Text="爱德华·G·迈耶三世" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Courier New" FontWeight="Bold" FontSize="26" Margin="0,5,0,0"/>
          <TextBlock Text="以表彰其作为第75.3特遣舰队司令于1988年6月2日在阿图岛为美国建立的卓著功勋。凭借着出众的能力、个人积极性和对职责的全心投入，迈耶为自己赢得了巨大的荣誉，也发扬了美国海军的光荣传统。" TextWrapping="Wrap" Margin="0,10,0,0" FontFamily="Courier New" FontSize="20" FontWeight="Bold"/>
		</StackPanel>
		<TextBlock Grid.Row="2" TextWrapping="Wrap" FontFamily="Imprint MT Shadow" VerticalAlignment="Center" FontSize="12">
于华盛顿特区签署
<LineBreak/>
日期：<Run FontFamily="Courier New" FontWeight="Bold" FontSize="18">1988年</Run><Run FontFamily="Courier New" FontWeight="Bold" FontSize="18">6月12日</Run>
		</TextBlock>
		<StackPanel Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center">
		  <TextBlock Text="唐纳德·G·华生" FontFamily="Brush Script MT" FontSize="60" Margin="0,0,0,-15"/>
		  <Rectangle Height="1" Fill="#FF000000" Margin="15,0,15,0"/>
          <TextBlock FontFamily="Imprint MT Shadow" Text="" TextAlignment="Center"/>
		</StackPanel>
      </Grid>
    </Border>
      <Image Source="{Binding Assets[United_States_Navy_Presidential_Unit_Citation_ribbon]}" Width="250" Margin="904,102,-34,694">
        <Image.RenderTransform>
          <TransformGroup>
            <ScaleTransform/>
            <SkewTransform/>
            <RotateTransform Angle="19"/>
            <TranslateTransform/>
          </TransformGroup>
        </Image.RenderTransform>
        <Image.Effect>
          <DropShadowEffect/>
        </Image.Effect>
      </Image>
      <Image Width="250" Source="{Binding Assets[Navy_Distinguished_Service_Medal_ribbon]}" Margin="955,419,-85,377">
        <Image.RenderTransform>
          <TransformGroup>
            <ScaleTransform/>
            <SkewTransform/>
            <RotateTransform Angle="-7"/>
            <TranslateTransform/>
          </TransformGroup>
        </Image.RenderTransform>
        <Image.Effect>
          <DropShadowEffect/>
        </Image.Effect>
      </Image>
      <Image Width="250" Source="{Binding Assets[Navy_Cross_ribbon]}" Margin="948,690,-78,106">
        <Image.RenderTransform>
          <TransformGroup>
            <ScaleTransform/>
            <SkewTransform/>
            <RotateTransform Angle="-31"/>
            <TranslateTransform/>
          </TransformGroup>
        </Image.RenderTransform>
        <Image.Effect>
          <DropShadowEffect/>
        </Image.Effect>
      </Image>
	</Grid>
  </Viewbox>
</Page>