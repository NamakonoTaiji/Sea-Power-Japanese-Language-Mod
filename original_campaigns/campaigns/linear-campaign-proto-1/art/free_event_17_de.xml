                        <!--<TextBlock Text="Правдоруб" Grid.Column="1" FontSize="135" FontFamily="Yu Gothic UI" FontWeight="Bold"/>
            <Rectangle Grid.ColumnSpan="2" Fill="#FF0000DD" Height="10" VerticalAlignment="Bottom" Margin="40,0,0,20" HorizontalAlignment="Left" Width="300"/>
            <Rectangle Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#FF0000FF" Height="10" Width="100" Margin="0,0,40,20"/>-->
                    </Grid>
                    <Border Background="AntiqueWhite" Margin="0,0,0,5" HorizontalAlignment="Left" Width="810" Height="150">
                        <TextBlock Text="DAS VOLK" FontFamily="Arial" Foreground="Black" FontWeight="Bold" FontSize="100" TextWrapping="Wrap" TextAlignment="Center" Margin="0,-30,0,0"/>
                    </Border>
                    <Border Background="AntiqueWhite" Margin="0,100,0,5" HorizontalAlignment="Left" Width="810" Height="50">
                        <TextBlock Text="ORGAN DER BEZIRKSLEITUNG ERFURT DER SOZIALISTISCHEN EINHEITSPARTEI DEUTSCHLANDS" FontFamily="Arial" Foreground="Black" FontWeight="Bold" FontSize="16" TextWrapping="Wrap" TextAlignment="Center" Margin="0,-25,0,0"/>
                    </Border>
                    <Border Background="AntiqueWhite" Margin="4,-140,0,5" HorizontalAlignment="Left" Width="125" Height="20">
                        <TextBlock Text="P  R  O  L  E  T  A  R  I  E  R" FontFamily="Times New Roman" Foreground="Black" FontWeight="Regular" FontSize="9" TextWrapping="Wrap" TextAlignment="Center" Margin="9,8,0,0"/>
                    </Border>
                    <Border Background="AntiqueWhite" Margin="4,-95,0,5" HorizontalAlignment="Left" Width="125" Height="20">
                        <TextBlock Text="A L L E R      L Ä N D E R ," FontFamily="Times New Roman" Foreground="Black" FontWeight="Regular" FontSize="9" TextWrapping="Wrap" TextAlignment="Center" Margin="9,3,0,0"/>
                    </Border>
                    <Border Background="AntiqueWhite" Margin="4,-55,0,5" HorizontalAlignment="Left" Width="125" Height="20">
                        <TextBlock Text="V E R E I N I G T  E U C H !" FontFamily="Times New Roman" Foreground="Black" FontWeight="Regular" FontSize="9" TextWrapping="Wrap" TextAlignment="Center" Margin="9,2,0,0"/>
                    </Border>
                    <Border Background="AntiqueWhite" Margin="4,-140,0,5" HorizontalAlignment="Right" Width="125" Height="20">
                        <TextBlock Text="Sonntag," FontFamily="Arial" Foreground="Black" FontWeight="Bold" FontSize="9" TextWrapping="Wrap" TextAlignment="Center" Margin="-74,5,0,0"/>
                    </Border>
                    <Border Background="AntiqueWhite" Margin="4,-95,0,5" HorizontalAlignment="Right" Width="125" Height="20">
                        <TextBlock Text="15. Mai 1988" FontFamily="Arial" Foreground="Black" FontWeight="Bold" FontSize="9" TextWrapping="Wrap" TextAlignment="Center" Margin="-60,-7,0,0"/>
                    </Border>
                    <Border Background="AntiqueWhite" Margin="4,-55,0,5" HorizontalAlignment="Right" Width="125" Height="10">
                        <TextBlock Text="44. Jahrgang Nr.211" FontFamily="Arial" Foreground="Black" FontWeight="Regular" FontSize="9" TextWrapping="Wrap" TextAlignment="Center" Margin="-30,-18,0,0"/>
                    </Border>
                    <Border Background="AntiqueWhite" Margin="4,-55,0,5" HorizontalAlignment="Right" Width="125" Height="10">
                        <TextBlock Text="Einzelpreis 15 Pf" FontFamily="Arial" Foreground="Black" FontWeight="Regular" FontSize="9" TextWrapping="Wrap" TextAlignment="Center" Margin="-43,-9,0,0"/>
                    </Border>
                    <Border Background="AntiqueWhite" Margin="4,-5,0,5" HorizontalAlignment="Right" Width="125" Height="5">
                        <TextBlock Text="Monatsabonnement 3,00 M" FontFamily="Arial" Foreground="Black" FontWeight="Regular" FontSize="9" TextWrapping="Wrap" TextAlignment="Center" Margin="0,-28,0,0"/>
                    </Border>
                    <Rectangle HorizontalAlignment="Stretch" Height="4" Fill="Black" Margin="0,50,0,0"/>
                    <Rectangle HorizontalAlignment="Stretch" Height="2" Fill="Black" Margin="0,60,0,0"/>
                    <Rectangle HorizontalAlignment="Left" Width="130" Height="2" Fill="Black" Margin="0,-170,0,0"/>
                    <Rectangle HorizontalAlignment="Left" Width="2" Height="68" Fill="Black" Margin="0,-102,0,0"/>
