                    <Rectangle HorizontalAlignment="Right" Width="130" Height="2" Fill="Black" Margin="0,-170,0,0"/>
                    <Rectangle HorizontalAlignment="Right" Width="2" Height="68" Fill="Black" Margin="0,-102,0,0"/>
