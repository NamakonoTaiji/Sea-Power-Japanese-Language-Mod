<Page
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignWidth="1920"
  d:DesignHeight="1080">
    <Viewbox>
        <Border Background="AntiqueWhite" HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" Height="1272" Padding="45" 
            TextElement.FontFamily="Times New Roman" TextElement.Foreground="Black" TextElement.FontSize="16">
            <Border.Effect>
                <DropShadowEffect />
            </Border.Effect>
            <StackPanel Orientation="Vertical">
                <Rectangle HorizontalAlignment="Stretch" Height="5" Fill="Black"/>
                <TextBlock Text="1988年3月8日|第80卷第39号|25美分" Margin="0,15,0,15" FontSize="24"/>
                <Rectangle HorizontalAlignment="Stretch" Height="5" Fill="Black"/>
                <Image Source="{Binding Assets[WDP_logo]}" Stretch="UniformToFill" Margin="0,15,0,10"/>
                <!--Rectangle HorizontalAlignment="Stretch" Height="5" Fill="Black"/-->
                <!--Grid Margin="0,5,0,15">
                    <Rectangle Fill="Red" Margin="0,110,0,5"/>
                    <TextBlock Text="爆炸性新闻" TextAlignment="Center" FontSize="112" FontWeight="Bold"/>
                </Grid>
                <Rectangle HorizontalAlignment="Stretch" Height="5" Fill="Black"/-->
                <Grid Margin="0,15,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="莫斯科退出导弹条约" FontWeight="Bold" FontSize="32" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,10"/>
                    <StackPanel Grid.Column="2" Grid.Row="1" Orientation="Vertical">

                        <TextBlock Text="克里姆林宫称条约为战略陷阱，北约官员感到惊恐" FontSize="24" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Justify">
						莫斯科——今天，在令人震惊的转折中，苏联宣布退出《中程导弹条约》并称其为“西方的一贯骗术”和“北约的包围战略”。
						<LineBreak/>
						总书记米哈伊尔·戈尔巴乔夫在向最高苏维埃发表的电视讲话中指责美国持续向北极地区增兵并在北约盟国秘密部署导弹，违反了此条约的“精神和内容”。戈尔巴乔夫宣称：“面对磨刀霍霍的北约，我们不会解除武装。”

						<LineBreak/>
三个月前刚刚签署的《中程导弹条约》标志着超级大国关系的历史性解冻，它授权销毁位于欧洲的数千枚导弹，这些导弹具备核打击能力。苏联退出条约的行为严重冲击了外交界，还有可能破坏已持续多年的军备控制工作。（接第2页）

                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Vertical" VerticalAlignment="Top">
                        <Image Source="{Binding Assets[01_ussr_missile_parade]}" Stretch="Uniform"/>
                        <TextBlock Text="在莫斯科的胜利日庆祝活动中，苏联军队在红场阅兵式上展示先进的中程弹道导弹。这些导弹可在几分钟内打击北约的绝大部分主要城市，体现了战略火箭军的实力。现已暂停执行的《中程导弹条约》旨在从双方的武库中消除此类武器，标志着双方向紧张局势降级和持久军备控制迈出的关键一步。（美联社图片）" TextWrapping="Wrap" TextAlignment="Left" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
                <Rectangle HorizontalAlignment="Stretch" Height="5" Fill="Black"/>
                <Grid Margin="0,15,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <TextBlock Text="苏联轰炸机在北海空域越界" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Justify">
                            奥斯陆——周五，苏联的两架图-95飞入挪威海岸25英里范围内，导致北约战斗机本月第三次拦截。英国和挪威官员证实英国皇家空军的狂风战斗机和挪威皇家空军F-16战斗机在苏联轰炸机绕飞两国防空识别区时紧急升空并进行跟随。
                            <LineBreak/>

军事分析师认为这种飞越是苏联不断增加的探测任务的一部分，其目标是测试北约的反应时间并收集电子情报。“他们越来越大胆了，”一位挪威国防部消息人士说。“这不是例行巡逻，而是在传递消息。”
                            <LineBreak/>双方没有发生敌对行为，但挪威外交大臣托尔瓦·斯托尔滕贝格称此次飞行为“挑衅”并警告莫斯科不要实施进一步的边缘政策。苏联外交部的回应则指责北约在“鼓吹”和“军事化北极边境”。
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Vertical">
                        <Image Source="{Binding Assets[01_bear_intercept]}"/>
                        <TextBlock Text="一架苏联图-95轰炸机在巴伦支海上空进行远程巡逻。此类飞机经常被苏联海军航空兵用于海上监视、电子情报收集和探测北约防空系统。图-95依靠其独特的涡轮螺旋桨发动机和长时间续航能力成为了挪威、英国和冰岛领空附近常见且挑衅意味十足的存在。美国官员谴责这些飞越行为是蓄意升级局势，目的是考验盟军的反应时间和决心。（国防部文件照片）" TextWrapping="Wrap" TextAlignment="Left" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="-1-" TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Viewbox>
</Page>