<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">
	<Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[Kuriles_NorthEastPacific_Close]}"/>
		<!-- Small Map -->
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[PacificFar]}" Width="250"/>
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="30" Height="20" Margin="60,0,0,140" BorderBrush="{StaticResource Brush.Border.FocusAccent}"/>
            </Grid>
        </Border>
		<!-- Photo inset -->
        <!--<Border Canvas.Right="10" Canvas.Bottom="10" BorderThickness="5" BorderBrush="White">
			<Border.Effect>
				<DropShadowEffect Opacity="0.25"/>
			</Border.Effect>
			<Border.RenderTransform>
				<TransformGroup>
					<RotateTransform Angle="-8" CenterY="200"/>
				</TransformGroup>
			</Border.RenderTransform>
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[10_kiev]}" Width="250"/>
            </Grid>
        </Border>-->
		
		<!-- Player unit summary -->
		<Border Canvas.Left="10" Canvas.Bottom="10" BorderThickness="3" BorderBrush="{StaticResource NTDS.FriendColour}" Background="#90a3b6" Width="250">
			<TextBlock Foreground="Blue" TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run Text="东方特遣舰队：" TextDecorations="Underline"/><LineBreak/>
                <Run Text="稳健（EM-679）"/><LineBreak/>
                <Run Text="谨慎（EM-672）"/><LineBreak/>
                <Run Text="光荣（RKR-103）"/><LineBreak/>
                <Run Text="伊萨琴科夫海军上将（BPK-686）"/><LineBreak/><LineBreak/>
                <Run Text="空中资产："/><LineBreak/>
                <Run Text="图-95RT（第392独立远程侦察航空团）"/><LineBreak/>
                <Run Text="图-22M2（第924近卫海军导弹航空团）"/><LineBreak/><LineBreak/>
                <Run Text="潜艇部队："/><LineBreak/>
                <Run Text="675型潜艇（K-175）"/>
           </TextBlock>
		</Border>

		<!-- Map Labels -->
		<TextBlock Foreground="SteelBlue" Text="北太平洋" HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold" Canvas.Left="750" Canvas.Top="300"/>
		
		<!-- Mission Area Ellipse -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Canvas.Left="475" Canvas.Top="300">
			<Ellipse Width="200" Height="200" Opacity="0.25" Fill="{StaticResource NTDS.HostileColour}"/>
			<!-- Mission Area Text -->
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" Text="美国特遣舰队" HorizontalAlignment="Center"/>
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" Text="大致位置" HorizontalAlignment="Center"/>
		</StackPanel>	
		
		<!-- Task Force Vostok -->
		<StackPanel Orientation="Vertical" Canvas.Left="400" Canvas.Top="200">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="东方特遣舰队"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- Tu-95RT 392nd ODRAP -->
		<StackPanel Orientation="Vertical" Canvas.Left="450" Canvas.Top="150">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="图-95RT（第392独立远程侦察航空团）"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Air}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- 2 x Tu-22M2 924th GuMRAP -->
		<StackPanel Orientation="Vertical" Canvas.Left="450" Canvas.Top="50">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="图-22M2（第924近卫海军导弹航空团）"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Air}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- K-175 -->
		<StackPanel Orientation="Vertical" Canvas.Left="450" Canvas.Top="600">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="K-175"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Submarine}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- U.S. Task Force -->
		<StackPanel Orientation="Vertical" Canvas.Left="532" Canvas.Top="380">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="美国特遣舰队"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>

		<!-- Arrows -->
		<!-- Tool for making paths: https://yqnn.github.io/svg-path-editor/ -->
		
		<Path Canvas.Left="450" Canvas.Top="445" Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z" Fill="{StaticResource NTDS.HostileColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="250"/>
            </Path.RenderTransform>
        </Path>
	</Canvas>
</Viewbox>
