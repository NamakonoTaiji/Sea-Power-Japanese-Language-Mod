<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">
	<Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[04_DiegoGarciaWest_Close]}"/>
		<!-- Small Map -->
        <Border Canvas.Left="10" Canvas.Bottom="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[IndianOceanFar]}" Width="250"/>
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="30" Height="20" Margin="80,0,0,30" BorderBrush="{StaticResource Brush.Border.FocusAccent}"/>
            </Grid>
        </Border>
		<!-- Photo inset -->
        <Border Canvas.Right="250" Canvas.Bottom="15" BorderThickness="5" BorderBrush="White" Background="White">
			<Border.Effect>
				<DropShadowEffect Opacity="0.25"/>
			</Border.Effect>
			<Border.RenderTransform>
				<TransformGroup>
					<RotateTransform Angle="-5" CenterY="200"/>
				</TransformGroup>
			</Border.RenderTransform>
            <StackPanel Orientation="Vertical">
                <Image Stretch="Uniform" Source="{Binding Assets[04_Diego_Garcia]}" Width="250"/>
				<TextBlock Foreground="Black" TextAlignment="Left" VerticalAlignment="Center" Margin="5" FontFamily="Courier New" FontWeight="Bold">
					<Run Text="迪戈加西亚岛美军基地"/><LineBreak/>
					<Run Text="国家安全委员会"/>
				</TextBlock>
            </StackPanel>	
        </Border>
		
		<!-- Photo inset -->
        <Border Canvas.Right="10" Canvas.Bottom="15" BorderThickness="5" BorderBrush="White" Background="White">
			<Border.Effect>
				<DropShadowEffect Opacity="0.25"/>
			</Border.Effect>
			<Border.RenderTransform>
				<TransformGroup>
					<RotateTransform Angle="5" CenterX="200"/>
				</TransformGroup>
			</Border.RenderTransform>
            <StackPanel Orientation="Vertical">
                <Image Stretch="Uniform" Source="{Binding Assets[04_Sacramento_AOE]}" Width="275"/>
				<TextBlock Foreground="Black" TextAlignment="Left" VerticalAlignment="Center" Margin="5" FontFamily="Courier New" FontWeight="Bold">
					<Run Text="萨克拉门托（AOE-2）"/><LineBreak/>
					<Run Text="海军1982年8月"/>
				</TextBlock>
            </StackPanel>	
        </Border>

		<!-- Map Labels -->
		<TextBlock Foreground="SteelBlue" Text="印度洋" HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold" Canvas.Left="550" Canvas.Top="75"/>
		<TextBlock Foreground="Black" Text="迪戈加西亚岛（英/美）" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="925" Canvas.Top="250">
			<!--<TextBlock.RenderTransform>
				<RotateTransform Angle="5" CenterX="200"/>
			</TextBlock.RenderTransform>-->
		</TextBlock>	
		
		<!-- Strike Group Molniya -->
		<StackPanel Orientation="Vertical" Canvas.Left="400" Canvas.Top="525">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="闪电打击群"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- K-184 -->
		<StackPanel Orientation="Vertical" Canvas.Left="525" Canvas.Top="150">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="K-184"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Submarine}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- Ampermetr -->
		<StackPanel Orientation="Vertical" Canvas.Left="400" Canvas.Top="350">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="电流表"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- USS Sacramento Force -->
		<StackPanel Orientation="Vertical" Canvas.Left="200" Canvas.Top="250">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="萨克拉门托号编队"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- Logistics Shuttle Force -->
		<StackPanel Orientation="Vertical" Canvas.Left="625" Canvas.Top="275">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="Logistics Shuttle Force"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- SAN Subs (?) -->
		<StackPanel Orientation="Vertical" Canvas.Left="450" Canvas.Top="250">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="？"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Submarine}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- Diego Garcia NSF -->
		<StackPanel Orientation="Vertical" Canvas.Left="1010" Canvas.Top="190">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text=""/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Airbase}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>

		<!-- Arrows -->
		<!-- Tool for making paths: https://yqnn.github.io/svg-path-editor/ -->
        <Path Canvas.Left="455" Canvas.Top="450" Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z" Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="0"/>
            </Path.RenderTransform>
        </Path>

	</Canvas>
</Viewbox>