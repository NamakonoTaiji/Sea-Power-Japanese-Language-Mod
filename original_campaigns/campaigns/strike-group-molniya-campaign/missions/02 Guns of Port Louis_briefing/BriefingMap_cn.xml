<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">
	<Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[02_Mauritius_Close]}"/>
		<!-- Small Map -->
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[IndianOceanFar]}" Width="250"/>
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="30" Height="20" Margin="90,0,0,85" BorderBrush="{StaticResource Brush.Border.FocusAccent}"/>
            </Grid>
        </Border>
		<!-- Photo inset -->
        <Border Canvas.Left="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White" Background="White">
			<Border.Effect>
				<DropShadowEffect Opacity="0.25"/>
			</Border.Effect>
			<Border.RenderTransform>
				<TransformGroup>
					<RotateTransform Angle="8" CenterY="200"/>
				</TransformGroup>
			</Border.RenderTransform>
            <StackPanel Orientation="Vertical">
                <Image Stretch="Uniform" Source="{Binding Assets[02_convoy]}" Width="250"/>
				<TextBlock Foreground="Black" TextAlignment="Left" VerticalAlignment="Center" Margin="5" FontFamily="Courier New" FontWeight="Bold">
					<Run Text="路易港内的北约船只"/><LineBreak/>
					<Run Text="国家安全委员会1985年7月1日"/>
				</TextBlock>
            </StackPanel>	
        </Border>
		<Border Canvas.Left="10" Canvas.Bottom="35" BorderThickness="5" BorderBrush="White" Background="White">
			<Border.Effect>
				<DropShadowEffect Opacity="0.25"/>
			</Border.Effect>
			<Border.RenderTransform>
				<TransformGroup>
					<RotateTransform Angle="-8" CenterX="200"/>
				</TransformGroup>
			</Border.RenderTransform>
            <StackPanel Orientation="Vertical">
                <Image Stretch="Uniform" Source="{Binding Assets[02_mirage]}" Width="250"/>
				<TextBlock Foreground="Black" TextAlignment="Left" VerticalAlignment="Center" Margin="5" FontFamily="Courier New" FontWeight="Bold">
					<Run Text="南非幻影F1"/><LineBreak/>
					<Run Text="图片：苏联空军/安哥拉人民解放运动"/>
				</TextBlock>
            </StackPanel>	
        </Border>
		<!-- Player unit summary - not possible given persistent nature of campaign! -->
		<!--
		<Border Canvas.Left="10" Canvas.Bottom="95" BorderThickness="3" BorderBrush="{StaticResource NTDS.FriendColour}" Background="#90a3b6" Width="250">
			<TextBlock Foreground="Blue" TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run Text="STRIKE GROUP MOLNIYA:" TextDecorations="Underline"/><LineBreak/><LineBreak/>
                <Run Text="Petropavlovsk BPK-591"/><LineBreak/>
                <Run Text="Ognevoy BPK-296"/>
           </TextBlock>
		</Border>
		
		<Border Canvas.Left="10" Canvas.Bottom="10" BorderThickness="3" BorderBrush="{StaticResource NTDS.FriendColour}" Background="#90a3b6" Width="250">
			<TextBlock Foreground="Blue" TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run Text="MOLNIYA AVIATION DETACHMENT:" TextDecorations="Underline"/><LineBreak/><LineBreak/>
                <Run Text="Varyag RKR-120"/><LineBreak/>
                <Run Text="MV Znamya Oktyabrya"/>
           </TextBlock>
		</Border>-->

		<!-- Map Labels -->
		<TextBlock Foreground="SteelBlue" Text="印度洋" HorizontalAlignment="Center" FontStyle="Italic" FontSize="16" FontWeight="Bold" Canvas.Left="550" Canvas.Top="75"/>
		<TextBlock Foreground="Black" Text="毛里求斯（法）" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Canvas.Left="725" Canvas.Top="450"/>
		<TextBlock Foreground="Black" Text="路易港" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Canvas.Left="775" Canvas.Top="375"/>
		
		<!-- Strike Group Molniya -->
		<StackPanel Orientation="Vertical" Canvas.Left="300" Canvas.Top="350">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="闪电打击群"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- Molniya Aviation Force -->
		<StackPanel Orientation="Vertical" Canvas.Left="350" Canvas.Top="200">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="闪电打击群航空部队"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- NATO Merchant Convoy -->
		<StackPanel Orientation="Vertical" Canvas.Left="700" Canvas.Top="320">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="北约商船"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- NATO Escorts (?) -->
		<StackPanel Orientation="Vertical" Canvas.Left="700" Canvas.Top="250">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="护航（？）"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- Emplacements -->
		<StackPanel Orientation="Vertical" Canvas.Left="680" Canvas.Top="370">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="海岸炮"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Installation}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- Hawk -->
		<StackPanel Orientation="Vertical" Canvas.Left="850" Canvas.Top="250">
			<TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="鹰式阵地"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.SAM}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- Civilian Vessels -->
		<StackPanel Orientation="Vertical" Canvas.Left="525" Canvas.Top="325">
			<TextBlock Foreground="{StaticResource NTDS.NeutralColour}" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="民用船只"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.NeutralColour}" Data="{StaticResource NTDS.Neutral.Surface}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.NeutralColour}"/>
            </Canvas>
        </StackPanel>

		<!-- Arrows -->
		<!-- Tool for making paths: https://yqnn.github.io/svg-path-editor/ -->
        <Path Canvas.Left="450" Canvas.Top="375" Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z" Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="90"/>
            </Path.RenderTransform>
        </Path>
		
		<Path Canvas.Left="535" Canvas.Top="190" Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z" Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="75"/>
            </Path.RenderTransform>
        </Path>

	</Canvas>
</Viewbox>