<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeapowerUI">
    <Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[01_SaintHelena_SouthAtlantic_Close]}" />
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[SouthAtlanticFar]}" Width="250" />
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Width="30" Height="20" Margin="160,0,0,70"
                    BorderBrush="{StaticResource Brush.Border.FocusAccent}" />
            </Grid>
        </Border>
        <Border Canvas.Left="5" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Border.Effect>
                <DropShadowEffect Opacity="0.25" />
            </Border.Effect>
            <Border.RenderTransform>
                <TransformGroup>
                    <RotateTransform Angle="12" CenterY="200" />
                </TransformGroup>
            </Border.RenderTransform>
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[01_edson_new_orleans]}" Width="250" />
            </Grid>
        </Border>
        <Border Canvas.Left="225" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Border.Effect>
                <DropShadowEffect Opacity="0.25" />
            </Border.Effect>
            <Border.RenderTransform>
                <TransformGroup>
                    <RotateTransform Angle="5" CenterY="200" />
                </TransformGroup>
            </Border.RenderTransform>
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[01_president_monroe]}" Width="250" />
            </Grid>
        </Border>
        <Border Canvas.Left="10" Canvas.Bottom="10" BorderThickness="3"
            BorderBrush="{StaticResource NTDS.FriendColour}" Background="#90a3b6" Width="250">
            <TextBlock Foreground="Blue" TextAlignment="Left" VerticalAlignment="Center" Margin="5">
                <Run Text="打撃群「モルニヤ」：" TextDecorations="Underline" />
                <LineBreak />
                <LineBreak />
                <Run Text="大型対潜艦 ペトロパブロフスク" />
                <LineBreak />
                <Run Text="ミサイル巡洋艦 ヴァリャーグ" />
                <LineBreak />
                <Run Text="大型対潜艦 オグネヴォイ" />
                <LineBreak />
                <Run Text="貨物船 ズナーミャ・オクチャブリャ" />
            </TextBlock>
        </Border>

        <TextBlock Foreground="SteelBlue" Text="南大西洋" HorizontalAlignment="Center"
            FontStyle="Italic" FontSize="16" FontWeight="Bold" Canvas.Left="525" Canvas.Top="75" />
        <TextBlock Foreground="Black" Text="アンゴラ" HorizontalAlignment="Center" FontSize="20"
            FontWeight="Bold" Canvas.Left="1000" Canvas.Top="550" />
        <TextBlock Foreground="Black" Text="セントヘレナ（英領）" HorizontalAlignment="Center" FontSize="14"
            FontWeight="Bold" Canvas.Left="190" Canvas.Top="500" />

        <StackPanel Orientation="Vertical" Canvas.Left="300" Canvas.Top="350">
            <TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center"
                Margin="0,0,0,0">
                <Run Text="打撃群「モルニヤ」" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.FriendColour}"
                    Data="{StaticResource NTDS.Allied.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}" />
            </Canvas>
        </StackPanel>

        <StackPanel Orientation="Vertical" Canvas.Left="450" Canvas.Top="300">
            <TextBlock Foreground="{StaticResource NTDS.HostileColour}" TextAlignment="Center"
                VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="NATO商船船団（所在不明！）" />
            </TextBlock>
            <Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}"
                    Stroke="{StaticResource NTDS.HostileColour}"
                    Data="{StaticResource NTDS.Enemy.Surface}" />
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3"
                    StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}" />
            </Canvas>
        </StackPanel>

        <Path Canvas.Left="625" Canvas.Top="400"
            Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z"
            Fill="{StaticResource NTDS.HostileColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="140" />
            </Path.RenderTransform>
        </Path>

    </Canvas>
</Viewbox>