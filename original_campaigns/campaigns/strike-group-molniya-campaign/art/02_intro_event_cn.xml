<!-- Campaign event template USSR dispatch - formatting taken from real world examples -->
<Page
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:SeapowerUI"
  mc:Ignorable="d"
  d:DesignWidth="1920"
  d:DesignHeight="1080">
  <Viewbox>
    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" Height="1272" Padding="45" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16">
		<Border.Effect>
			<DropShadowEffect />
		</Border.Effect>
		
		<Border.Background>
			<ImageBrush ImageSource="{Binding Assets[bkg_paper]}" Stretch="UniformToFill"/>
		</Border.Background>
		
        <StackPanel Orientation="Vertical">

		<Grid
		  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" >
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="3*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			
			<TextBlock Grid.Row="0" Grid.Column="0" Text="# 374/PR/52" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
			<TextBlock Grid.Row="1" Grid.Column="0" Text="17.05.85 r." Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
			<TextBlock Grid.Row="0" Grid.Column="1" Text="" Margin="40,0,40,0" FontWeight="Bold" TextAlignment="Center"/>
			<TextBlock Grid.Row="0" Grid.Column="2" Text="绝密" Margin="0" TextDecorations="Underline" FontSize="20" FontWeight="Bold" TextAlignment="Right"/>
			<TextBlock Grid.Row="1" Grid.Column="2" Text="印本编号1" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Center"/>
		</Grid>

				<TextBlock Text="指令编号017/85" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
				<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,1"/>
				<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,10"/>

			<Grid
			  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
			<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="10"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="10"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="发件："/>
				<TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="海军司令部"/>
				<TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="收件："/>
				<TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="北方舰队司令"/>
				<TextBlock Grid.Row="5" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="抄送："/>
				<TextBlock Grid.Row="5" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="太平洋舰队司令"/>
				<TextBlock Grid.Row="6" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="主题："/>
				<TextBlock Grid.Row="6" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="彼得罗巴甫洛夫斯克号的前沿部署"/>

				<TextBlock Grid.Row="7" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap" FontWeight="Bold">
					<LineBreak/>
					根据当前国际形势和已批准的应急计划指令，太平洋舰队的大型反潜舰彼得罗巴甫洛夫斯克号临时调往北方舰队。
					<LineBreak/>
					<LineBreak/>
					北方舰队司令需将彼得罗巴甫洛夫斯克号及其附属部队部署至南大西洋。彼得罗巴甫洛夫斯克号将与下列舰艇会合：
					<LineBreak/>
					<LineBreak/>
					•导弹巡洋舰瓦良格号
					<LineBreak/>
					•大型反潜舰火热号
					<LineBreak/>
					•试验航空舰十月旗帜号
					<LineBreak/>
					•8架雅克-38（第279独立舰载攻击航空团）
					<LineBreak/>
					<LineBreak/>
					这支部队将被命名为闪电打击群，需在严格的无线电静默条件下行动，避免不必要的接触，并且必须在既定的商业航线以外行动。
					<LineBreak/>
					<LineBreak/>
					抵达指定行动区域后，打击群将保持高度戒备状态，以便在敌对行为发生时执行战斗任务。一旦确认行动态势发生变化，我们将下达进一步指示。
					<LineBreak/>
				</TextBlock>
				<TextBlock Grid.Row="8" Grid.ColumnSpan="4" TextWrapping="Wrap" FontWeight="Bold">
					指令结束
					<LineBreak/>
					/署名/戈尔什科夫
					<LineBreak/>
					<LineBreak/>
					绝密
					<LineBreak/>
					阅后销毁	
				</TextBlock>
			</Grid>
        </StackPanel>
    </Border>
</Viewbox>
</Page>