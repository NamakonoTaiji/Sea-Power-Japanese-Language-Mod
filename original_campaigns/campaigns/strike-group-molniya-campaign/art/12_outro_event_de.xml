<Page
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignWidth="1920"
  d:DesignHeight="1080">
    <Viewbox>
        <Border Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" Height="1272" Padding="45" 
            TextElement.FontFamily="Times New Roman" TextElement.Foreground="Black" TextElement.FontSize="16">
            <Border.Effect>
                <DropShadowEffect />
            </Border.Effect>
            <StackPanel Orientation="Vertical">
                <Border Background="red" Margin="0,0,0,5" HorizontalAlignment="Left" Width="205" Height="15">
                    <TextBlock Text="TV: S.24/25   Sport: S.30" Foreground="White" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" TextAlignment="Justify" Margin="15,0,0,0"/>
                </Border>
                <Canvas>
                    <Image Source="{Binding Assets[WAS]}" Width="200" Margin="0,60,0,15" Canvas.Left="0" Stretch="Uniform"/>
                </Canvas>
                <Rectangle HorizontalAlignment="Left" Width="205" Height="3" Fill="Black"/>
                <TextBlock Text="21.Juli 1985" Margin="0,5,0,0" FontSize="20"/>
                <TextBlock Text="Nr. 28 | 1,50 DM" Margin="0,0,0,0" FontSize="20"/>
                <Border Background="Black" Margin="0,-80" HorizontalAlignment="Right" Width="590" Height="600">
                    <TextBlock Text="PEINLICHE BLAMAGE AUF HOHER SEE:" Foreground="White" FontWeight="Bold" FontSize="28.2" TextWrapping="Wrap" TextAlignment="Center" Margin="15,10,10,15"/>
                </Border>
                <Rectangle HorizontalAlignment="Center" Width="590" Height="10" Margin="220,-920,0,15" Fill="red"/>
                <Border Background="Black" Margin="0,-60" HorizontalAlignment="Right" Width="590" Height="130">
                    <TextBlock Text="SOWJET-FLOTTE ENTKOMMT NATO! ZUFLUCHT IN INDI-SCHEM HAFEN!" TextDecorations="Underline" Foreground="White" FontWeight="Bold" FontSize="55" TextWrapping="Wrap" TextAlignment="Justify" Margin="15,-400,10,15"/>
                </Border>
                <Border Background="Black" Margin="-120,-180,0,0" HorizontalAlignment="Center" Width="250" Height="250">
                    <TextBlock Text="Der sowjetische Raketen-kreuzer „Petropavlovsk“ entgeht nach einer spek-takulären Jagd durch Atlan-tik und Indischen Ozean den NATO-Streitkräften und taucht schließlich in indi-schen Gewässern unter. Mili-tärexperten sprechen von einem schweren Rückschlag, nachdem wichtige NATO-Kräfte abgezogen werden mussten." Foreground="White" FontWeight="Bold" FontSize="18" TextWrapping="Wrap" TextAlignment="Justify" Margin="15,-30,10,15"/>
                </Border>
                <Canvas>
                    <Image Source="{Binding Assets[12_petropavlovsk]}" Width="320" Margin="0,-320,20,50" Canvas.Right="0" Stretch="Uniform"/>
                </Canvas>
                <Border Width="200" Height="320" Margin="0,-320,0,0" HorizontalAlignment="Left" BorderBrush="Black" BorderThickness="2">
                    <Grid>
                        <Rectangle Fill="OrangeRed" Opacity="0.4"/>
                        <TextBlock Text="Opposition fordert Aufklärung zur Marine-Krise"
               Margin="1,0,1,1"
               Foreground="Black"
               FontWeight="Bold"
               FontSize="20"
               TextWrapping="Wrap"
               TextAlignment="center"/>
                        <TextBlock Text="BONN: Nach den jüng-sten Vorfällen auf hoher See verlangen mehrere Abgeordnete eine umfassende Unterrich-tung durch die Bunde-sregierung. Kritiker sprechen von offenen Fragen zur Sicherheits-lage und warnen vor möglichen Folgen für Europa. (Seite 3)"
               Margin="15,80,10,15"
               Foreground="Black"
               FontWeight="Bold"
               FontSize="16"
               TextWrapping="Wrap"
               TextAlignment="Justify"/>
                    </Grid>
                </Border>
                <Grid Margin="0,15,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                </Grid>
                <!--Rectangle HorizontalAlignment="Stretch" Height="3" Fill="Black" Margin="0,-20,0,3"/-->
                <Grid Margin="0,-10,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="2" Orientation="Vertical">
                        <TextBlock Text="NATO zieht die Schlinge zu!" TextDecorations="Underline" FontSize="40" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="US-Flotte blockiert Indiens Küste" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,25,15"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Justify" Margin="0,0,25,15">
						COCHIN, INDIEN: Die Vereinigten Staaten haben vor der Westküste Indiens eine massive Seebarriere errichtet, nachdem sowjetische Kriegsschiffe im Hafen von Cochin Zuflucht gesucht haben. Kriegsschiffe und Aufklärungsflugzeuge kreisen rund um die Uhr außerhalb indischer Gewässer und behalten jede Bewegung im Blick.
						<LineBreak/>
						Militärkreise berichten von einem Großaufgebot aus Trägerflugzeugen und Begleitschiffen, das sämtliche Seewege überwacht. Offiziell respektieren die US-Streitkräfte Indiens Neutralität, doch die Präsenz zeigt deutlich, dass Washington keinen weiteren sowjetischen Vorstoß dulden will.
                        <LineBreak/>
                        Weitere militärische Schritte sind bislang nicht angekündigt, doch die US-Flotte soll so lange vor Ort bleiben, wie die sowjetischen Einheiten im Hafen liegen. Verbündete sprechen von einem klaren Signal an Moskau, während die angespannte Lage auf den Weltmeeren weiter anhält. (weiter auf Seite 4)
                        </TextBlock>
                    </StackPanel>
                    <Canvas>
                        <Rectangle HorizontalAlignment="Left" Width="15" Height="550" Fill="red"/>
                        <Rectangle HorizontalAlignment="Center" Width="15" Height="550" Fill="red" Margin="400,0,0,0"/>
                        <Rectangle HorizontalAlignment="Right" Width="15" Height="550" Fill="red" Margin="795,0,0,0"/>
                        <!--Rectangle HorizontalAlignment="Center" Width="385" Height="3" Fill="black" Margin="15,200,0,0"/-->
                    </Canvas>
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <TextBlock Text="SOWJET-KREUZER ENTKOMMT ÜBER ZWEI OZEANE" TextDecorations="Underline" FontSize="40" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Margin="15,0,0,15"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Justify" Margin="20,15,0,15">
						INDISCHER OZEAN: Nach einer wochenlangen Jagd über Tausende Seemeilen ist es dem sowjetischen Raketenkreuzer „Petropavlovsk“ gelungen, den NATO-Streitkräften zu entkommen und in indischen Gewässern Zuflucht zu finden. Westliche Kriegsschiffe und Aufklärungsflugzeuge hatten den Kreuzer seit seinem Auftauchen im Atlantik verfolgt, verloren jedoch kurz vor der indischen Küste den Zugriff.
						<LineBreak/>
						Ein US-Senator bezeichnete den Abbruch der Verfolgung als „ernste Schwäche“ und warnte vor einem gefährlichen Signal an den Osten. Offizielle Stellen in Washington und anderen NATO-Hauptstädten lehnten eine Stellungnahme hierzu ab. Unterdessen bleiben amerikanische Kriegsschiffe vor der indischen Küste in Alarmbereitschaft. Beobachter befürchten, dass der spektakuläre Vorfall das Vertrauen in die Handlungsfähigkeit des Westens erschüttern könnte. (weiter auf Seite 2)
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <!--Rectangle HorizontalAlignment="Stretch" Height="3" Fill="Black" Margin="0,-36,0,15"/-->
            </StackPanel>
        </Border>
    </Viewbox>
</Page>