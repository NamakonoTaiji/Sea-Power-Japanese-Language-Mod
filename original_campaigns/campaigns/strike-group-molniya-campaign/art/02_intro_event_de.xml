<!-- Campaign event template USSR dispatch - formatting taken from real world examples -->

<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">

	<Border HorizontalAlignment="Center" VerticalAlignment="Center" Height="UniformToFill" Width="900" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16" Padding="45">
		<Border.Effect>
			<DropShadowEffect />
		</Border.Effect>
		<Border.Background>
			<ImageBrush ImageSource="{Binding Assets[bkg_paper]}" Stretch="UniformToFill"/>
		</Border.Background>
		
        <StackPanel Orientation="Vertical">

		<Grid
		  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" >
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="3*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			
			<TextBlock Grid.Row="0" Grid.Column="0" Text="# 374/PR/52" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
			<TextBlock Grid.Row="1" Grid.Column="0" Text="17.05.85 r." Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
			<TextBlock Grid.Row="0" Grid.Column="1" Text="" Margin="40,0,40,0" FontWeight="Bold" TextAlignment="Center"/>
			<TextBlock Grid.Row="0" Grid.Column="2" Text="Cовершенно cекретно" Margin="0" TextDecorations="Underline" FontSize="20" FontWeight="Bold" TextAlignment="Right"/>
			<TextBlock Grid.Row="1" Grid.Column="2" Text="Экз. № 1" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Center"/>
		</Grid>

				<TextBlock Text="DIREKTIVE Nr.017/85" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
				<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,1"/>
				<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,10"/>

			<Grid
			  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
			<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="10"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="10"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="VON:"/>
				<TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="Oberkommando der Marine (GK VMF)"/>
				<TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="AN:"/>
				<TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="Kommandant, Rotbanner-Nordflotte"/>
				<TextBlock Grid.Row="5" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="KOPIE:"/>
				<TextBlock Grid.Row="5" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="Operative Hauptverwaltung, Generalstab"/>
				<TextBlock Grid.Row="6" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="BETREFF:"/>
				<TextBlock Grid.Row="6" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="Vorverlegung der PETROPAVLOVSK"/>

				<TextBlock Grid.Row="7" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap" FontWeight="Bold">
					<LineBreak/>
					Basierend auf der aktuellen internationalen Lage und gemäß den genehmigten Einsatzplanungsrichtlinien wird das große U-Jagd-Schiff PETROPAVLOVSK der Rotbanner-Pazifikflotte nun der Rotbanner-Nordflotte unterstellt.
					<LineBreak/>
					<LineBreak/>
					Der Kommandeur der Rotbanner-Nordflotte wird angewiesen, die PETROPAVLOVSK mit zugeordneten Kräften in den Südatlantik zu verlegen. PETROPAVLOVSK wird durch folgende Kriegsschiffe unterstützt:
					<LineBreak/>
					<LineBreak/>
					• Lenkwaffenkreuzer VARYAG
					<LineBreak/>
					• Großes U-Jagd-Schiff OGNEVOY
					<LineBreak/>
					• Experimentelles Flugdeckkreuzer ZNYAMNYA OKTYBYRA
					<LineBreak/>
					• 6 x Yak-38 des 279. Marinefliegerregiments
					<LineBreak/>
					<LineBreak/>
					Dieser Verband wird als EINSATZGRUPPE MOLNIYA (Blitz) bezeichnet. Der Verband hat unter strenger Funkstille zu operieren, unnötigen Kontakt zu vermeiden und außerhalb etablierter Handelsschifffahrtsrouten zu verbleiben.
					<LineBreak/>
					<LineBreak/>
					Nach Erreichen des zugewiesenen Einsatzraumes hat die Einsatzgruppe volle Gefechtsbereitschaft zur Durchführung von Kampfeinsätzen im Falle von Feindseligkeiten aufrechtzuerhalten. Weitere Weisungen werden bei Änderungen der operativen Lage übermittelt.
					<LineBreak/>
				</TextBlock>
				<TextBlock Grid.Row="8" Grid.ColumnSpan="4" TextWrapping="Wrap" FontWeight="Bold">
					ENDE DER NACHRICHT
					<LineBreak/>
					/s/ GORSHKOV
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					Cовершенно cекретно
					<LineBreak/>
					При чтении — уничтожить
				</TextBlock>
			</Grid>
        </StackPanel>
    </Border>
</ScrollViewer>