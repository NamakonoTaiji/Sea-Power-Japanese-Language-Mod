<!-- Campaign event template USSR dispatch - formatting taken from real world examples -->

<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">

	<Border HorizontalAlignment="Center" VerticalAlignment="Center" Height="UniformToFill" Width="900" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16" Padding="45">
		<Border.Effect>
			<DropShadowEffect />
		</Border.Effect>
		<Border.Background>
			<ImageBrush ImageSource="{Binding Assets[bkg_paper]}" Stretch="UniformToFill"/>
		</Border.Background>
		
        <StackPanel Orientation="Vertical">

		<Grid
		  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" >
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="3*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			
			<TextBlock Grid.Row="0" Grid.Column="0" Text="# 387/PR/51" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
			<TextBlock Grid.Row="1" Grid.Column="0" Text="04.07.85 r." Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
			<TextBlock Grid.Row="0" Grid.Column="1" Text="" Margin="40,0,40,0" FontWeight="Bold" TextAlignment="Center"/>
			<TextBlock Grid.Row="0" Grid.Column="2" Text="绝密" Margin="0" TextDecorations="Underline" FontSize="20" FontWeight="Bold" TextAlignment="Right"/>
			<TextBlock Grid.Row="1" Grid.Column="2" Text="印本编号1" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Center"/>
		</Grid>

				<TextBlock Text="指令编号022/85" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
				<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,1"/>
				<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,10"/>

			<Grid
			  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
			<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="10"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="10"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="发件："/>
				<TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="北方舰队司令"/>
				<TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="收件："/>
				<TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="闪电打击群指挥官"/>
				<TextBlock Grid.Row="5" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="抄送："/>
				<TextBlock Grid.Row="5" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="太平洋舰队第8作战分舰队司令"/>
				<TextBlock Grid.Row="6" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="主题："/>
				<TextBlock Grid.Row="6" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="印度洋特别行动"/>

				<TextBlock Grid.Row="7" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap" FontWeight="Bold">
					<LineBreak/>
					总部已收到你于7月3日提交的毛里求斯近海行动总结报告。在此谨向闪电打击群的军官、水手、飞行员们表示祝贺，感谢他们纪律严明地执行了扰乱敌方海上活动的行动。我方情报显示你的行动已迫使北约重新部署大西洋和太平洋战区的重要资产。
					<LineBreak/>
					<LineBreak/>
					你提交的附件（A）详细列出了弹药消耗、燃料状况和物资准备情况，我们已审阅。总部同意你的评估，即若不立即补充物资，持续的进攻行动将无法维持。在你离开北方舰队水域之前，我们已授权三艘商船秘密航行，运送燃料、给养、航空物资和备用导弹。这些船只自出发以来一直在佯装进行商业活动。
					<LineBreak/>
					<LineBreak/>
					电流表号侦察船已被指派协调会合程序和时间安排。我们允许你在遥远区域选择一个隐蔽的补给锚地。保障支援部队的安全对于任务的继续进行至关重要。
					<LineBreak/>
					<LineBreak/>
					我们将在确认成功补给后发送进一步的行动指示。
					<LineBreak/>
				</TextBlock>
				<TextBlock Grid.Row="8" Grid.ColumnSpan="4" TextWrapping="Wrap" FontWeight="Bold">
					指令结束
					<LineBreak/>
					/署名/卡皮塔涅茨
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					绝密
					<LineBreak/>
					阅后销毁
				</TextBlock>
			</Grid>
        </StackPanel>
    </Border>
</ScrollViewer>