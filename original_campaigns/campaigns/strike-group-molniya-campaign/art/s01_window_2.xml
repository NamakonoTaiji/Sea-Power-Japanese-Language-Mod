<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">

	<Border Background="#2b2d31" HorizontalAlignment="Center" VerticalAlignment="Center" Height="Auto" Width="900" TextElement.Foreground="#949aa1" TextElement.FontWeight="Bold" TextElement.FontSize="16" Padding="20">

        <StackPanel Orientation="Vertical">
			<TextBlock HorizontalAlignment="Center" FontSize="36">
				INTRODUCTION
			</TextBlock>
			
			<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="#949aa1" Margin="0,0,0,10"/>
			
			<Image Source="{Binding Assets[gorbachev-deng]}" Margin="0,0,0,15"/>
			
			<TextBlock TextWrapping="Wrap">
				1985 — Event 2 description
			</TextBlock>	
			
			<StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
				<Button Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="Next" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/strike-group-molniya-campaign/art/s01_window_2.xml"/>
			</StackPanel>
			<StackPanel Orientation="Horizontal" Margin="0" HorizontalAlignment="Center">
			<Button Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="Back" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/strike-group-molniya-campaign/art/s01_window_1.xml"/>
			<Button Width="100" Height="50" Margin="15" FontSize="16" VerticalAlignment="Bottom" Content="Next" Command="{Binding OpenFileCommand}" CommandParameter="campaigns/strike-group-molniya-campaign/art/s01_window_3.xml"/>
		</StackPanel>
        </StackPanel>
    </Border>
</ScrollViewer>