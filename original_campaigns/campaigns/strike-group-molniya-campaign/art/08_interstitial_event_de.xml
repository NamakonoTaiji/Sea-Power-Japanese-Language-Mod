<!-- Campaign event template USSR dispatch - formatting taken from real world examples -->

<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">

	<Border HorizontalAlignment="Center" VerticalAlignment="Center" Height="UniformToFill" Width="900" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16" Padding="45">
		<Border.Effect>
			<DropShadowEffect />
		</Border.Effect>
		<Border.Background>
			<ImageBrush ImageSource="{Binding Assets[bkg_paper]}" Stretch="UniformToFill"/>
		</Border.Background>
		
        <StackPanel Orientation="Vertical">

		<Grid
		  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" >
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="3*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			
			<TextBlock Grid.Row="0" Grid.Column="0" Text="# 389/PR/52" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
			<TextBlock Grid.Row="1" Grid.Column="0" Text="10.07.85 r." Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
			<TextBlock Grid.Row="0" Grid.Column="1" Text="" Margin="40,0,40,0" FontWeight="Bold" TextAlignment="Center"/>
			<TextBlock Grid.Row="0" Grid.Column="2" Text="Cовершенно cекретно" Margin="0" TextDecorations="Underline" FontSize="20" FontWeight="Bold" TextAlignment="Right"/>
			<TextBlock Grid.Row="1" Grid.Column="2" Text="Экз. № 1" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Center"/>
		</Grid>

				<TextBlock Text="DIREKTIVE Nr.028/85" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
				<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,1"/>
				<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,10"/>

			<Grid
			  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
			<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="10"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="10"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="VON:"/>
				<TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="Kommandant, Rotbanner-Nordflotte"/>
				<TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="AN:"/>
				<TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="Kommandant, Kampfverband MOLNIYA"/>
				<TextBlock Grid.Row="5" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="KOPIE:"/>
				<TextBlock Grid.Row="5" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="Hauptquartier, 8. Operatives Geschwader, Rotbanner-Pazifikflotte"/>
				<TextBlock Grid.Row="6" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="BETREFF:"/>
				<TextBlock Grid.Row="6" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="Weitere Operationen im Indischen Ozean"/>

				<TextBlock Grid.Row="7" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap" FontWeight="Bold">
					<LineBreak/>
					Das Oberkommando bestätigt den Eingang Ihres Gefechts- und Versorgungsberichts vom 09 JUL nach Kampfhandlungen im Raum der Crozet-Inseln. Kraftstoff- und Munitionsbestände werden als ausreichend bewertet, um weitere Operationen zu ermöglichen.
					<LineBreak/>
					<LineBreak/>
					Das Oberkommando spricht den Offizieren und Besatzungen der Schlaggruppe MOLNIYA seine Anerkennung aus. Die den Streitkräften der REPUBLIK SÜDAFRIKA zugefügten Verluste haben deren Regierung gezwungen, Verhandlungen aufzunehmen und Neutralität im Konflikt zu erklären. Widerstand in diesem Gebiet ist nun auf amerikanische Einheiten beschränkt.
					<LineBreak/>
					<LineBreak/>
					Jedoch haben unsere Quellen innerhalb der USA gemeldet, dass der Trägerkampfverband USS Enterprise abgezogen wurde, um Ihren Verband zu vernichten. Direkte Kampfhandlungen gegen diesen Verband würden nach unserer Bewertung ein inakzeptables Risiko für Personal und Material bedeuten, ohne entsprechenden Nutzen zu erzielen.
					<LineBreak/>
					<LineBreak/>
					Sie erhalten daher den Befehl, unverzüglich den Marsch nach Norden in Richtung INDISCHER Gewässer aufzunehmen. Das Oberkommando hat eine Vereinbarung mit der Regierung Indiens getroffen, wonach Ihre Kräfte im Flottenstützpunkt COCHIN Schutz finden. Diese Maßnahme dient dem Erhalt der Kampfgruppe MOLNIYA für zukünftige Operationen und zwingt die USA, weiterhin Kräfte in diesem Gebiet zu binden.
					<LineBreak/>
					<LineBreak/>
					Weitere Weisungen werden übermittelt, sobald verfügbar. Sollten sich Gelegenheiten zum Angriff ergeben, werden diese an Sie weitergegeben. Viel Erfolg, Genossen.
					<LineBreak/>
				</TextBlock>
				<TextBlock Grid.Row="8" Grid.ColumnSpan="4" TextWrapping="Wrap" FontWeight="Bold">
					ENDE DER NACHRICHT
					<LineBreak/>
					/s/ Kapitanets
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					<LineBreak/>
					Cовершенно cекретно
					<LineBreak/>
					После прочтения — уничтожить
				</TextBlock>
			</Grid>
        </StackPanel>
    </Border>
</ScrollViewer>