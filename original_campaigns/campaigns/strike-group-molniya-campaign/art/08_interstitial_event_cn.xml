<!-- Campaign event template USSR dispatch - formatting taken from real world examples -->
<Page
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:SeapowerUI"
  mc:Ignorable="d"
  d:DesignWidth="1920"
  d:DesignHeight="1080">
  <Viewbox>
    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" Height="1272" Padding="45" TextElement.FontFamily="Courier New" TextElement.Foreground="Black" TextElement.FontSize="16">
		<Border.Effect>
			<DropShadowEffect />
		</Border.Effect>
		
		<Border.Background>
			<ImageBrush ImageSource="{Binding Assets[bkg_paper]}" Stretch="UniformToFill"/>
		</Border.Background>
		
        <StackPanel Orientation="Vertical">

		<Grid
		  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" >
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="3*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			
			<TextBlock Grid.Row="0" Grid.Column="0" Text="# 389/PR/52" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
			<TextBlock Grid.Row="1" Grid.Column="0" Text="10.07.85 r." Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
			<TextBlock Grid.Row="0" Grid.Column="1" Text="" Margin="40,0,40,0" FontWeight="Bold" TextAlignment="Center"/>
			<TextBlock Grid.Row="0" Grid.Column="2" Text="绝密" Margin="0" TextDecorations="Underline" FontSize="20" FontWeight="Bold" TextAlignment="Right"/>
			<TextBlock Grid.Row="1" Grid.Column="2" Text="印本编号1" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Center"/>
		</Grid>

				<TextBlock Text="指令编号028/85" Margin="0" FontSize="20" FontWeight="Bold" TextAlignment="Left"/>
				<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,1"/>
				<Rectangle HorizontalAlignment="Stretch" Height="1" Fill="Black" Margin="0,0,0,10"/>

			<Grid
			  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
			<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="10"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="10"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="发件："/>
				<TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="北方舰队司令"/>
				<TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="收件："/>
				<TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="闪电打击群指挥官"/>
				<TextBlock Grid.Row="5" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="抄送："/>
				<TextBlock Grid.Row="5" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="太平洋舰队第8作战分舰队司令"/>
				<TextBlock Grid.Row="6" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="主题："/>
				<TextBlock Grid.Row="6" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" HorizontalAlignment="Left" FontWeight="Bold" Text="在印度洋的进一步行动"/>

				<TextBlock Grid.Row="7" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap" FontWeight="Bold">
					<LineBreak/>
					总部已收到你于7月9日克罗泽群岛之战后提交的交战和补给报告。我们评估你的燃料、弹药和航空物资足以支持你继续进行机动和战斗行动。
					<LineBreak/>
					<LineBreak/>
					总部向闪电打击群的官兵表示祝贺。南非共和国在遭受战损后被迫参与谈判并宣布在冲突中保持中立。我们评估此目前战区内的敌军仅有美军。
					<LineBreak/>
					<LineBreak/>
					然而，我们在美国境内的秘密消息来源已发出警告称位于阿拉伯海的企业号航母战斗群已经开往你的位置，尝试找到并消灭你的部队。我们评估认为继续与敌军交战将造成不可接受的人员伤亡且无法带来相应的行动收益。
					<LineBreak/>
					<LineBreak/>
					因此，你的任务是向北航行至中立的印度海域，避开既定航道和可预测的巡逻航线。指挥部已与印度政府达成协议，在位于科钦的印度海军基地为你的部队提供庇护。此安排将使闪电打击群保存战斗力，以备未来可能的行动之需，并迫使美军继续停留在此战区。
					<LineBreak/>
					<LineBreak/>
					我们将尽快下达进一步行动指示。如有机会出现，你将收到命令。祝你们好运，同志们。
					<LineBreak/>
				</TextBlock>
				<TextBlock Grid.Row="8" Grid.ColumnSpan="4" TextWrapping="Wrap" FontWeight="Bold">
					指令结束
					<LineBreak/>
					/署名/卡皮塔涅茨
					<LineBreak/>
					<LineBreak/>
绝密					
					<LineBreak/>
					阅后销毁
				</TextBlock>
			</Grid>
        </StackPanel>
    </Border>
</Viewbox>
</Page>