<Page
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignWidth="1920"
  d:DesignHeight="1080">
  <Viewbox>
  <Grid Width="1920" Height="1080">
  <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="1120" Height="864" Padding="45" 
            TextElement.Foreground="Black" TextElement.FontSize="16" Background="#FFFAEBD7">
        <Border.RenderTransform>
          <TransformGroup>
            <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
            <SkewTransform/>
            <RotateTransform Angle="-8"/>
            <TranslateTransform X="178" Y="136"/>
          </TransformGroup>
        </Border.RenderTransform>
	  <Border.Effect>
	    <DropShadowEffect />
	  </Border.Effect>
			
	
      <Grid>
		<Grid.RowDefinitions>
		  <RowDefinition Height="Auto"/>
		  <RowDefinition Height="*"/>
		  <RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
        <Image Grid.Row="0" Source="{Binding Assets[NavyDSM]}" Width="153" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-30,0,0"/>
        <Image Grid.Row="2" Source="{Binding Assets[Seal_of_the_United_States_Department_of_Defense]}" Width="100" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
		<StackPanel Grid.Row="1" Orientation="Vertical">
          <TextBlock Text="DEPARTMENT OF THE NAVY" TextWrapping="Wrap" FontFamily="Imprint MT Shadow" FontSize="45" HorizontalAlignment="Center" Margin="0,10,0,0"/>
          <TextBlock Text="TO ALL WHO SHALL SEE THESE PRESENTS, GREETINGS, THIS IS TO VERTIFY THAT THE SECRETARY OF THE NAVY HAS ON THIS DAY AWAREDED THE" TextWrapping="Wrap"  FontFamily="Imprint MT Shadow" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,5,0,0"/>
          <TextBlock Text="DISTINGUISHED SERVICE MEDAL" FontFamily="Imprint MT Shadow" FontSize="45" HorizontalAlignment="Center" Margin="-15,10,-15,0"/>
		  <TextBlock Text="TO" TextWrapping="Wrap" FontFamily="Imprint MT Shadow" TextAlignment="Center" FontSize="24" HorizontalAlignment="Center" Margin="0,5,0,0"/>
          <TextBlock Text="COMMANDER LEE GARDNER JR." TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Courier New" FontWeight="Bold" FontSize="26" Margin="0,5,0,0"/>
          <TextBlock Text="FOR DISTINGUISHED AND EXCEPTIONAL SERVICE TO THE UNITED STATES WHILE SERVING AS COMMANDER FIGHTER SQUADRON EIGHTY FOUR (VF-84) AT ATTU ISLAND ON 2 JUNE 1988. BY HIS EXCEPTIONAL ABILITY AND PERSONAL INITIATIVE, COMMANDER GARDNER REFLECTED GREAT CREDIT UPON HIMSELF AND UPHELD THE HIGHEST TRADITIONS OF THE UNITED STATES NAVAL SERVICE." TextWrapping="Wrap" Margin="0,10,0,0" FontFamily="Courier New" FontSize="20" FontWeight="Bold"/>
		</StackPanel>
		<TextBlock Grid.Row="2" TextWrapping="Wrap" FontFamily="Imprint MT Shadow" VerticalAlignment="Center" FontSize="12">
GIVEN UNDER MY HAND IN THE CITY OF WASHINGTON, DC
<LineBreak/>
THIS <Run FontFamily="Courier New" FontWeight="Bold" FontSize="18">18TH</Run> DAY OF  <Run FontFamily="Courier New" FontWeight="Bold" FontSize="18">JUNE 1988</Run>
		</TextBlock>
		<StackPanel Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center">
		  <TextBlock Text="David J Osborne" FontFamily="Brush Script MT" FontSize="60" Margin="0,0,0,-15"/>
		  <Rectangle Height="1" Fill="#FF000000" Margin="15,0,15,0"/>
          <TextBlock FontFamily="Imprint MT Shadow" Text="David J Osborne, NVSFCTA" TextAlignment="Center"/>
		</StackPanel>
      </Grid>
    </Border>
    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="1120" Height="864" Padding="45" 
            TextElement.Foreground="Black" TextElement.FontSize="16" Background="#FFFAEBD7">
        <Border.RenderTransform>
          <TransformGroup>
            <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
            <SkewTransform/>
            <RotateTransform Angle="-20"/>
            <TranslateTransform X="-382" Y="204"/>
          </TransformGroup>
        </Border.RenderTransform>
	  <Border.Effect>
	    <DropShadowEffect />
	  </Border.Effect>
			
	
      <Grid>
		<Grid.RowDefinitions>
		  <RowDefinition Height="Auto"/>
		  <RowDefinition Height="*"/>
		  <RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
        <Image Grid.Row="0" Source="{Binding Assets[Navy_Cross]}" Width="153" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-30,0,0"/>
        <Image Grid.Row="2" Source="{Binding Assets[Seal_of_the_United_States_Department_of_Defense]}" Width="100" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
		<StackPanel Grid.Row="1" Orientation="Vertical">
          <TextBlock Text="THE UNITED STATES OF AMERICA" TextWrapping="Wrap" FontFamily="Imprint MT Shadow" FontSize="45" HorizontalAlignment="Center" Margin="0,10,0,0"/>
          <TextBlock TextWrapping="Wrap"  FontFamily="Imprint MT Shadow" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,5,0,0" Text="THE PRESIDENT OF THE UNITED STATES OF AMERICA HAS AWARDED THE"/>
          <TextBlock Text="NAVY CROSS" FontFamily="Imprint MT Shadow" FontSize="45" HorizontalAlignment="Center" Margin="-15,10,-15,0"/>
		  <TextBlock Text="TO" TextWrapping="Wrap" FontFamily="Imprint MT Shadow" TextAlignment="Center" FontSize="24" HorizontalAlignment="Center" Margin="0,5,0,0"/>
          <TextBlock Text="COMMANDER EDWARD G. MEYER III" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Courier New" FontWeight="Bold" FontSize="26" Margin="0,5,0,0"/>
          <TextBlock Text="FOR DISTINGUISHED AND EXCEPTIONAL SERVICE TO THE UNITED STATES WHILE SERVING AS COMMANDER TASK FORCE 75.3 OFF ATTU ISLAND ON 2 JUNE 1988. BY HIS EXCEPTIONAL ABILITY, PERSONAL INITIATIVE, AND TOTAL DEDICATION TO DUTY, CDR MEYER REFLECTED GREAT CREDIT UPON HIMSELF AND UPHELD THE HIGHEST TRADITIONS OF THE UNITED STATES NAVAL SERVICE." TextWrapping="Wrap" Margin="0,10,0,0" FontFamily="Courier New" FontSize="20" FontWeight="Bold"/>
		</StackPanel>
		<TextBlock Grid.Row="2" TextWrapping="Wrap" FontFamily="Imprint MT Shadow" VerticalAlignment="Center" FontSize="12">
GIVEN UNDER MY HAND IN THE CITY OF WASHINGTON, DC
<LineBreak/>
THIS <Run FontFamily="Courier New" FontWeight="Bold" FontSize="18">12TH</Run> DAY OF  <Run FontFamily="Courier New" FontWeight="Bold" FontSize="18">JUNE 1988</Run>
		</TextBlock>
		<StackPanel Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center">
		  <TextBlock Text="Donald G Watson" FontFamily="Brush Script MT" FontSize="60" Margin="0,0,0,-15"/>
		  <Rectangle Height="1" Fill="#FF000000" Margin="15,0,15,0"/>
          <TextBlock FontFamily="Imprint MT Shadow" Text="Donald G Watson, SFCTA" TextAlignment="Center"/>
		</StackPanel>
      </Grid>
    </Border>
      <Image Source="{Binding Assets[United_States_Navy_Presidential_Unit_Citation_ribbon]}" Width="250" Margin="904,102,-34,694">
        <Image.RenderTransform>
          <TransformGroup>
            <ScaleTransform/>
            <SkewTransform/>
            <RotateTransform Angle="19"/>
            <TranslateTransform/>
          </TransformGroup>
        </Image.RenderTransform>
        <Image.Effect>
          <DropShadowEffect/>
        </Image.Effect>
      </Image>
      <Image Width="250" Source="{Binding Assets[Navy_Distinguished_Service_Medal_ribbon]}" Margin="955,419,-85,377">
        <Image.RenderTransform>
          <TransformGroup>
            <ScaleTransform/>
            <SkewTransform/>
            <RotateTransform Angle="-7"/>
            <TranslateTransform/>
          </TransformGroup>
        </Image.RenderTransform>
        <Image.Effect>
          <DropShadowEffect/>
        </Image.Effect>
      </Image>
      <Image Width="250" Source="{Binding Assets[Navy_Cross_ribbon]}" Margin="948,690,-78,106">
        <Image.RenderTransform>
          <TransformGroup>
            <ScaleTransform/>
            <SkewTransform/>
            <RotateTransform Angle="-31"/>
            <TranslateTransform/>
          </TransformGroup>
        </Image.RenderTransform>
        <Image.Effect>
          <DropShadowEffect/>
        </Image.Effect>
      </Image>
	</Grid>
  </Viewbox>
</Page>